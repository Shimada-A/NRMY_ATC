@using Wms.Helpers;
@model Wms.Areas.Master.ViewModels.User.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_User01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "User", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table>
            <tr>
                <td class="tdtitle">@UserResource.CenterIdSearch</td>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.CenterDropDownFor(model => model.SearchConditions.CenterId, Wms.Common.Profile.User.UserId, UserResource.Unspecified, new { @id = "ddlSerchCenter", tabindex = "1" })
                        </div>
                    </div>
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@UserResource.UserIdSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.UserId, new { htmlAttributes = new { @class = "w_14_long", @id = "txtUserId", tabindex = "1" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@UserResource.UserNameSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.UserName, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtUserName", tabindex = "2" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td></td>
                <td>
                </td>
                <td>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "User", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="4" onclick="$('#frmSearch').submit()">@FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.SearchFlag, new { id = "hidSearchFlag" })
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.UserResult.Users != null)
{
    if (Model.UserResult.Users.Count() > 0)
    {
        <div class="sublbarea no_border" style="height:54px;margin-right:40px;margin-bottom: -10px;">
            <div class="sortarea">
                <ul>
                    @if (ViewBag.PermissionLevel == PermissionLevelClasses.PermissionLevelSystemManager)
                    {
                        <li>
                            <button type="button" id="btnPrintA4" class="download" style="width:200px">
                                <img src="~/Content/img/print.png" />
                                @UserResource.BtnPrintA4
                            </button>
                        </li>
                    }
                    <li hidden>
                        <button type="button" id="btnGasDownload" class="download" style="width:140px">
                            <img src="~/Content/img/download.png" />
                            @UserResource.BTN_GAS_DOWNLOAD
                        </button>
                    </li>
                    <li>
                        <button type="button" id="btnDownload" class="download" style="width:140px">
                            <img src="~/Content/img/download.png" />
                            @FormsResource.BTN_DOWNLOAD
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    }
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.UserResult.Users.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.UserResult.Users.Count() > 0)
            {
                @Html.PagedListPager(Model.UserResult.Users, Page => Url.Action("Search", "User", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.UserResult.Users.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:71vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey">&nbsp;</th>
                                <th class="bg-grey">
                                    @UserResource.No
                                </th>
                                <th class="bg-grey">
                                    @UserResource.CenterId
                                </th>
                                <th class="bg-grey">
                                    @UserResource.UserId
                                </th>
                                <th class="bg-grey">
                                    @UserResource.UserName
                                </th>
                                <th class="bg-grey">
                                    @UserResource.PermissionLevel
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        @using (Html.BeginForm("Edit", "User", FormMethod.Post, new { id = "frmUpdate" }))
                        {
                            <tbody>
                                @Html.AntiForgeryToken()
                                @Html.Partial("_DeleteConfirmMessageDialog", @MessagesResource.QUE_DELETE)
                                @foreach (var cModel in Model.UserResult.Users.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Users[{0}].", cModel.i);
                                    <tr>
                                        <td class="w_checkbox align-middle">
                                            <label class="checkboxgroup">
                                                @Html.CheckBox(key + "IsCheck", new { @id = (key + "CheckedValue"), @class = "check-box" })
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.UserResult.Users.PageNumber - 1) * Model.UserResult.Users.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CenterName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.UserId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.UserName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.PermissionLevelName)
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.CenterId, new { Name = key + "CenterId" })
                                            @Html.HiddenFor(modelItem => cModel.v.UserId, new { Name = key + "UserId", @class = "rowid" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                            @Html.HiddenFor(modelItem => cModel.v.ShipperId, new { Name = key + "ShipperId" })
                                            @Html.HiddenFor(modelItem => cModel.v.DateMakeClass, new { Name = key + "DateMakeClass" })
                                            @Html.HiddenFor(modelItem => cModel.v.DeleteFlag, new { Name = key + "DeleteFlag" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <input id="hiddata" type="hidden" name="userId" />
                        }
                    </table>
                </div>
            </div>
        }
    </div> }

@*Bottomnav*@
@section Basefooter{
    @Html.Partial("_CheckBoxCounter")
    <div class="btnarea">
        <button type="submit" id="btnInsert" class="btn btn-outline-dark btnsize" form="frmSearch" formmethod="get" formaction=@Url.Action("Insert", "User", new { area = "Master", controller = "Insert", action = "Create" })>@FormsResource.BTN_NEW</button>
        @*@Html.ActionLink(FormsResource.BTN_NEW, "Insert", "User", null, new { @class = "btn btn-outline-dark btnsize _pm", @id = "lnkCreate", tabindex = "1001" })*@
        <button id="btnDeleteHidden" type="button" class="btn btn-outline-danger btnsize _pm _part" data-toggle="modal" data-target="#delconfirm" hidden>@FormsResource.BTN_DELETE</button>
        <button type="submit" id="btnDelete" class="btn btn-outline-danger btnsize _pm _part">@FormsResource.BTN_DELETE</button>
        <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "User", new { area = "Master", controller = "User", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        var UsersView = {
            /**
             * CONST Object
             */
            CONST: {
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                FORM: 'form',
                METHOD: 'method',
                ACTION: 'action'
            },

            /**
             * SELECTORS Object
             */
            SELECTORS: {
                chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
                chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
                chkInRow: 'input[type=checkbox][class=check-box]',
                tblRow: '#listData tbody tr',
                btnCheckAll: '#rbCheckAll',
                btnUnCheckAll: '#rbUnCheckAll',
                rowSelected: '#spnCheckedCounter',
                chkChecked: ':checkbox:checked',
                chkLabel: '#listData span.chk_parts',
                form: 'form',
                searchForm: '#frmSearch',
                frmUpdate: 'frmUpdate',
                btnDelete: '#btnDelete',
                btnUpdate: '#btnUpdate',
                btnSearch: '#btnSearch',
                btnInsert: '#btnInsert',
                btnSubmit: 'button[type=submit],input[type=submit]'
            },

            /**
                * Init data
                */
            init: function () {
                this.registerEvent();

                this.setCheckboxs();

                this.setButtonStatus();
            },

            /**
            * Register event for control
            */
            registerEvent: function () {

                /**
                * Stop event fired when click to checkbox
                */
                $(UsersView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                * Check box click
                */
                $(UsersView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    UsersView.setButtonStatus();
                });

                /**
                * Button check all clicked
                */
                $(UsersView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $(UsersView.SELECTORS.chkInTable).prop('checked', true);
                        UsersView.setRowidsFlag(true);
                    }
                });

                /**
                * Button UnCheck all clicked
                */
                $(UsersView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $(UsersView.SELECTORS.chkInTable).prop('checked', false);
                        UsersView.setRowidsFlag(false);
                    }
                });


                $(UsersView.SELECTORS.btnSearch).click(function () {
                    UsersView.setStorageInit();
                    $("#hidSearchFlag").val(true);
                    var urlAction = '@Url.Action("Search", "User", new { area = "Master" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "GET");
                    $form.submit();
                });

                $(UsersView.SELECTORS.btnInsert).click(function () {
                    var urlAction = '@Url.Action("Insert", "User", new { area = "Master" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "GET");
                    $form.submit();
                });

                $(UsersView.SELECTORS.btnUpdate).click(function () {
                    var list = UsersView.getCheckList();
                    $("#hiddata").val(list[0]);

                    var urlAction = '@Url.Action("Edit" , "User" , new { area = "Master"})';
                    frmUpdate.attr("action", urlAction);
                    frmUpdate.attr("method", "POST");
                    $("#frmUpdate").submit();
                    //UsersView.setStorageInit();
                });


                $(UsersView.SELECTORS.btnDelete).click(function () {
                    var list = UsersView.getCheckList();
                    //UsersView.setStorageInit();
                    $("#hiddata").val(JSON.stringify(list));

                    var urlAction = '@Url.Action("Delete", "User", new { area= "Master" })';
                    $("#frmUpdate").attr("action", urlAction);
                    $("#frmUpdate").attr("method", "POST");
                    $('#btnDeleteHidden').click();
                });
            },

            /**
                * Enable/Disable button Edit
                */
            setButtonStatus: function () {
                // save page
                UsersView.setCheckboxs('set')
            },

            // save page
            setRowidsFlag: function (flag) {
                var storage = window.localStorage;
                var rowids = storage.getItem('PKeys');
                if (rowids != null) {
                    var jrid = JSON.parse(rowids);
                    $.each(jrid, function (key) {
                        jrid[key] = flag;
                    });
                    storage.setItem('PKeys', JSON.stringify(jrid));
                }
                UsersView.setButtonStatus();
            },

            setCheckboxs: function (flag) {
                var storage = window.localStorage;
                var rowids = storage.getItem('PKeys');
                if (rowids != null) {
                    var cnt = 0;
                    var jrid = JSON.parse(rowids);
                    var checkboxs = $("#listData input[type=checkbox]")
                    checkboxs.each(function () {
                        var row = $(this).parent().parent().parent();
                        var rowid = row.find(".rowid").val();
                        //var idx = rowid - 1;
                        //var Rid = $("input[name='LocTransporters[" + idx + "].Rid']").val();

                        if (flag == 'set') {
                            jrid[rowid] = $(this).is(':checked');
                        }
                        else {
                            if (jrid[rowid]) {
                                $(this).prop("checked", true);
                            }
                        }
                    });

                    if (flag == 'set') {
                        storage.setItem('PKeys', JSON.stringify(jrid));
                    }

                    $.each(jrid, function (key, value) {
                        if (value) {
                            cnt++;
                        }
                    });


                    $(UsersView.SELECTORS.btnDelete).attr('disabled', 'disabled');
                    $(UsersView.SELECTORS.btnUpdate).attr('disabled', 'disabled');

                    if ($('#frmUpdate').length > 0) {
                        if (cnt > 0) {
                            if (getUsable_Class() == 3) {
                                $(UsersView.SELECTORS.btnDelete).removeAttr('disabled');
                            }
                            if (cnt == 1) {
                                $(UsersView.SELECTORS.btnUpdate).removeAttr('disabled');
                            }
                        }

                        $(UsersView.SELECTORS.rowSelected).text(cnt);
                    }
                }
            },

            setStorageInit: function () {
                if (window.localStorage) {

                    var storage = window.localStorage;
                    storage.removeItem('PKeys');
                    var data = {
                        'SearchConditions.CenterId': $("#ddlSerchCenter").val(),
                        'SearchConditions.UserId': $("#txtUserId").val(),
                        'SearchConditions.UserName': $("#txtUserName").val()
                    };


                    $.ajax({
                        type: "post",
                        url: "@Url.Action("GetPKeys", "User")",
                        data: data,
                        async: false,
                        success: function (data) {
                            var rowids = {};
                            $.each(data, function (n, value) {
                                rowids[value] = false;
                            });

                            var storage = window.localStorage;
                            storage.setItem('PKeys', JSON.stringify(rowids));

                        }
                    });
                }
            },

            getCheckList: function () {
                var list = [];
                var storage = window.localStorage;
                rowids = storage.getItem('PKeys');
                if (rowids != null) {

                    var jrid = JSON.parse(rowids);
                    $.each(jrid, function (key) {
                        if (jrid[key]) {
                            list.push(key);
                        }
                    });
                }

                return list;
            },
        }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        if ('@TempData[AppConst.SUCCESS]' != '') {
            UsersView.setStorageInit();
        }
        UsersView.init();

        $("#btnDownload").on("click", function () {
            var urlAction = '@Url.Action("Download", "User", new { area = "Master" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();

            setTimeout(function () {
                var count = UsersView.getCheckList().length;
                if (count == 1) {
                    $(UsersView.SELECTORS.btnUpdate).prop("disabled", false);
                }

                if (count >= 1) {
                    if (getUsable_Class() == 3) {
                        $(UsersView.SELECTORS.btnDelete).prop('disabled', false);
                    }
                }
                $("#btnInsert").prop("disabled", false);
            }, 1000);
        });
        $("#btnGasDownload").on("click", function () {
            var urlAction = '@Url.Action("GasDownload", "User", new { area = "Master" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        $("#btnPrintA4").on("click", function () {
            var urlAction = '@Url.Action("PrintA4", "User", new { area = "Master" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            //$form.attr("target", "newtab");
            $form.submit();
            //$form.attr("target", "_self");

            setTimeout(function () {
                var count = UsersView.getCheckList().length;
                if (count == 1) {
                    $(UsersView.SELECTORS.btnUpdate).prop("disabled", false);
                }

                if (count >= 1) {
                    $(UsersView.SELECTORS.btnDelete).prop('disabled', false);
                }
                $("#btnInsert").prop("disabled", false);
            }, 1000);

        });
    });
    function ClearConditons() {
        $("#txtUserId").val("");
        $("#txtUserName").val("");
    }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "User", new { area= "Master" })';
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        }

    </script>
}