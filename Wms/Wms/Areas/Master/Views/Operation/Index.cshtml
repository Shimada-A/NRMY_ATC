@model Wms.Areas.Master.ViewModels.Operation.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_Operation01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Operation", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table>
            <tr style="height:5vh">
                <th>
                    @OperationResource.Category：
                </th>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.CategoryName,
                                (IEnumerable<SelectListItem>)ViewBag.CategoryNameList,
                                CommonResource.None, new { id = "ddlCategoryName", tabindex = "1" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <th class="tdtitle_13">@OperationResource.Operation：</th>
                <td colspan="2">
                    @Html.EditorFor(model => model.SearchConditions.OperationId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtOperationId", tabindex = "2" } })
                    &nbsp;
                    @Html.EditorFor(model => model.SearchConditions.OperationName, new { htmlAttributes = new { @class = "w_14_long", @id = "txtOperationName", tabindex = "3" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
            <tr>
                <td>
                </td>
                <td>
                </td>
                <td>
                </td>
                <td>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "Operation", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark", tabindex = "3" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="4">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.SearchFlag, new { id = "hidSearchFlag"})
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.OperationResult.Operations != null)
{
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.OperationResult.Operations.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.OperationResult.Operations.Count() > 0)
            {
                @Html.PagedListPager(Model.OperationResult.Operations, Page => Url.Action("Search", "Operation", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.OperationResult.Operations.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:65vh;">

                    @using (Html.BeginForm("Edit", "Operation", FormMethod.Post, new { id = "frmUpdate" }))
                    {
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey">&nbsp;</th>
                                    <th class="bg-grey">
                                        @OperationResource.No
                                    </th>
                                    <th class="bg-grey">
                                        @OperationResource.CategoryName
                                    </th>
                                    <th class="bg-grey">
                                        @OperationResource.OperationId
                                    </th>
                                    <th class="bg-grey">
                                        @OperationResource.OperationName
                                    </th>
                                    <th hidden>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @Html.AntiForgeryToken()
                                @Html.Partial("_DeleteConfirmMessageDialog", @MessagesResource.QUE_DELETE)
                                @foreach (var cModel in Model.OperationResult.Operations.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Operations[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle w_checkbox">
                                            <label class="checkboxgroup">
                                                @Html.CheckBox(key + "IsCheck", new { @id = (key + "CheckedValue"), @class = "check-box" })
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.OperationResult.Operations.PageNumber - 1) * Model.OperationResult.Operations.PageSize)
                                        </td>
                                        <td class="aligin-middle">
                                            @Html.DisplayFor(modelitem => cModel.v.CategoryName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.OperationId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.OperationName)
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.OperationId, new { Name = key + "OperationId", @id = key + "txtOperationId" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount", @id = key + "hidUpdateCount" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <input id="hiddata" type="hidden" name="operationId" />
                    }
                </div>
            </div>
        }
    </div>
}

@*Bottomnav*@
@section Basefooter{
    @Html.Partial("_CheckBoxCounter")
<div class="btnarea">
    @if (Wms.Common.Profile.User.GetUsable_Class(Request.Url) != "1")
    {
        <button type="submit" id="btnCreate" class="btn btn-outline-dark btnsize" form="frmSearch" formmethod="get" formaction=@Url.Action("Create", "Operation", new { area = "Master", controller = "Operation", action = "Create" })>@FormsResource.BTN_NEW</button>
        @*@Html.ActionLink(FormsResource.BTN_NEW, "Create", "Operation", null, new { @class = "btn btn-outline-dark btnsize _pm", @id = "lnkCreate", tabindex = "1001" })*@
        <button type="submit" id="btnDelete" class="btn btn-outline-danger btnsize _pm">@FormsResource.BTN_DELETE</button> }
    else
    {
        <button type="submit" id="lnkCreate" class="btn btn-outline-dark btnsize _pm" disabled>@FormsResource.BTN_NEW</button>
        <button type="submit" id="btnDelete" class="btn btn-outline-danger btnsize _pm" disabled>@FormsResource.BTN_DELETE</button>
    }
    <button id="btnDeleteHidden" type="button" class="btn btn-outline-danger _pm" data-toggle="modal" data-target="#delconfirm" hidden>@FormsResource.BTN_DELETE</button>
    <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "Operation", new { area = "Master", controller = "Operation", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
</div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
    var OperationsView = {
        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            btnDelete: '#btnDelete'
        },

        /**
         * Init data
         */
        init: function () {
            this.registerEvent();
            this.setCheckboxs();
            this.setButtonStatus();
        },

        /**
        * Register event for control
        */
        registerEvent: function () {

            /**
            * Stop event fired when click to checkbox
            */
            $("#listData span.chk_parts").click(function (evt) {
                evt.stopPropagation();
            });

            /**
            * Check box click
            */
            $(OperationsView.SELECTORS.chkInTable).click(function (evt) {
                evt.stopPropagation();
                OperationsView.setButtonStatus();
            });

            /**
            * Button check all clicked
            */
            $("#rbCheckAll").click(function () {
                if ($("#listData").length) {
                    $(OperationsView.SELECTORS.chkInTable + ':enabled').prop('checked', true);
                    OperationsView.setRowidsFlag(true);
                }
            });

            /**
            * Button UnCheck all clicked
            */
            $("#rbUnCheckAll").click(function () {
                if ($("#listData").length) {
                    $(OperationsView.SELECTORS.chkInTable).prop('checked', false);
                    OperationsView.setRowidsFlag(false);
                }
            });

            $("#btnSearch").click(function () {
                OperationsView.setStorageInit();
                $("#hidSearchFlag").val(true)
                var urlAction = '@Url.Action("Search", "Operation", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();
            });

            $("#btnCreate").click(function () {
                var urlAction = '@Url.Action("Create", "Operation", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();
            });

            $("#btnUpdate").click(function () {
                var target = $("#hiddata").val();
                if (target == "") {
                    var list = OperationsView.getCheckList();
                    $("#hiddata").val(list[0]);
                } else {
                    $("#hiddata").val(JSON.parse(target)[0]);
                }
                var urlAction = '@Url.Action("Edit", "Operation", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $("#frmUpdate").attr("method", "POST");
                $("#frmUpdate").submit();

            //    OperationsView.setStorageInit();
            });

            $(OperationsView.SELECTORS.btnDelete).click(function () {
                var list = OperationsView.getCheckList();
                //OperationsView.setStorageInit();
                $("#hiddata").val(JSON.stringify(list));

                var urlAction = '@Url.Action("Delete", "Operation", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $('#btnDeleteHidden').click();
            });

        },

        /**
         * Enable/Disable button Edit
         */
        setButtonStatus: function () {
            OperationsView.setCheckboxs('set')
        },

        // save page
        setRowidsFlag: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    jrid[key] = flag;
                });
                storage.setItem('PKeys', JSON.stringify(jrid));
            }
            OperationsView.setButtonStatus();
        },

        setCheckboxs: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var cnt = 0;
                var jrid = JSON.parse(rowids);
                var checkboxs = $("#listData input[type=checkbox]:enabled")
                checkboxs.each(function () {
                    var row = $(this).parent().parent().parent();

                    var rowid = row.find($("[name$= 'OperationId']")).val();
                    if (flag == 'set') {
                        jrid[rowid] = $(this).is(':checked');
                    }
                    else {
                        if (jrid[rowid]) {
                            $(this).prop("checked", true);
                        }
                    }
                });

                if (flag == 'set') {
                    storage.setItem('PKeys', JSON.stringify(jrid));
                }

                $.each(jrid, function (key, value) {
                    if (value) {
                        cnt++;
                    }
                });

                $("#btnDelete").attr('disabled', 'disabled');
                $("#btnUpdate").attr('disabled', 'disabled');

                if ($('#frmUpdate').length > 0) {
                    if (cnt > 0) {
                        if (getUsable_Class() == 3) {
                            $("#btnDelete").removeAttr('disabled');
                        }
                        if (cnt == 1) {
                            $("#btnUpdate").removeAttr('disabled');
                        }
                    }

                    $("#spnCheckedCounter").text(cnt);
                }
            }

        },

        setStorageInit: function () {
            if (window.localStorage) {

                var storage = window.localStorage;
                storage.removeItem('PKeys');
                var data = {
                    'SearchConditions.OperationId': $("#txtOperationId").val(),
                    'SearchConditions.OperationName': $("#txtOperationName").val(),
                    'SearchConditions.CategoryName': $("#ddlCategoryName").val()
                };

                $.ajax({
                    type: "post",
                    url: "@Url.Action("GetPKeys", "Operation", new { area = "Master" })",
                    data: data,
                    async: false,
                    success: function (data) {
                        var rowids = {};
                        $.each(data, function (n, value) {
                            rowids[value] = false;
                        });
                        var storage = window.localStorage;
                        storage.setItem('PKeys', JSON.stringify(rowids));

                    }
                });
            }
        },

        getCheckList: function () {
            var list = [];
            var storage = window.localStorage;
            rowids = storage.getItem('PKeys');

            if (rowids != null) {

                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    if (jrid[key]) {
                        list.push(key);
                    }
                });
            }
            return list;
        },

    }


    /**
    * Page loaded
    */
    //$(document).ready(function () {
    //    OperationsView.init();
    //});

        $(document).ready(function () {
            if ('@TempData[AppConst.SUCCESS]' != '') {
                OperationsView.setStorageInit();
            }
            OperationsView.init();
        });

    // Sort
    function getSortData() {

        $("#hidSort").val($("#ddlSort").val());
        $("#hidSortKey").val($("#ddlSortKey").val());

        var $form = $("#frmSearch");
        var urlAction ='@Url.Action("Search", "Operation", new { area= "Master" })';
        $form.attr("action", urlAction);
        $form.attr("method", "GET");
        $form.submit();
    }
    </script>
}