@using Wms.Areas.Master.Resources;
@using CResource = Wms.Common.Resources;
@using PagedList.Mvc;
@using Wms.Areas.Master.Extensions;
@using Wms.Helpers;
@using Wms.Areas.Master.Controllers;
@using Wms.Common;
@using Wms.Areas.Master.Resources;
@using PagedList.Mvc;

@model Wms.Areas.Master.ViewModels.EditLayout.EditOutput
@Html.HiddenFor(model => model.ObjectId)
<div class="detail Container">
    <div class="Container" style="min-width:60vh;">
        <label>
            @EditLayoutResource.TableInfo
        </label>
        <div class="tb_scroll" style="height:65vh;">
            <table class="table table-bordered" id="objectData">
                <thead>
                    <tr>
                        <th class="bg-grey">
                            @EditLayoutResource.No
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.ItemName
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.DataType
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cModel in Model.ObjectDetails.Select((v, i) => new { v, i }))
                    {
                        var key = String.Format("ObjectDetails[{0}].", cModel.i);
                        <tr>
                            <td class="align-middle text-right w_no  tno">
                                @Html.HiddenFor(model => model.ObjectDetails[cModel.i].ShipperId)
                                @Html.HiddenFor(model => model.ObjectDetails[cModel.i].TemplateId)
                                @Html.HiddenFor(modelItem => Model.ObjectDetails[cModel.i].ColumnId)
                                @Html.HiddenFor(modelItem => Model.ObjectDetails[cModel.i].ObjectId)
                                @Html.HiddenFor(model => model.ObjectDetails[cModel.i].DigitInt, new { @id=key+"Digit",@name=key+"Digit"})
                                @Html.DisplayAndHiddenFor(modelItem => Model.ObjectDetails[cModel.i].ColumnNo)
                            </td>
                            <td class="output-title">
                                @Html.DisplayAndHiddenFor(modelItem => Model.ObjectDetails[cModel.i].ColumnName)
                            </td>
                            <td class="data-type">
                                @Html.HiddenFor(model => Model.ObjectDetails[cModel.i].DataType)
                                @Html.DisplayAndHiddenFor(modelItem => Model.ObjectDetails[cModel.i].DataTypeName)
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
    <div class="Container" style="margin-left:10px;margin-right:10px;">
        <div id="setAll" style="margin-top:100px;">>></div>
    </div>
    <div class="Container">
        <label>
            @EditLayoutResource.EditOutputFile
        </label>
        <div class="tb_scroll" style="height:65vh;">
            <table class="table table-bordered" id="outputFiles">
                <thead>
                    <tr>
                        <th class="bg-grey tno">
                            @EditLayoutResource.No
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.OutputTitle
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.ByteCount
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.PadChar
                        </th>
                        <th class="bg-grey">
                            @EditLayoutResource.PadDirection
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cModel in Model.EditOutputFileDetails.Select((v, i) => new { v, i }))
                    {
                        var key = String.Format("EditOutputFileDetails[{0}].", cModel.i);
                        <tr>
                            <td class="text-right w_no ">
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].IsNewData)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].ShipperId)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].TemplateId)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].RowNo)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].ColumnId)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].ObjectId)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].SubNo)
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].DataType)
                                @Html.EditorFor(model => model.EditOutputFileDetails[cModel.i].ColumnNo
                                    , new { htmlAttributes = new { @class = "tno no-spin", @type = "number", @onchange = string.Format("changedColumnNo({0})", cModel.i) } })
                                @Html.ValidationMessageFor(model => model.EditOutputFileDetails[cModel.i].ColumnNo)
                            </td>
                            <td>
                                @Html.EditorFor(model => model.EditOutputFileDetails[cModel.i].ColumnName
                                   , new { htmlAttributes = new { @class = "output-title" } })
                                @Html.ValidationMessageFor(model => model.EditOutputFileDetails[cModel.i].ColumnName)
                            </td>
                            <td class="byte-count">
                                @Html.EditorFor(model => model.EditOutputFileDetails[cModel.i].Digit
                                    , new { htmlAttributes = new { @class = "byte-count" } })
                            </td>
                            <td>
                                @Html.HiddenFor(model => model.EditOutputFileDetails[cModel.i].PadClass)
                                @Html.EditorFor(model => model.EditOutputFileDetails[cModel.i].PadValue
                                    , new { htmlAttributes = new { @class = "pad-value", id = key + "PadValue", maxlength = 1 } })

                                     @Html.ValidationMessageFor(model => model.EditOutputFileDetails[cModel.i].PadValue)
                            </td>
                            <td>
                                @Html.EnumDropDownListFor(model => model.EditOutputFileDetails[cModel.i].PadDirection)
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>
    </div>
</div>

<scripts>




</scripts>