                AddLocTransporter();
                $(this).attr("data-dismiss", "modal");

                //Enterキーを押すと次のIndexへ移動(誤送信を防止するため)
                $("input").on("keydown", function (e) {
                    if (e.which == 13) {
                        e.preventDefault();
                        var inputObj = $("input:visible");
                        var nextIndex = inputObj.index(this) + 1;
                        if (inputObj[nextIndex]) {
                            $("input:visible")[nextIndex].focus();
                        }
                    }
                });
            }
            else {
                $(this).removeAttr("data-dismiss");
            }

            window.localStorage.setItem('Pop_PKeys', JSON.stringify({}));
            $("#tb_pop tbody tr input[type=checkbox]").prop("checked", false);

            enableSubmit();
            adjustScroll();
        });

