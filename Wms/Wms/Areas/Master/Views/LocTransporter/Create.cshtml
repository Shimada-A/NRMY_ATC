@section LayoutScripts{
    <script type="text/javascript">
    var LocTransporterMasterEdit = {
        /**
        * Constants
        */
        CONST: {
            ERR_EXCLUSIVE_UPDATE: 'ERR_EXCLUSIVE_UPDATE',
            ATTR_ERROR_CODE: 'errorcode',
            STR_TRUE: 'True',
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            GET: 'get'
        },

        /**
         * Global variables
         */
        GLOBAL: {
            textChanged: false,
            msgExclusiveUpdate: '@MessagesResource.ERR_EXCLUSIVE_UPDATE',
            titleInformation: '@MessagesResource.TITLE_INFORMATION',
        },

        /**
         * Jquery selector
         */
        SELECTORS: {
            form: 'form',
            frmUpdate: 'frmInsert',
            hdUpdateError: '#hdUpdateError',
            btnSubmitExclusiveUpdateDialog: '#exclusiveUpdateDialog button[type="submit"]',
            exclusiveUpdateDialog: 'exclusiveUpdateDialog',
            chkInTable: '#tb_loc input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#tb_loc input[type=checkbox][id$=".CheckedValue"]:checked',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            chkChecked: ':checkbox:checked',
            chkLabel: '#tb_loc span.chk_parts',
        },

        /**
         * Init function
         */
        init: function () {
            // Set up event
            this.setUpEvent();

            this.setStorageInit();
            this.setCheckboxs();

            // check error when update
            this.checkUpdateError();
        },

        /**
         * Set up event
         */
        setUpEvent: function () {
            $('#tb_loc').width($('#table_AllUpdate').width());
            $('#tb_AllUpdate_btnAllUpdate').width($('#th_check').width() + $('#th_No').width() + $('#th_ShipToStore').width() + $('#th_ShipStore').width());
            $('#tb_AllUpdate_StartDate').width($('#th_TekiyouStartDate').width());
            $('#tb_AllUpdate_MainTransporter').width($('#th_MainTransporter').width());
            $('#tb_AllUpdate_MainLeadTimes').width($('#th_MainLeadTime').width());
            $('#tb_Transporter_Mon').width($('#th_Transporter_Mon').width());
            $('#tb_LeadTime_Mon').width($('#th_LeadTime_Mon').width());
            $('#tb_Transporter_Tue').width($('#th_Transporter_Tue').width());
            $('#tb_LeadTime_Tue').width($('#th_LeadTime_Tue').width());
            $('#tb_Transporter_Wed').width($('#th_Transporter_Wed').width());
            $('#tb_LeadTime_Wed').width($('#th_LeadTime_Wed').width());
            $('#tb_Transporter_Thu').width($('#th_Transporter_Thu').width());
            $('#tb_LeadTime_Thu').width($('#th_LeadTime_Thu').width());
            $('#tb_Transporter_Fri').width($('#th_Transporter_Fri').width());
            $('#tb_LeadTime_Fri').width($('#th_LeadTime_Fri').width());
            $('#tb_Transporter_Sat').width($('#th_Transporter_Sat').width());
            $('#tb_LeadTime_Sat').width($('#th_LeadTime_Sat').width());
            $('#tb_Transporter_Sun').width($('#th_Transporter_Sun').width());
            $('#tb_LeadTime_Sun').width($('#th_LeadTime_Sun').width());
            $('#tb_Transporter_Hol').width($('#th_Transporter_Hol').width());
            $('#tb_LeadTime_Hol').width($('#th_LeadTime_Hol').width());
            /**
            * Stop event fired when click to checkbox
            */
            $(LocTransporterMasterEdit.SELECTORS.chkLabel).click(function (evt) {
                evt.stopPropagation();
            });

            /**
            * Check box click
            */
            $(LocTransporterMasterEdit.SELECTORS.chkInTable).click(function (evt) {
                evt.stopPropagation();
                LocTransporterMasterEdit.setCheckboxs('set');
            });

            /**
            * Button check all clicked
            */
            $(LocTransporterMasterEdit.SELECTORS.btnCheckAll).click(function () {
                if ($("#tb_loc").length) {
                    $(LocTransporterMasterEdit.SELECTORS.chkInTable).prop('checked', true);
                    LocTransporterMasterEdit.setRowidsFlag(true);
                }
            });

            /**
            * Button UnCheck all clicked
            */
            $(LocTransporterMasterEdit.SELECTORS.btnUnCheckAll).click(function () {
                if ($("#tb_loc").length) {
                    $(LocTransporterMasterEdit.SELECTORS.chkInTable).prop('checked', false);
                    LocTransporterMasterEdit.setRowidsFlag(false);
                }
            });
        },

        /**
        *
        */
        setRowidsFlag: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys_Create');
            if (rowids != null) {
                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    jrid[key] = flag;
                });
                storage.setItem('PKeys_Create', JSON.stringify(jrid));
            }
            LocTransporterMasterEdit.setCheckboxs('set');
        },

        // save page
        setCheckboxs: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys_Create');
            if (rowids != null) {
                var cnt = 0;
                var jrid = JSON.parse(rowids);
                var checkboxs = $("#tb_loc input[type=checkbox]");
                $.each(checkboxs, function () {
                    var row = $(this).parent().parent().parent();
                    var rowid = row.find(".rowid").html().trim();

                    if (flag == 'set') {
                        jrid[rowid] = $(this).is(':checked');
                    }
                    else {
                        if (jrid[rowid]) {
                            $(this).prop("checked", true);
                        }
                    }
                });

                if (flag == 'set') {
                    storage.setItem('PKeys_Create', JSON.stringify(jrid));
                }

                $.each(jrid, function (key, value) {
                    if (value) {
                        cnt++;
                    }
                });
                if ($('#frmInsert').length > 0) {
                    $(LocTransporterMasterEdit.SELECTORS.rowSelected).text(cnt);
                }
            }

        },

        setStorageInit: function () {
            if (window.localStorage) {
                var storage = window.localStorage;
                storage.removeItem('PKeys_Create');
                var rowids = {};

                var checkboxs = $("#tb_loc input[type=checkbox]")
                $.each(checkboxs, function () {
                    var row = $(this).parent().parent().parent();
                    var rowid = row.find(".rowid").html().trim();;

                    rowids[rowid] = $(this).is(':checked');
                });

                var storage = window.localStorage;
                storage.setItem('PKeys_Create', JSON.stringify(rowids));
            }
        },

        /**
         * Check error when update record.
         */
        checkUpdateError: function () {
            if ($(LocTransporterMasterEdit.SELECTORS.hdUpdateError).val() === LocTransporterMasterEdit.CONST.STR_TRUE) {
                if ($(LocTransporterMasterEdit.SELECTORS.hdUpdateError).attr(LocTransporterMasterEdit.CONST.ATTR_ERROR_CODE) === LocTransporterMasterEdit.CONST.ERR_EXCLUSIVE_UPDATE) {
                    // show message box
                    $(LocTransporterMasterEdit.SELECTORS.btnSubmitExclusiveUpdateDialog).removeAttr('disabled');
                    messageDialog.open(LocTransporterMasterEdit.SELECTORS.exclusiveUpdateDialog, LocTransporterMasterEdit.GLOBAL.titleInformation, LocTransporterMasterEdit.GLOBAL.msgExclusiveUpdate);
                    $(LocTransporterMasterEdit.SELECTORS.btnSubmitExclusiveUpdateDialog).click(function () {
                        window.location = "Index";
                    });
                }
            }
        }
    }
    </script>

    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")

    @*  *@
<script type="text/javascript">
    const adjustScroll = function () {
        const parent = $('.tb_scroll');
        const child = $('.tb_scroll_child');

        if (parent.get(0) && parent.get(0).scrollHeight > parent.innerHeight()) {
            child.addClass('addScroll');
        } else {
            child.removeClass('addScroll');
        }

        child.scrollLeft(parent.scrollLeft());
    };

    $(document).ready(function () {
        String.prototype.format = function () {
            if (arguments.length == 0) return this;
            for (var s = this, i = 0; i < arguments.length; i++)
                s = s.replace(new RegExp("\\{" + i + "\\}", "g"), arguments[i]);
            return s;
        };

        var date = new Date();
        var startdate = "" + date.getFullYear() + "/" + (date.getMonth() + 1) + "/" + date.getDate();
        $("#ddlStartDate").val(startdate);
        $("#ddlStartDate").attr('value', startdate);

        LocTransporterMasterEdit.init();
        //adjustScroll();

        /// <summary>
        /// 登録するボタン押下
        /// </summary>
        $('#btnSave').click(function () {
            if (!inputChk()) return;
            if (!RepeatChk()) return;
            if (!DuplicateChk()) return;
            if (!NaniwaSortingChk()) return;

            if (validateForm($('#frmInsert'))) {
                $("#updconfirm").modal({
                    show: true,
                    backdrop: true
                });
            }
        });

        //エラーチェック
        function inputChk() {

            var Check = $("#tb_loc tbody tr");
            var ERR_NUMBER = '@Share.Common.Resources.MessagesResource.ERR_NUMBER';
            var ERR_LENGTH = '@Share.Common.Resources.MessagesResource.ERR_LENGTH';
            var ERR_REQUIRED = '@Share.Common.Resources.MessagesResource.ERR_REQUIRED';
            var err = true;
            var alert = $("#alert-danger");
            alert.css('display', 'none');

            Check.each(function () {

                var row = $(this);
                var rowid = row.find(".rowid").html().trim();
                var tList = row.find(".LeadTimes");
                var transporter = row.find(".ddlTransporterId");

                transporter.each(function () {
                    var clientCd = row.find(".ddlClientCd")
                    var sagawaClientRequiered = '配送業者が佐川急便の場合、佐川顧客コード';

                    if (transporter.val() == "02" && clientCd.val() == '') {
                        alert.html(ERR_REQUIRED.format(rowid, sagawaClientRequiered));
                        err = false;
                        return false;
                    }

                    var clientCd = row.find(".ddlControlId")
                    var naniwaClientRequiered = '配送業者が浪速運送の場合、浪速顧客コード';

                    if (transporter.val() == "03" && clientCd.val() == '') {
                        alert.html(ERR_REQUIRED.format(rowid, naniwaClientRequiered));
                        err = false;
                        return false;
                    }

                    var clientCd = row.find(".ddlConsignorId")
                    var WsClientRequiered = '配送業者がワールドサプライの場合、WS顧客コード';

                    if (transporter.val() == "08" && clientCd.val() == '') {
                        alert.html(ERR_REQUIRED.format(rowid, WsClientRequiered));
                        err = false;
                        return false;
                    }
                })

                tList.each(function () {
                    var text = $(this);
                    var name = text.attr('name')
                    name = GetLeadTiemName(name);
                    if (text.val().trim() === '') {
                        alert.html(ERR_REQUIRED.format(rowid, name));
                        err = false;
                        return false;

                    }
                    else {
                        if (!isNaN(text.val())) {
                            if (text.val() > 99) {
                                alert.html(ERR_LENGTH.format(rowid, name, '2'));
                                err = false;
                                return false;
                            }
                        } else {
                            alert.html(ERR_NUMBER.format(rowid, name));
                            err = false;
                            return false;
                        }
                    }
                });

                if (!err) {
                    alert.css('display', 'block');
                    return false;
                }
            });

            return err;

        }

        //登録済みチェック
        function RepeatChk() {
            var Check = $("#tb_loc tbody tr");
            var err = true;
            var alert = $("#alert-danger");
            var ERR_ALREADY_SAVED_ROW = '@Share.Common.Resources.MessagesResource.ERR_ALREADY_SAVED_ROW';

            Check.each(function () {

                var rowid = $(this).find(".rowid").html().trim();
                var idx = rowid - 1;
                var key = 'LocTransporters[' + idx + '].'
                var shiptostoreid = $("input[name='" + key + 'ShipToStoreId' + "']").val();

                var startdate = $("input[name='" + key + 'StartDate' + "']").val();
                var centerid = $("input[name='" + key + 'CenterId' + "']").val();
                var rid = $("input[name='" + key + 'RowId' + "']").val();
                err = GetTargetById(shiptostoreid, startdate, centerid, rid);

                if (!err) {
                    alert.html(ERR_ALREADY_SAVED_ROW.format(rowid));
                    alert.css('display', 'block');
                    return false;
                }
            });

            console.log(err);
            return err;

        }

        //出荷先と適用開始日が両方同じ行がないかチェック
        function DuplicateChk() {
            var Check = $("#tb_loc tbody tr");
            var err = true;
            var alert = $("#alert-danger");
            var ERR_DUPLICATE_ROW = '@Wms.Resources.MessageResource.ERR_DUPLICATE_ROW';
            var arrShiptostoreId = [];
            var arrStartdate = [];

            Check.each(function () {

                var rowid = $(this).find(".rowid").html().trim();
                var idx = rowid - 1;
                var key = 'LocTransporters[' + idx + '].';
                var shiptostoreid = $("input[name='" + key + 'ShipToStoreId' + "']").val();
                var startdate = new Date($("input[name='" + key + 'StartDate' + "']").val());

                for (var i = 0; i < arrShiptostoreId.length; i++) {
                    //同じ出荷先が２行以上あった場合、適用開始日も同じだったらエラー
                    if (arrShiptostoreId[i] == shiptostoreid) {
                        if (startdate.getFullYear() + '/' + (startdate.getMonth() + 1) + '/' + startdate.getDate() == arrStartdate[i]) {
                            alert.html(ERR_DUPLICATE_ROW.format(i + 1, rowid));
                            alert.css('display', 'block');
                            err = false;
                            return false;
                        }
                    }
                }

                arrShiptostoreId[idx] = shiptostoreid;
                arrStartdate[idx] = startdate.getFullYear() + '/' + (startdate.getMonth() + 1) + '/' + startdate.getDate();
            });

            console.log(err);
            return err;

        }

        // 配送業者が03：浪速のとき 浪速仕分コード設定がない店舗の場合はエラー
        function NaniwaSortingChk() {
            const transpoterIdNaniwa = "03";
            var err = true;
         
            $("#tb_loc tbody tr").each(function () {
                var rowid = $(this).find(".rowid").html().trim();
                var idx = rowid - 1;
                var key = 'LocTransporters[' + idx + '].';
                if ($("select[name='" + key + 'TransporterId' + "']").val() == transpoterIdNaniwa) {
                    var shipToStoreId = $("input[name='" + key + 'ShipToStoreId' + "']").val();
                    var check = CheckNaniwaSorting(shipToStoreId);
                    if (!check) {
                        $("#alert-danger").html('行No' + rowid + '：@Wms.Resources.MessageResource.ERR_LOC_TRANSPORTER_NANIWA');
                        $("#alert-danger").css('display', 'block');
                        err = false;
                        return false;
                    }
                }
            });
            return err;
        }

        function GetLeadTiemName(name) {
            var temp = name.split('.');
            if (temp.length > 1) {
                switch (temp[1]) {
                    case 'LeadTimes':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimes';
                        break;
                    case 'LeadTimesMon':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesMon';
                        break;
                    case 'LeadTimesTue':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesTue';
                        break;
                    case 'LeadTimesWed':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesWed';
                        break;
                    case 'LeadTimesThu':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesThu';
                        break;
                    case 'LeadTimesFri':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesFri';
                        break;
                    case 'LeadTimesSat':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesSat';
                        break;
                    case 'LeadTimesSun':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesSun';
                        break;
                    case 'LeadTimesHol':
                        name = '@Wms.Areas.Master.Resources.LocTransporterResource.LeadTimesHol';
                        break;
                    default:
                        ''
                }
                return name;
            }

            return ' ';

        }

        /// <summary>
        /// 既に登録されています。
        /// </summary>
        function GetTargetById(shiptostoreid, startdate, centerid, rowid) {
            var parameters = { 'ShipToStoreId': shiptostoreid, 'StartDate': startdate, 'CenterId': centerid, 'RowId': rowid}

            var repeat = true;
            $.ajax({
                type: "post",
                url: "@Url.Action("GetTargetById","LocTransporter")",
                data: parameters,
                async: false,
                success: function (data) {
                    if (data.success) {
                        repeat = false;
                    }
                }
            });
            return repeat;
        }

        /// <summary>
        /// 浪速に設定された店について浪速仕分コードマスタ設定されていない店があります。浪速へ設定できません。
        /// </summary>
        function CheckNaniwaSorting(shipToStoreId) {
            var ret = false;
         
            $.ajax({
                type: "post",
                url: "@Url.Action("CheckNaniwaSorting", "LocTransporter")",
                data: { 'ShipToStoreId': shipToStoreId },
                async: false,
                success: function (data) {
                    if (data.success) {
                        ret = true;
                    }
                }
            });
            return ret;
        }

        /// <summary>
        /// 戻るボタン押下
        /// </summary>
        $('#btnReturn').click(function () {
            window.location.href = "@Url.Action("Index","LocTransporter")";
        });

