@model Wms.Areas.Master.ViewModels.NaniwaSorting.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_NaniwaSorting01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "NaniwaSorting", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table>
            <tr>
                <td class="tdtitle_13">@NaniwaSortingResource.StoreId：</td>
                <td colspan="2">
                    @Html.EditorFor(model => model.SearchConditions.StoreId, new { htmlAttributes = new { @class = "w_14_long", @id = "txtStoreId", tabindex = "1" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td class="tdtitle_13">@NaniwaSortingResource.StoreName：</td>
                <td colspan="2">
                    @Html.EditorFor(model => model.SearchConditions.StoreName, new { htmlAttributes = new { @class = "w_14_long", @id = "txtStoreName", tabindex = "2" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td class="tdtitle_13">@NaniwaSortingResource.NaniwaDeliCenterCd：</td>
                <td colspan="2">
                    @Html.EditorFor(model => model.SearchConditions.NaniwaDeliCenterCd, new { htmlAttributes = new { @class = "w_14_long", @id = "txtNaniwaDeliCenterCd", tabindex = "3" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td class="tdtitle_13">@NaniwaSortingResource.NaniwaDeliCenterName：</td>
                <td colspan="2">
                    @Html.EditorFor(model => model.SearchConditions.NaniwaDeliCenterName, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtNaniwaDeliCenterName", tabindex = "4" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td>
                </td>
                <td>
                </td>
                <td>
                </td>
                <td>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "NaniwaSorting", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark", tabindex = "5" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="6">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.SearchFlag, new { id = "hidSearchFlag"})
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.NaniwaSortingResult.NaniwaSortings != null)
{
    if (Model.NaniwaSortingResult.NaniwaSortings.Count() > 0)
    {
        <div class="sublbarea no_border" style="height:54px;margin-right:40px;margin-bottom: -10px;">
            <div class="sortarea">
                <ul>
                    <li>
                        <button type="button" id="btnDownload" class="download" @(Model.NaniwaSortingResult.NaniwaSortings != null && Model.NaniwaSortingResult.NaniwaSortings.Count() > 0 ? "" : "disabled='disabled'")>
                            <img src="~/Content/img/download.png" />
                            @FormsResource.BTN_DOWNLOAD
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    }
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.NaniwaSortingResult.NaniwaSortings.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.NaniwaSortingResult.NaniwaSortings.Count() > 0)
            {
                @Html.PagedListPager(Model.NaniwaSortingResult.NaniwaSortings, Page => Url.Action("Search", "NaniwaSorting", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.NaniwaSortingResult.NaniwaSortings.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:65vh;">

                    @using (Html.BeginForm("Edit", "NaniwaSorting", FormMethod.Post, new { id = "frmUpdate" }))
                    {
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey">&nbsp;</th>
                                    <th class="bg-grey">
                                        @NaniwaSortingResource.No
                                    </th>
                                    <th class="bg-grey">
                                        @NaniwaSortingResource.StoreId
                                    </th>
                                    <th class="bg-grey">
                                        @NaniwaSortingResource.StoreName
                                    </th>
                                    <th class="bg-grey">
                                        @NaniwaSortingResource.NaniwaDeliCenterCd
                                    </th>
                                    <th class="bg-grey">
                                        @NaniwaSortingResource.NaniwaDeliCenterName
                                    </th>
                                    <th hidden>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @Html.AntiForgeryToken()
                                @Html.Partial("_DeleteConfirmMessageDialog", @MessagesResource.QUE_DELETE)
                                @foreach (var cModel in Model.NaniwaSortingResult.NaniwaSortings.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("NaniwaSortings[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle w_checkbox">
                                            <label class="checkboxgroup">
                                                @Html.CheckBox(key + "IsCheck", new { @id = (key + "CheckedValue"), @class = "check-box" })
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.NaniwaSortingResult.NaniwaSortings.PageNumber - 1) * Model.NaniwaSortingResult.NaniwaSortings.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StoreId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StoreName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.NaniwaDeliCenterCd)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.NaniwaDeliCenterName)
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.RowId, new { Name = key + "Rid", @id = key + "Rid", @class = "rowid" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        <input id="hiddata" type="hidden" name="rowid" />
                    }
                </div>
            </div>
        }
    </div>
}

@*Bottomnav*@
@section Basefooter{
    @Html.Partial("_CheckBoxCounter")
<div class="btnarea">
    @if (Wms.Common.Profile.User.GetUsable_Class(Request.Url) != "1")
    {
        <button type="submit" id="btnCreate" class="btn btn-outline-dark btnsize" form="frmSearch" formmethod="get" formaction=@Url.Action("Create", "NaniwaSorting", new { area = "Master", controller = "NaniwaSorting", action = "Create" })>@FormsResource.BTN_NEW</button>
        @*@Html.ActionLink(FormsResource.BTN_NEW, "Create", "NaniwaSorting", null, new { @class = "btn btn-outline-dark btnsize _pm", @id = "lnkCreate", tabindex = "1001" })*@
        <button type="submit" id="btnDelete" class="btn btn-outline-danger btnsize _pm">@FormsResource.BTN_DELETE</button> }
    else
    {
        <button type="submit" id="lnkCreate" class="btn btn-outline-dark btnsize _pm" disabled>@FormsResource.BTN_NEW</button>
        <button type="submit" id="btnDelete" class="btn btn-outline-danger btnsize _pm" disabled>@FormsResource.BTN_DELETE</button>
    }
    <button id="btnDeleteHidden" type="button" class="btn btn-outline-danger _pm" data-toggle="modal" data-target="#delconfirm" hidden>@FormsResource.BTN_DELETE</button>
    <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "NaniwaSorting", new { area = "Master", controller = "NaniwaSorting", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
</div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
    var NaniwaSortingsView = {
        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]'
        },

        /**
         * Init data
         */
        init: function () {
            this.registerEvent();
            this.setCheckboxs();
            this.setButtonStatus();
        },

        /**
        * Register event for control
        */
        registerEvent: function () {

            /**
            * Stop event fired when click to checkbox
            */
            $("#listData span.chk_parts").click(function (evt) {
                evt.stopPropagation();
            });

            /**
            * Check box click
            */
            $(NaniwaSortingsView.SELECTORS.chkInTable).click(function (evt) {
                evt.stopPropagation();
                NaniwaSortingsView.setButtonStatus();
            });

            /**
            * Button check all clicked
            */
            $("#rbCheckAll").click(function () {
                if ($("#listData").length) {
                    $(NaniwaSortingsView.SELECTORS.chkInTable + ':enabled').prop('checked', true);
                    NaniwaSortingsView.setRowidsFlag(true);
                }
            });

            /**
            * Button UnCheck all clicked
            */
            $("#rbUnCheckAll").click(function () {
                if ($("#listData").length) {
                    $(NaniwaSortingsView.SELECTORS.chkInTable).prop('checked', false);
                    NaniwaSortingsView.setRowidsFlag(false);
                }
            });

            $("#btnSearch").click(function () {
                NaniwaSortingsView.setStorageInit();
                $("#hidSearchFlag").val(true)
                var urlAction = '@Url.Action("Search", "NaniwaSorting", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();
            });

            $("#btnCreate").click(function () {
                var urlAction = '@Url.Action("Create", "NaniwaSorting", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();
            });

            $("#btnUpdate").click(function () {
                var target = $("#hiddata").val();
                if (target == "") {
                    var list = NaniwaSortingsView.getCheckList();
                    $("#hiddata").val(list[0]);
                } else {
                    $("#hiddata").val(JSON.parse(target)[0]);
                }
                var urlAction = '@Url.Action("Edit", "NaniwaSorting", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $("#frmUpdate").attr("method", "POST");
                $("#frmUpdate").submit();

            //    NaniwaSortingsView.setStorageInit();
            });

            $("#btnDelete").click(function () {
                var list = NaniwaSortingsView.getCheckList();
                //NaniwaSortingsView.setStorageInit();
                $("#hiddata").val(JSON.stringify(list));

                var urlAction = '@Url.Action("Delete", "NaniwaSorting", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $('#btnDeleteHidden').click();
            });
        },

        /**
         * Enable/Disable button Edit
         */
        setButtonStatus: function () {
            NaniwaSortingsView.setCheckboxs('set')
        },

        // save page
        setRowidsFlag: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    jrid[key] = flag;
                });
                storage.setItem('PKeys', JSON.stringify(jrid));
            }
            NaniwaSortingsView.setButtonStatus();
        },

        setCheckboxs: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var cnt = 0;
                var jrid = JSON.parse(rowids);
                var checkboxs = $("#listData input[type=checkbox]:enabled")
                checkboxs.each(function () {
                    var row = $(this).parent().parent().parent();
                    var rowid = row.find(".rowid").val();

                    if (flag == 'set') {
                        jrid[rowid] = $(this).is(':checked');
                    }
                    else {
                        if (jrid[rowid]) {
                            $(this).prop("checked", true);
                        }
                    }
                });

                if (flag == 'set') {
                    storage.setItem('PKeys', JSON.stringify(jrid));
                }

                $.each(jrid, function (key, value) {
                    if (value) {
                        cnt++;
                    }
                });

                $("#btnDelete").attr('disabled', 'disabled');
                $("#btnUpdate").attr('disabled', 'disabled');

                if ($('#frmUpdate').length > 0) {
                    if (cnt > 0) {
                        if (getUsable_Class() == 3) {
                            $("#btnDelete").removeAttr('disabled');
                        }
                        if (cnt == 1) {
                            $("#btnUpdate").removeAttr('disabled');
                        }
                    }

                    $("#spnCheckedCounter").text(cnt);
                }
            }

        },

        setStorageInit: function () {
            if (window.localStorage) {

                var storage = window.localStorage;
                storage.removeItem('PKeys');
                var data = {
                    'SearchConditions.StoreId': $("#txtStoreId").val(),
                    'SearchConditions.StoreName': $("#txtStoreName").val(),
                    'SearchConditions.NaniwaDeliCenterCd': $("#txtNaniwaDeliCenterCd").val(),
                    'SearchConditions.NaniwaDeliCenterName': $("#txtNaniwaDeliCenterName").val()
                };

                $.ajax({
                    type: "post",
                    url: "@Url.Action("GetPKeys", "NaniwaSorting", new { area = "Master" })",
                    data: data,
                    async: false,
                    success: function (data) {
                        var rowids = {};
                        $.each(data, function (n, value) {
                            rowids[value] = false;
                        });

                        var storage = window.localStorage;
                        storage.setItem('PKeys', JSON.stringify(rowids));

                    }
                });
            }
        },

        getCheckList: function () {
            var list = [];
            var storage = window.localStorage;
            rowids = storage.getItem('PKeys');

            if (rowids != null) {

                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    if (jrid[key]) {
                        list.push(key);
                    }
                });
            }
            return list;
        },

    }

    /**
    * File Download
    */
    $("#btnDownload").on("click", function () {
        var urlAction = '@Url.Action("Download", "NaniwaSorting", new { area = "Master" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "GET");
        $form.submit();

        setTimeout(function () {
            var count = NaniwaSortingsView.getCheckList().length;
            if (count == 1) {
                $("#btnUpdate").prop("disabled", false);
            }
            if (getUsable_Class() == 3) {
                if (count >= 1) {
                    $("#btnDelete").prop('disabled', false);
                }
                $("#btnCreate").prop("disabled", false);
            }
        }, 1000);
    });

    /**
    * Page loaded
    */
    //$(document).ready(function () {
    //    NaniwaSortingsView.init();
    //});

    $(document).ready(function () {
        if ('@TempData[AppConst.SUCCESS]' != '') {
            NaniwaSortingsView.setStorageInit();
        }
        NaniwaSortingsView.init();
    });

    // Sort
    function getSortData() {

        $("#hidSort").val($("#ddlSort").val());
        $("#hidSortKey").val($("#ddlSortKey").val());

        var $form = $("#frmSearch");
        var urlAction ='@Url.Action("Search", "NaniwaSorting", new { area= "Master" })';
        $form.attr("action", urlAction);
        $form.attr("method", "GET");
        $form.submit();
    }
    </script>
}