@model Wms.Areas.Master.ViewModels.Brand.Index
@{
    /**/

    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_Brand01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Brand", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table>
            <tr>
                <td class="tbtitle">@BrandResource.BrandId</td>
                <td colspan="3">
                    @Html.EditorFor(model => model.SearchConditions.BrandId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtBrandId", tabindex = "1" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tbtitle">@BrandResource.BrandName</td>
                <td colspan="3">
                    @Html.EditorFor(model => model.SearchConditions.BrandName, new { htmlAttributes = new { @class = "w_18_normal", @id = "txtBrandName", tabindex = "2" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@BrandResource.DeleteFlagSearch</td>
                <td class="w_checkbox" colspan="3">
                    <label class="checkboxgroup">
                        @Html.CheckBoxFor(model => model.SearchConditions.DeleteFlag, new { @id = "chkIsNewDate", @class = "check-box" })
                        <span class="chk_parts"></span>
                    </label>
                    <span>@BrandResource.DeleteFlagSearch2</span>
                </td>
            </tr>
            <tr>
                <td style="width: 5.3rem;"></td>
                <td style="width: 12rem;"></td>
                <td class="alignright">
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "Brand", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="4" onclick="$('#frmSearch').submit()">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
    }
</div>
<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.BrandResult.Brands != null)
{
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.BrandResult.Brands.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.BrandResult.Brands.Count() > 0)
            {
                @Html.PagedListPager(Model.BrandResult.Brands, Page => Url.Action("Search", "Brand", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.BrandResult.Brands.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:71vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">&nbsp;</th>
                                <th class="bg-grey align-middle">
                                    @BrandResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @BrandResource.BrandId
                                </th>
                                <th class="bg-grey align-middle">
                                    @BrandResource.BrandName
                                </th>
                                <th class="bg-grey align-middle">
                                    @BrandResource.BrandShortName
                                </th>
                                <th class="bg-grey align-middle">
                                    @BrandResource.DeleteFlag
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "Brand", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.BrandResult.Brands.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Brands[{0}].", cModel.i);
                            <tr>
                                <td class="align-middle chk_cell">
                                    <label>
                                        <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" />
                                        <span class="radio_parts"></span>
                                    </label>
                                    @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                </td>
                                <td class="align-middle text-right w_no">
                                    @((cModel.i + 1) + (Model.BrandResult.Brands.PageNumber - 1) * Model.BrandResult.Brands.PageSize)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.BrandId)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.BrandName)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.BrandShortName)
                                </td>
                                <td class="align-middle">
                                    <label class="chklist">
                                        @Html.CheckBoxFor(model => cModel.v.DeleteFlag, new { @class = "check-box _pm", onclick = "return false;" })
                                        <span class="chk_parts">
                                        </span>
                                    </label>
                                </td>
                                <td class="template" hidden>
                                    @Html.HiddenFor(modelItem => cModel.v.BrandId, new { Name = key + "BrandId" })
                                    @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                    @Html.HiddenFor(modelItem => cModel.v.ShipperId, new { Name = key + "ShipperId" })
                                </td>
                            </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "Brand", new { area = "Master", controller = "Brand", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
    /**
     * Country class
     */
    var BrandsView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=radio][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=radio][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=radio][class=check-box]',
            tblRow: '#listData tbody tr',
            btnEdit: '#btnUpdate',
            ddlSortKey: '#ddlSortKey',
            chkChecked: ':radio:checked',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]'
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus();
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Check box click
                 */
                $(BrandsView.SELECTORS.chkInTable).click(function (evt) {
                    $(this).prop("checked", true);
                    evt.stopPropagation();
                    BrandsView.setButtonStatus();
                });

                /**
                * Dropdownlist change item
                */
                $(BrandsView.SELECTORS.ddlSort).change(function (val) {
                    $(BrandsView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(BrandsView.SELECTORS.ddlSortKey).change(function (val) {
                    $(BrandsView.SELECTORS.btnSearch).click();
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function () {
                // Enable/Disable button Edit
                if ($(BrandsView.SELECTORS.chkCheckedInTable).length === 1) {
                    $(BrandsView.SELECTORS.btnEdit).removeAttr('disabled');
                } else {
                    $(BrandsView.SELECTORS.btnEdit).attr('disabled', 'disabled');
                }
            },
        }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        BrandsView.init();
    });
        function ClearConditons() {
            $("#txtBrandId").val("");
        $("#txtBrandName").val("");
    }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "Brand", new { area= "Master" })';
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        }
        function SetIsCheck(id) {
                    $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
                    $('#listData input[type=checkbox][id="'+id+'"]').prop("checked", true);
        }
    </script>
}