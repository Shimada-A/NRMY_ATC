@** スクリプト *@
@section LayoutScripts{
    @Scripts.Render("~/bundles/FileUpload")
<script>
    /**
     * Country class
     */
    var LocationsView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnDelete: '#btnDelete',
            btnUpdate: '#btnUpdate',
            btnSearch: '#btnSearch',
            btnSubmit: 'button[type=submit],input[type=submit]'
        },

        /**
            * Init data
            */
        init: function () {
            this.registerEvent();
            this.setCheckboxs();
            this.setButtonStatus();
        },

        /**
        * Register event for control
        */
        registerEvent: function () {

            /**
            * Stop event fired when click to checkbox
            */
            $(LocationsView.SELECTORS.chkLabel).click(function (evt) {
                evt.stopPropagation();
            });

            /**
            * Check box click
            */
            $(LocationsView.SELECTORS.chkInTable).click(function (evt) {
                evt.stopPropagation();
                LocationsView.setButtonStatus();
            });

            /**
            * Button check all clicked
            */
            $(LocationsView.SELECTORS.btnCheckAll).click(function () {
                if ($("#listData").length) {
                    $(LocationsView.SELECTORS.chkInTable + ':enabled').prop('checked', true);
                    LocationsView.setRowidsFlag(true);
                }
            });

            /**
            * Button UnCheck all clicked
            */
            $(LocationsView.SELECTORS.btnUnCheckAll).click(function () {
                if ($("#listData").length) {
                    $(LocationsView.SELECTORS.chkInTable).prop('checked', false);
                    LocationsView.setRowidsFlag(false);
                }
            });


            $(LocationsView.SELECTORS.btnSearch).click(function () {
                LocationsView.setStorageInit();
                $("#hidSearchFlag").val(true)
                var urlAction = '@Url.Action("Search", "Location", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            });

            $('btnCreate').click(function () {
                var urlAction = '@Url.Action("Create", "Location", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();
            });

            $(LocationsView.SELECTORS.btnUpdate).click(function () {
                var target = $("#hiddata").val();
                if (target == "") {
                    var list = LocationsView.getCheckList();
                    $("#hiddata").val(list[0]);
                } else {
                    $("#hiddata").val(JSON.parse(target)[0]);
                }
                var urlAction = '@Url.Action("Edit", "Location", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $("#frmUpdate").attr("method", "POST");
                $("#frmUpdate").submit();

            //    LocationsView.setStorageInit();
            });

            $(LocationsView.SELECTORS.btnDelete).click(function () {
                var list = LocationsView.getCheckList();
                //LocationsView.setStorageInit();
                $("#hiddata").val(JSON.stringify(list));

                var urlAction = '@Url.Action("Delete", "Location", new { area= "Master" })';
                $("#frmUpdate").attr("action", urlAction);
                $('#btnDeleteHidden').click();
            });
        },

        /**
            * Enable/Disable button Edit
            */
        setButtonStatus: function () {
            LocationsView.setCheckboxs('set')
        },

        // save page
        setRowidsFlag: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    jrid[key] = flag;
                });
                storage.setItem('PKeys', JSON.stringify(jrid));
            }
            LocationsView.setButtonStatus();
        },

        setCheckboxs: function (flag) {
            var storage = window.localStorage;
            var rowids = storage.getItem('PKeys');
            if (rowids != null) {
                var cnt = 0;
                var jrid = JSON.parse(rowids);
                var checkboxs = $("#listData input[type=checkbox]:enabled")
                checkboxs.each(function () {
                    var row = $(this).parent().parent().parent();
                    var rowid = row.find(".rowid").val();

                    if (flag == 'set') {
                        jrid[rowid] = $(this).is(':checked');
                    }
                    else {
                        if (jrid[rowid]) {
                            $(this).prop("checked", true);
                        }
                    }
                });

                if (flag == 'set') {
                    storage.setItem('PKeys', JSON.stringify(jrid));
                }

                $.each(jrid, function (key, value) {
                    if (value) {
                        cnt++;
                    }
                });


                $(LocationsView.SELECTORS.btnDelete).attr('disabled', 'disabled');
                $(LocationsView.SELECTORS.btnUpdate).attr('disabled', 'disabled');

                if ($('#frmUpdate').length > 0) {
                    if (cnt > 0) {
                        if (getUsable_Class() == 3) {
                            $(LocationsView.SELECTORS.btnDelete).removeAttr('disabled');
                        }
                        if (cnt == 1) {
                            $(LocationsView.SELECTORS.btnUpdate).removeAttr('disabled');
                        }
                    }

                    $(LocationsView.SELECTORS.rowSelected).text(cnt);
                }
            }

        },

        setStorageInit: function () {
            if (window.localStorage) {

                var storage = window.localStorage;
                storage.removeItem('PKeys');
                var data = {
                    'SearchConditions.CenterId': $("#ddlSearchLoc").val(),
                    'SearchConditions.LocationClass': $("#ddlSearchClass").val(),
                    'SearchConditions.Locsec1': $("#txtLocsec1").val(),
                    'SearchConditions.Locsec2': $("#txtLocsec2").val(),
                    'SearchConditions.Locsec3': $("#txtLocsec3").val(),
                    'SearchConditions.Locsec4': $("#txtLocsec4").val(),
                    'SearchConditions.Locsec5': $("#txtLocsec5").val()
                };


                $.ajax({
                    type: "post",
                    url: "@Url.Action("GetPKeys", "Location", new { area = "Master" })",
                    data: data,
                    async: false,
                    success: function (data) {
                        var rowids = {};
                        $.each(data, function (n, value) {
                            rowids[value] = false;
                        });

                        var storage = window.localStorage;
                        storage.setItem('PKeys', JSON.stringify(rowids));

                    }
                });
            }
        },

        getCheckList: function () {
            var list = [];
            var storage = window.localStorage;
            rowids = storage.getItem('PKeys');

            if (rowids != null) {

                var jrid = JSON.parse(rowids);
                $.each(jrid, function (key) {
                    if (jrid[key]) {
                        list.push(key);
                    }
                });
            }

            return list;
        },

    }

    /**
    * File Download
    */
    $("#btnDownload").on("click", function () {
        var urlAction = '@Url.Action("Download", "Location", new { area = "Master" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "GET");
        $form.submit();

        setTimeout(function () {
            var count = LocationsView.getCheckList().length;
            if (count == 1) {
                $(LocationsView.SELECTORS.btnUpdate).prop("disabled", false);
            }
            if (getUsable_Class()== 3) {
                if(count >= 1) {
                $(LocationsView.SELECTORS.btnDelete).prop('disabled', false);
                }
            $("#btnCreate").prop("disabled", false);
            }
        }, 1000);
    });
    $("#btnDownloadTemp").on("click", function () {
        var urlAction = '@Url.Action("DownloadTemp", "Location", new { area = "Master" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "GET");
        $form.submit();

        setTimeout(function () {
            var count = LocationsView.getCheckList().length;
            if (count == 1) {
                $(LocationsView.SELECTORS.btnUpdate).prop("disabled", false);
            }
            if (getUsable_Class() == 3) {
                if (count >= 1) {
                    $(LocationsView.SELECTORS.btnDelete).prop('disabled', false);
                }
                $("#btnCreate").prop("disabled", false);
            }
        }, 1000);
    });

    Dropzone.autoDiscover = false;
    //ファイルアップロード
    fileUploadModal.init();
    /**
    * File Upload
    */
    $('#btnUpload').on('click', function () {
        var urlAction = '@Url.Action("Upload", "Location", new { area = "Master" })';
        var urlIndexAction = '@Url.Action("Index", "Location", new { area = "Master" })';
        var urlErrAction = '@Url.Action("UploadErr", "Location", new { area = "Master" })';
        fileUploadModal.setting({
            url: urlAction,
            title: "@LocationResource.Title" + "@FormsResource.FileUplaodTitle",
            acceptedFiles: ".xlsx",
            successCallback: function (data) {
                if (data.err == 'true') {
                    location.href = urlErrAction;
                } else {
                    location.href = urlIndexAction;
                }
            }
        });
        fileUploadModal.open();
    });

    /**
    * Page loaded
    */
    //$(document).ready(function () {
    //    LocationsView.init();
    //});

        $(document).ready(function () {
        if ('@TempData[AppConst.SUCCESS]' != '') {
            LocationsView.setStorageInit();
        }
            LocationsView.init();
    });


    function ClearConditons() {
        $("#txtLocsec1").val("");
        $("#txtLocsec2").val("");
        $("#txtLocsec3").val("");
        $("#txtLocsec4").val("");
        $("#txtLocsec5").val("");
    }
    // Sort
    function getSortData() {

        $("#hidSort").val($("#ddlSort").val());
        $("#hidSortKey").val($("#ddlSortKey").val());

        var $form = $("#frmSearch");
        var urlAction ='@Url.Action("Search", "Location", new { area= "Master" })';
        $form.attr("action", urlAction);
        $form.attr("method", "POST");
        $form.submit();
    }
    $("#btnPrintLabel").on("click", function () {
        var urlAction = '@Url.Action("PrintLabel", "Location", new { area = "Master" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "POST");
        $form.attr("target", "newtab");
        $form.submit();
        $form.attr("target", "_self");

        setTimeout(function () {
            var count = LocationsView.getCheckList().length;
            if (count == 1) {
                $(LocationsView.SELECTORS.btnUpdate).prop("disabled", false);
            }
            if (getUsable_Class() == 3) {
                if (count >= 1) {
                    $(LocationsView.SELECTORS.btnDelete).prop('disabled', false);
                }
                $("#btnCreate").prop("disabled", false);
            }
        }, 1000);
    });
    $("#btnPrintA4").on("click", function () {
        var urlAction = '@Url.Action("PrintA4", "Location", new { area = "Master" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "POST");
        $form.attr("target", "newtab");
        $form.submit();
        $form.attr("target", "_self");

        setTimeout(function () {
            var count = LocationsView.getCheckList().length;
            if (count == 1) {
                $(LocationsView.SELECTORS.btnUpdate).prop("disabled", false);
            }
            if (getUsable_Class() == 3) {
                if (count >= 1) {
                    $(LocationsView.SELECTORS.btnDelete).prop('disabled', false);
                }
                $("#btnCreate").prop("disabled", false);
            }
        }, 1000);
    });
</script>
}