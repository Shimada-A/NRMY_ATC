                    @Html.EditorFor(model => model.SearchConditions.Locsec2, new { htmlAttributes = new { @class = "w_6_short", @id = "txtLocsec2", tabindex = "4" } })
                    @Html.LikeMark(CommonsResource.Full)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@LocationResource.Locsec3Search</td>
                <td colspan="3">
                    @Html.EditorFor(model => model.SearchConditions.Locsec3, new { htmlAttributes = new { @class = "w_6_short", @id = "txtLocsec3", tabindex = "5" } })
                    @Html.LikeMark(CommonsResource.Full)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@LocationResource.Locsec4Search</td>
                <td colspan="3">
                    @Html.EditorFor(model => model.SearchConditions.Locsec4, new { htmlAttributes = new { @class = "w_6_short", @id = "txtLocsec4", tabindex = "6" } })
                    @Html.LikeMark(CommonsResource.Full)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@LocationResource.Locsec5Search</td>
                <td colspan="3">
