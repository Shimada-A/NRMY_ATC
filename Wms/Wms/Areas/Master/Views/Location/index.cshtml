                                                {
                                                    @Html.CheckBox(key + "IsCheck", new { @id = (key + "CheckedValue"), @class = "check-box" })
                                                }
                                                else
                                                {
                                                    @Html.CheckBox(key + "IsCheck", new { @id = (key + "CheckedValue"), @class = "check-box", disabled = true })
                                                }
