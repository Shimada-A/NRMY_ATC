            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:65vh;">

                    @using (Html.BeginForm("Edit", "Location", FormMethod.Post, new { id = "frmUpdate" }))
                    {
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey">&nbsp;</th>
                                    <th class="bg-grey">
                                        @LocationResource.No
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.LocationCd
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Locsec1
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Locsec2
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Locsec3
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Locsec4
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Locsec5
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.LocationClass
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Case
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.Grade
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.AllocPriority
                                    </th>
                                    <th class="bg-grey">
                                        @LocationResource.PickingGroupNo
                                    </th>
                                    <th hidden>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @Html.AntiForgeryToken()
                                @Html.Partial("_DeleteConfirmMessageDialog", @MessagesResource.QUE_DELETE)
                                @foreach (var cModel in Model.LocationResult.Locations.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Locations[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle w_checkbox">
                                            <label class="checkboxgroup">
