    {
        @Html.Partial("_CreateConfirmMessageDialog", @MessagesResource.QUE_CREATE)
    }
    else
    {
        @Html.Partial("_UpdateConfirmMessageDialog", @MessagesResource.QUE_UPDATE)
    }
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        //LocationMasterEdit
        var LocationMasterEdit = {
            /**
            * Constants
            */
            CONST: {
                QUE_UPDATE_OVERWRITE: 'QUE_UPDATE_OVERWRITE',
                ERR_EXCLUSIVE_UPDATE: 'ERR_EXCLUSIVE_UPDATE',
                ATTR_ERROR_CODE: 'errorcode',
                STR_TRUE: 'True',
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                GET: 'get'
            },

            /**
             * Global variables
             */
            GLOBAL: {
                textChanged: false,
                msgExclusiveUpdate: '@MessagesResource.ERR_EXCLUSIVE_UPDATE',
                titleInformation: '@MessagesResource.TITLE_INFORMATION',
                msgQueUpdateOverwrite: '@MessagesResource.QUE_UPDATE_OVERWRITE',
            },

            /**
             * Jquery selector
             */
            SELECTORS: {
                form: 'form',
                frmUpdate: 'frmUpdate',
                btnUpdate: '#btnUpdate',
                btnReturn: '#btnReturn',
                hdUpdateError: '#hdUpdateError',
                hdAllowOverrideRecord: '#allowOverrideRecord',
                AreaId: '#AreaId',
                btnSubmitUpdateConfirmDialog: '#updateConfirmDialog button[type="submit"]',
                btnSubmitExclusiveUpdateDialog: '#exclusiveUpdateDialog button[type="submit"]',
                btnSubmitOverWriteDialog: '#overWriteRecordDialog button[type="submit"]',
                updateConfirmDialog: 'updateConfirmDialog',
                exclusiveUpdateDialog: 'exclusiveUpdateDialog',
                overWriteRecordDialog: 'overWriteRecordDialog',
            },

            /**
             * Init function
             */
            init: function () {
                // Set up event
                this.setUpEvent();
                // check error when update
                this.checkUpdateError();
            },

            /**
             * Set up event
             */
            setUpEvent: function () {
                /**
                 * Allow overwrite record
                 */
                $(LocationMasterEdit.SELECTORS.btnSubmitOverWriteDialog).click(function () {
                    $(LocationMasterEdit.SELECTORS.hdAllowOverrideRecord).val('true');
                });
            },

            /**
             * Check error when update record.
             */
            checkUpdateError: function () {
                if ($(LocationMasterEdit.SELECTORS.hdUpdateError).val() === LocationMasterEdit.CONST.STR_TRUE) {
                    if ($(LocationMasterEdit.SELECTORS.hdUpdateError).attr(LocationMasterEdit.CONST.ATTR_ERROR_CODE) === LocationMasterEdit.CONST.ERR_EXCLUSIVE_UPDATE) {
                        // show message box
                        $(LocationMasterEdit.SELECTORS.btnSubmitExclusiveUpdateDialog).removeAttr('disabled');
                        messageDialog.open(LocationMasterEdit.SELECTORS.exclusiveUpdateDialog, LocationMasterEdit.GLOBAL.titleInformation, LocationMasterEdit.GLOBAL.msgExclusiveUpdate);
                        $(LocationMasterEdit.SELECTORS.btnSubmitExclusiveUpdateDialog).click(function () {
                            window.location = "Index";
                        });
                    }
                    // Renew record if it deleted
                    if ($(LocationMasterEdit.SELECTORS.hdUpdateError).attr(LocationMasterEdit.CONST.ATTR_ERROR_CODE) === LocationMasterEdit.CONST.QUE_UPDATE_OVERWRITE) {
                        // show message box
                        $(LocationMasterEdit.SELECTORS.btnSubmitOverWriteDialog).removeAttr('disabled');
                        messageDialog.open(LocationMasterEdit.SELECTORS.overWriteRecordDialog, LocationMasterEdit.GLOBAL.titleInformation, (LocationMasterEdit.GLOBAL.msgQueUpdateOverwrite.replace(/\{0}/g, $(LocationMasterEdit.SELECTORS.AreaId).val())));
                        $(LocationMasterEdit.SELECTORS.btnSubmitOverWriteDialog).attr(LocationMasterEdit.SELECTORS.form, LocationMasterEdit.SELECTORS.frmUpdate).attr(LocationMasterEdit.CONST.FORM_METHOD, LocationMasterEdit.CONST.POST).attr(LocationMasterEdit.CONST.FORM_ACTION, '@Url.Action("Update", "User", new { area = "Master" })').attr(LocationMasterEdit.SELECTORS.form, LocationMasterEdit.SELECTORS.frmUpdate);
                    }
                }
            }
        }

        function EventCheck() {
            var urlAction = '@Url.Action("GetCaseClass", "Location", new { area = "" })';
            $.ajax({
                url: urlAction,
                type: "POST",
                data: {
                    kbn: "CASECLASS",
                    cd: $("#ddlSearchClass").val()
                },
                success: function (data) {
                    if (data.name != null && data.name != "") {
                        $("#ddlCaseClass").html(data.name);
                        $("#HidCaseClass").val(data.val);
                        $("#CaseClass").val(data.val);
                    } else {
                        $("#ddlCaseClass").html("");
                        $("#HidCaseClass").val(data.val);
                    }
                }

            });
         };

        /* 確認メッセージの設定 */
        $('#btnCreate').on("click", function () {
            if (!validateForm($('#frmUpdate'))) {
                return;
            }
            $('#btnCreateHidden').click();
        });

        /* 確認メッセージの設定 */
        $('#btnUpdate').on("click", function () {
            if (!validateForm($('#frmUpdate'))) {
                return;
            }
            $('#btnUpdateHidden').click();
        });

        $('#submitCreate').on("click", function () {
            var urlAction = '@Url.Action("Create", "Location", new { area = "Master" })';
            var $form = $("#frmUpdate");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });

        //Enterキーを押すと次のIndexへ移動(誤送信を防止するため)
        $("input").on("keydown", function (e) {
            if (e.which == 13) {
                e.preventDefault();
                var inputObj = $("input:visible");
                var nextIndex = inputObj.index(this) + 1;
                if (inputObj[nextIndex]) {
                    $("input:visible")[nextIndex].focus();
                }
            }
        });
    </script>
}