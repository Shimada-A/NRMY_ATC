                        @Html.ValidationMessageFor(model => model.Locsec_2, "", new { })
                    }
                    else
                    {
                        //Update
                        @Html.DisplayFor(model => model.Locsec_2)
                        @Html.HiddenFor(model => model.Locsec_2)
                    }
                </dd>
            </dl>
            <dl>
                <dt>
                    @LocationResource.Locsec3
                </dt>
                <dd>
                    @if (string.IsNullOrWhiteSpace(Model.LocationCd))
                    {
                        //Create
                        @Html.EditorFor(model => model.Locsec_3, new { htmlAttributes = new { tabindex = "3", @placeholder = "", @class = "w_6_short" } })
                        @Html.ValidationMessageFor(model => model.Locsec_3, "", new { })
                    }
                    else
                    {
                        //Update
                        @Html.DisplayFor(model => model.Locsec_3)
                        @Html.HiddenFor(model => model.Locsec_3)
                    }
                </dd>
            </dl>
            <dl>
                <dt>
                    @LocationResource.Locsec4
                </dt>
                <dd>
                    @if (string.IsNullOrWhiteSpace(Model.LocationCd))
                    {
                        //Create
                        @Html.EditorFor(model => model.Locsec_4, new { htmlAttributes = new { tabindex = "4", @placeholder = "", @class = "w_6_short" } })
                        @Html.ValidationMessageFor(model => model.Locsec_4, "", new { })
                    }
                    else
                    {
                        //Update
                        @Html.DisplayFor(model => model.Locsec_4)
                        @Html.HiddenFor(model => model.Locsec_4)
                    }
                </dd>
            </dl>
            <dl>
                <dt>
                    @LocationResource.Locsec5
                </dt>
                <dd>
                    @if (string.IsNullOrWhiteSpace(Model.LocationCd))
                    {
                        //Create
                        @Html.EditorFor(model => model.Locsec_5, new { htmlAttributes = new { tabindex = "5", @placeholder = "", @class = "w_6_short" } })
                        @Html.ValidationMessageFor(model => model.Locsec_5, "", new { })
                    }
