@model Wms.Areas.Master.ViewModels.Warehouses.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_Warehouse01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Warehouses", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table>
            <tr>
                <td>@WarehousesResource.CenterIdSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.CenterId, new { htmlAttributes = new { @class = "w_14_long", @id = "txtCenterId", tabindex = "1" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td></td>
            </tr>
            <tr>
                <td>@WarehousesResource.CenterNameSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.CenterName, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtCenterName", tabindex = "2" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td></td>
            </tr>
            <tr>
                <td>@WarehousesResource.CenterAddressSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.CenterAddress, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtCenterAddress", tabindex = "3" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
                <td></td>
            </tr>
            <tr>
                <td>@WarehousesResource.CenterTelSearch</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.CenterTel, new { htmlAttributes = new { @class = "w_14_long", @id = "txtCenterTel", tabindex = "4", @onblur = "hyphenCheck()" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                    @Html.ValidationMessageFor(model => model.SearchConditions.CenterTel, "", new { id = "CenterTel-errormessage" })
                </td>
                <td></td>
            </tr>
            <tr>
                <td></td>
                <td></td>
                <td>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "Warehouses", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="5" onclick="$('#frmSearch').submit()">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.WarehouseResult.Warehouses != null)
{
    if (Model.WarehouseResult.Warehouses.Count() > 0)
    {
        <div class="sublbarea no_border" style="height:54px;margin-right:40px;margin-bottom: -10px;">
            <div class="sortarea">
                <ul>
                    <li>
                        <button type="button" id="btnDownload" class="download" style="width:140px">
                            <img src="~/Content/img/download.png" />
                            @FormsResource.BTN_DOWNLOAD
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    }
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.WarehouseResult.Warehouses.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.WarehouseResult.Warehouses.Count() > 0)
            {
                @Html.PagedListPager(Model.WarehouseResult.Warehouses, Page => Url.Action("Search", "Warehouses", new { Page }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.WarehouseResult.Warehouses.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:71vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey">&nbsp;</th>
                                <th class="bg-grey">
                                    @WarehousesResource.No
                                </th>
                                <th class="bg-grey">
                                    @WarehousesResource.CenterId
                                </th>
                                <th class="bg-grey">
                                    @WarehousesResource.CenterName
                                </th>
                                <th class="bg-grey">
                                    @WarehousesResource.CenterShortName
                                </th>
                                <th class="bg-grey">
                                    @WarehousesResource.WmsClass
                                </th>
                                <th class="bg-grey">
                                    @WarehousesResource.BrandWorkClass
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "Warehouses", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.WarehouseResult.Warehouses.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Warehouses[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" />

                                                @*@if (cModel.v.CenterId == Wms.Common.Profile.User.CenterId)
                                                    {
                                                        <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" />
                                                    }
                                                    else
                                                    {
                                                        <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" disabled />
                                                    }*@
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })

                                            @*@if (cModel.v.CenterId == Wms.Common.Profile.User.CenterId)
                                                {
                                                    @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                                }
                                                else
                                                {
                                                    @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", disabled = true, hidden = true })
                                                }*@
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.WarehouseResult.Warehouses.PageNumber - 1) * Model.WarehouseResult.Warehouses.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CenterId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CenterName1)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CenterShortName)
                                        </td>
                                        <td class="align-middle">
                                            <label class="chklist">
                                                @Html.CheckBoxFor(modelItem => cModel.v.WmsClassBool, new { @class = "check-box _pm", onclick = "return false;" })
                                                <span class="chk_parts">
                                                </span>
                                            </label>
                                        </td>
                                        <td class="align-middle">
                                            <label class="chklist">
                                                @Html.CheckBoxFor(modelItem => cModel.v.BrandWorkClassBool, new { @class = "check-box _pm", onclick = "return false;" })
                                                <span class="chk_parts">
                                                </span>
                                            </label>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.CenterId, new { Name = key + "CenterId" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                            @Html.HiddenFor(modelItem => cModel.v.ShipperId, new { Name = key + "ShipperId" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "Warehouses", new { area = "Master", controller = "Warehouses", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        /**
        * Country class
        */
        var Warehouses = {

            /**
            * CONST Object
            */
            CONST: {
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                FORM: 'form',
                METHOD: 'method',
                ACTION: 'action'
            },

            /**
            * SELECTORS Object
            */
            SELECTORS: {
                chkInTable: '#listData input[type=radio][id$=".CheckedValue"]',
                chkCheckedInTable: '#listData input[type=radio][id$=".CheckedValue"]:checked',
                chkInRow: 'input[type=radio][class=check-box]',
                tblRow: '#listData tbody tr',
                btnEdit: '#btnUpdate',
                ddlSortKey: '#ddlSortKey',
                chkChecked: ':radio:checked',
                form: 'form',
                searchForm: '#frmSearch',
                frmUpdate: 'frmUpdate',
                btnSubmit: 'button[type=submit],input[type=submit]',
                btnSearch: '#btnSearch',
            },

            /**
            * Init data
            */
            init: function () {
                this.registerEvent();
                this.setButtonStatus();
            },

            /**
            * Register event for control
            */
            registerEvent: function () {

                /**
                * Check box click
                */
                $(Warehouses.SELECTORS.chkInTable).click(function (evt) {
                    $(this).prop("checked", true);
                    evt.stopPropagation();
                    Warehouses.setButtonStatus();
                });

                /**
                * Dropdownlist change item
                */
                $(Warehouses.SELECTORS.ddlSort).change(function (val) {
                    $(Warehouses.SELECTORS.btnSearch).click();
                });

                /**
                * Dropdownlist change item
                */
                $(Warehouses.SELECTORS.ddlSortKey).change(function (val) {
                    $(Warehouses.SELECTORS.btnSearch).click();
                });

                $(Warehouses.SELECTORS.btnSearch).click(function () {
                    var urlAction = '@Url.Action("Search", "Warehouses", new { area = "Master" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "GET");
                    $form.submit();
                });
            },

            /**
            * Enable/Disable button Edit
            */
            setButtonStatus: function () {
                // Enable/Disable button Edit
                if ($(Warehouses.SELECTORS.chkCheckedInTable).length === 1) {
                    $(Warehouses.SELECTORS.btnEdit).removeAttr('disabled');
                } else {
                    $(Warehouses.SELECTORS.btnEdit).attr('disabled', 'disabled');
                }
            },
        }

        /**
        * Page loaded
        */
        $(document).ready(function () {
            Warehouses.init();

            $("#btnDownload").on("click", function () {
                var urlAction = '@Url.Action("Download", "Warehouses", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();

                setTimeout(function () {
                    if ($(Warehouses.SELECTORS.chkCheckedInTable).length === 1) {
                        $(Warehouses.SELECTORS.btnEdit).removeAttr('disabled');
                    } 
                }, 1000);
            });
        });
        function ClearConditons() {
            $("#txtCenterId").val("");
            $("#txtCenterName").val("");
        }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "Warehouses", new { area= "Master" })';
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        }
        function SetIsCheck(id) {
                    $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
                    $('#listData input[type=checkbox][id="'+id+'"]').prop("checked", true);
        }

    </script>
}