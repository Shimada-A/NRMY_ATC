@using Wms.Helpers;
@model Wms.Areas.Master.ViewModels.Store.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_Store01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Store", FormMethod.Get, new { id = "frmSearch" }))
    {
        <table class="w-search">
            <tbody>
                <tr>
                    <td class="tdtitle10">@StoreResource.StoreClassSearch</td>
                    <td>
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.GeneralDropDownFor(
                                    model => model.SearchConditions.StoreClass
                                    , "STORE_CLASS", CommonResource.AllLocId
                                    , CommonResource.None, new { @id = "txtStoreClass", tabindex = "1" })
                            </div>
                        </div>
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.StoreIdSearch</td>
                    <td>
                        @Html.EditorFor(model => model.SearchConditions.StoreId, new { htmlAttributes = new { @class = "w_14_long", @id = "txtStoreId", tabindex = "2" } })
                        @Html.LikeMark(CommonsResource.BeforeLike)
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.StoreNameSearch</td>
                    <td>
                        @Html.EditorFor(model => model.SearchConditions.StoreName, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtStoreName", tabindex = "3" } })
                        @Html.LikeMark(CommonsResource.BeforeLike)
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.StoreAddressSearch</td>
                    <td>
                        @Html.EditorFor(model => model.SearchConditions.StoreAddress, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtStoreAddress", tabindex = "4" } })
                        @Html.LikeMark(CommonsResource.Like)
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.StoreTelSearch</td>
                    <td>
                        @Html.EditorFor(model => model.SearchConditions.StoreTel, new { htmlAttributes = new { @class = "w_14_long", @id = "txtStoreTel", tabindex = "5" } })
                        @Html.LikeMark(CommonsResource.BeforeLike)
                        @Html.ValidationMessageFor(model => model.SearchConditions.StoreTel, "", new { id = "StoreTel-errormessage" })
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.DeleteFlagSearch</td>
                    <td class="w_checkbox" colspan="2">
                        <label class="checkboxgroup">
                            @Html.CheckBoxFor(model => model.SearchConditions.DeleteFlag, new { @id = "chkIsNewDate", @class = "check-box" })
                            <span class="chk_parts"></span>
                        </label>
                        <span>@StoreResource.DeleteFlagSearch2</span>
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.MakeDateSearch</td>
                    <td>
                        <div class="sortarea" style="width:600px;">
                            <span class="date_input">
                                @Html.EditorFor(model => model.SearchConditions.MakeDateFrom, new { htmlAttributes = new { tabindex = "2", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                                <span class="arrow">&nbsp;</span>
                            </span>
                            -
                            <span class="date_input">
                                @Html.EditorFor(model => model.SearchConditions.MakeDateTo, new { htmlAttributes = new { tabindex = "3", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                                <span class="arrow">&nbsp;</span>
                            </span>
                        </div>
                        <div>
                            @Html.ValidationMessageFor(model => model.SearchConditions.MakeDateFrom, "", new { id = "MakeDateFromMessage" })
                            @Html.ValidationMessageFor(model => model.SearchConditions.MakeDateTo, "", new { id = "MakeDateToMessage" })
                        </div>
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td class="tdtitle10">@StoreResource.InspectionMustFlagSearch</td>
                    <td class="w_checkbox" colspan="2">
                        <label class="checkboxgroup">
                            @Html.CheckBoxFor(model => model.SearchConditions.InspectionMustFlag, new { @id = "chkInspectionMustFlag", @class = "check-box" })
                            <span class="chk_parts"></span>
                        </label>
                        <span>@StoreResource.InspectionMustFlagSearch2</span>
                    </td>
                    <td></td>
                </tr>
                <tr>
                    <td></td>
                    <td></td>
                    <td>
                        @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "Store", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark" })
                        <button class="btn btn-outline-dark" id="btnSearch" tabindex="4" onclick="$('#frmSearch').submit()">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                    </td>
                </tr>
            </tbody>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.StoreResult.Stores != null)
{
    <div class="sublbarea no_border" style="height:54px;margin-right:40px;margin-bottom: -10px;">
        <div class="sortarea">
            <ul>
                <li>
                    <button type="button" id="btnDownload" class="download" style="width:140px">
                        <img src="~/Content/img/download.png" />
                        @FormsResource.BTN_DOWNLOAD
                    </button>
                </li>
            </ul>
        </div>
    </div>
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.StoreResult.Stores.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.StoreResult.Stores.Count() > 0)
            {
                @Html.PagedListPager(Model.StoreResult.Stores, Page => Url.Action("Search", "Store", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.StoreResult.Stores.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:71vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">&nbsp;</th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.StoreClass
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.StoreId
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.StoreName
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.OpenDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.CloseDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.InspectionMustFlag
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.StockOutDisableFlag
                                </th>
                                <th class="bg-grey align-middle">
                                    @StoreResource.DeleteFlag
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "Store", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.StoreResult.Stores.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Stores[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" />
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.StoreResult.Stores.PageNumber - 1) * Model.StoreResult.Stores.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StoreClass)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StoreId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StoreName1)
                                            @Html.DisplayFor(modelItem => cModel.v.StoreName2)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(model => cModel.v.OpenDate, "{0:yyyy/MM/dd}")
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(model => cModel.v.CloseDate, "{0:yyyy/MM/dd}")
                                        </td>
                                        <td class="align-middle">
                                            <label class="chklist">
                                                @Html.CheckBoxFor(model => cModel.v.InspectionMustFlag, new { @class = "check-box _pm", onclick = "return false;" })
                                                <span class="chk_parts">
                                                </span>
                                            </label>
                                        </td>
                                        <td class="align-middle">
                                            <label class="chklist">
                                                @Html.CheckBoxFor(model => cModel.v.StockOutDisableFlag, new { @class = "check-box _pm", onclick = "return false;" })
                                                <span class="chk_parts">
                                                </span>
                                            </label>
                                        </td>
                                        <td class="align-middle">
                                            <label class="chklist">
                                                @Html.CheckBoxFor(model => cModel.v.DeleteFlag, new { @class = "check-box _pm", onclick = "return false;" })
                                                <span class="chk_parts">
                                                </span>
                                            </label>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.StoreId, new { Name = key + "StoreId" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                            @Html.HiddenFor(modelItem => cModel.v.ShipperId, new { Name = key + "ShipperId" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        <button type="submit" id="btnUpdate" class="btn btn-dark btnsize" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "Store", new { area = "Master", controller = "Store", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        /**
         * Country class
         */
        var StoresView = {
        
            /**
             * CONST Object
             */
            CONST: {
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                FORM: 'form',
                METHOD: 'method',
                ACTION: 'action'
            },
        
            /**
             * SELECTORS Object
             */
            SELECTORS: {
                chkInTable: '#listData input[type=radio][id$=".CheckedValue"]',
                chkCheckedInTable: '#listData input[type=radio][id$=".CheckedValue"]:checked',
                chkInRow: 'input[type=radio][class=check-box]',
                tblRow: '#listData tbody tr',
                btnEdit: '#btnUpdate',
                ddlSortKey: '#ddlSortKey',
                chkChecked: ':radio:checked',
                form: 'form',
                searchForm: '#frmSearch',
                btnSearch: '#btnSearch',
                frmUpdate: 'frmUpdate',
                btnSubmit: 'button[type=submit],input[type=submit]'
            },
        
            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus();
            },
        
            /**
             * Register event for control
             */
            registerEvent: function () {
        
                /**
                 * Check box click
                 */
                $(StoresView.SELECTORS.chkInTable).click(function (evt) {
                    $(this).prop("checked", true);
                    evt.stopPropagation();
                    StoresView.setButtonStatus();
                });
        
                /**
                * Dropdownlist change item
                */
                $(StoresView.SELECTORS.ddlSort).change(function (val) {
                    $(StoresView.SELECTORS.btnSearch).click();
                });
        
                /**
                 * Dropdownlist change item
                 */
                $(StoresView.SELECTORS.ddlSortKey).change(function (val) {
                    $(StoresView.SELECTORS.btnSearch).click();
                });
        
                $(StoresView.SELECTORS.btnSearch).click(function () {
                    var urlAction = '@Url.Action("Search", "Store", new { area = "Master" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "GET");
                    $form.submit();
                });
        
                $(StoresView.SELECTORS.btnUpdate).click(function () {
                    var list = UsersView.getCheckList();
                    $("#hiddata").val(list[0]);
                    $("#frmUpdate").submit();
                });
        
            },
        
            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function () {
                // Enable/Disable button Edit
                if ($(StoresView.SELECTORS.chkCheckedInTable).length === 1) {
                    $(StoresView.SELECTORS.btnEdit).removeAttr('disabled');
                } else {
                    $(StoresView.SELECTORS.btnEdit).attr('disabled', 'disabled');
                }
            },
        }
        
        
        /**
        * Page loaded
        */
        $(document).ready(function () {
            StoresView.init();
        
            $("#btnDownload").on("click", function () {
                var urlAction = '@Url.Action("Download", "Store", new { area = "Master" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "GET");
                $form.submit();

                setTimeout(function () {
                    if ($(StoresView.SELECTORS.chkCheckedInTable).length === 1) {
                        $(StoresView.SELECTORS.btnEdit).removeAttr('disabled');
                    }
                }, 1000);
            });
        });
        
        function ClearConditons() {
            $("#txtStoreClass").val(0);
            $("#txtStoreId").val("");
            $("#txtStoreName").val("");
        }

        // Sort
        function getSortData() {
        
            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());
        
            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "Store", new { area= "Master" })';
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        }

        function SetIsCheck(id) {
            $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
            $('#listData input[type=checkbox][id="' + id + '"]').prop("checked", true);
        }

    </script>
}