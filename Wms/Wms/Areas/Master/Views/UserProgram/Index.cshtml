@** スクリプト *@
@section LayoutScripts{
    <script>
    /**
     * Country class
     */
        var UserProgramsView = {

            /**
             * CONST Object
             */
            CONST: {
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                FORM: 'form',
                METHOD: 'method',
                ACTION: 'action'
            },

            /**
             * SELECTORS Object
             */
            SELECTORS: {
                chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
                chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
                chkInRow: 'input[type=checkbox][class=check-box]',
                tblRow: '#listData tbody tr',
                btnCheckAll: '#rbCheckAll',
                btnUnCheckAll: '#rbUnCheckAll',
                rowSelected: '#spnCheckedCounter',
                chkChecked: ':checkbox:checked',
                chkLabel: '#listData span.chk_parts',
                form: 'form',
                searchForm: '#frmSearch',
                frmUpdate: 'frmUpdate',
                btnUpdate: '#btnUpdate',
                btnSearch: '#btnSearch',
                btnSubmit: 'button[type=submit],input[type=submit]'
            },

            /**
            * Init data
            */
            init: function () {
                this.registerEvent();
                this.setCheckboxs();
                this.setButtonStatus();
            },

            /**
            * Register event for control
            */
            registerEvent: function () {

                /**
                * Stop event fired when click to checkbox
                */
                $(UserProgramsView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                * Check box click
                */
                $(UserProgramsView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    UserProgramsView.setButtonStatus();
                });

                /**
                * Button check all clicked
                */
                $(UserProgramsView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $(UserProgramsView.SELECTORS.chkInTable).prop('checked', true);
                        UserProgramsView.setRowidsFlag(true);
                    }
                });

                /**
                * Button UnCheck all clicked
                */
                $(UserProgramsView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $(UserProgramsView.SELECTORS.chkInTable).prop('checked', false);
                        UserProgramsView.setRowidsFlag(false);
                    }
                });

                $(UserProgramsView.SELECTORS.btnSearch).click(function () {
                    UserProgramsView.setStorageInit();
                });


                $(UserProgramsView.SELECTORS.btnUpdate).click(function () {
                    var list = UserProgramsView.getCheckList();
                    $("#hiddata").val(JSON.stringify(list));

                    var storage = window.localStorage;
                    $("#hiddata1").val(storage.getItem('PPLClass'));

                    $("#frmUpdate").submit();
                });
            },

            /**
            * Enable/Disable button Edit
            */
            setButtonStatus: function () {
                UserProgramsView.setCheckboxs('set')
            },

            // save page
            setRowidsFlag: function (flag) {
                var storage = window.localStorage;
                var rowids = storage.getItem('PKeys');
                if (rowids != null) {
                    var jrid = JSON.parse(rowids);
                    $.each(jrid, function (key) {
                        jrid[key] = flag;
                    });
                    storage.setItem('PKeys', JSON.stringify(jrid));
                }
                UserProgramsView.setButtonStatus();
            },

            setCheckboxs: function (flag) {
                var storage = window.localStorage;
                var rowids = storage.getItem('PKeys');
                if (rowids != null) {
                    var cnt = 0;
                    var jrid = JSON.parse(rowids);
                    var checkboxs = $("#listData input[type=checkbox]")
                    checkboxs.each(function () {
                        var row = $(this).parent().parent().parent();
                        var rowid = row.find(".rowid").val();
                        //var idx = rowid - 1;
                        //var Rid = $("input[name='LocTransporters[" + idx + "].Rid']").val();

                        if (flag == 'set') {
                            jrid[rowid] = $(this).is(':checked');
                        }
                        else {
                            if (jrid[rowid]) {
                                $(this).prop("checked", true);
                            }
                        }
                    });

                    if (flag == 'set') {
                        storage.setItem('PKeys', JSON.stringify(jrid));
                    }

                    $.each(jrid, function (key, value) {
                        if (value) {
                            cnt++;
                        }
                    });


                    $(UserProgramsView.SELECTORS.btnUpdate).attr('disabled', 'disabled');

                    if (cnt > 0) {
                        $(UserProgramsView.SELECTORS.btnUpdate).removeAttr('disabled');
                    }

                    if ($('#frmUpdate').length > 0) {
                        $(UserProgramsView.SELECTORS.rowSelected).text(cnt);
                    }
                }

            },

            setStorageInit: function () {
                if (window.localStorage) {

                    var storage = window.localStorage;
                    storage.removeItem('PKeys');
                    var data = {
                        'SearchConditions.ProgramName': $("#txtProgramName").val(),
                        'SearchConditions.ProgramClass': $("#txtProgramClass").val(),
                        'SearchConditions.PermissionLevel': $("#txtPermissionLevel").val()
                    };

                    storage.setItem('PPLClass', $("#txtPermissionLevel").val());

                    $.ajax({
                        type: "post",
                        url: "@Url.Action("GetPKeys", "UserProgram")",
                        data: data,
                        async: false,
                        success: function (data) {
                            var rowids = {};
                            $.each(data, function (n, value) {
                                rowids[value] = false;
                            });

                            var storage = window.localStorage;
                            storage.setItem('PKeys', JSON.stringify(rowids));

                        }
                    });
                }
            },

            getCheckList: function () {
                var list = [];
                var storage = window.localStorage;
                rowids = storage.getItem('PKeys');
                if (rowids != null) {

                    var jrid = JSON.parse(rowids);
                    $.each(jrid, function (key) {
                        if (jrid[key]) {
                            list.push(key);
                        }
                    });
                }

                return list;
            },

        }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        UserProgramsView.init();
    });
    function ClearConditons() {
        $("#txtUserId").val("");
        $("#txtUserName").val("");
    }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());

