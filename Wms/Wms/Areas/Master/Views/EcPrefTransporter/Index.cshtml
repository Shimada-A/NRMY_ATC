@using Share.Common;
@using PagedList.Mvc;
@using Wms.Areas.Master.Resources;
@model Wms.Areas.Master.ViewModels.EcPrefTransporter.Index
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_MAS_EcPrefTransporter01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "EcPrefTransporter", FormMethod.Get, new { id = "frmSearch" }))
    {
    <table>
        <tr>
            <td class="tdtitle_10">
                @EcPrefTransporterResource.Center：
            </td>
            <td>
                <div class="sort">
                    <div class="sort_inner">
                        @Html.DropDownListFor(model => model.SearchConditions.CenterId, (IEnumerable<SelectListItem>)ViewBag.Center, new { id = "ddlSearchCenter", tabindex = "1" })
                    </div>
                </div>
            </td>
        </tr>
        <tr>
            <td class="tdtitle_10">
                @EcPrefTransporterResource.TransporterId：
            </td>
            <td colspan="2">
                <div class="sort">
                    <div class="sort_inner">
                        @Html.DropDownListFor(model => model.SearchConditions.TransporterId, (IEnumerable<SelectListItem>)ViewBag.Transporter, CommonResource.None, new { id = "ddlTransporterId", tabindex = "2" })
                    </div>
                </div>
            </td>
            <td></td>
            <td></td>
        </tr>
        <tr>
            <td></td>
            <td></td>
            <td>
                @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "EcPrefTransporter", new { area = "Master" }, new { type = "button", @class = "btn btn-outline-dark" })
                <button class="btn btn-outline-dark" id="btnSearch" tabindex="4" onclick="$('#frmSearch').submit()">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
            </td>
        </tr>
    </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
    }
</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.EcPrefTransporterResult.EcPrefTransporters != null)
{
    @* Sublbarea *@
    <div class="sublbarea">
        <div class="sortarea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.EcPrefTransporterResult.EcPrefTransporters.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.EcPrefTransporterResult.EcPrefTransporters.Count() > 0)
            {
                @Html.PagedListPager(Model.EcPrefTransporterResult.EcPrefTransporters, Page => Url.Action("Search", "EcPrefTransporter", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.EcPrefTransporterResult.EcPrefTransporters.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:71vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey">&nbsp;</th>
                                <th class="bg-grey">
                                    @EcPrefTransporterResource.No
                                </th>
                                <th class="bg-grey">
                                    @EcPrefTransporterResource.PrefId
                                </th>
                                <th class="bg-grey">
                                    @EcPrefTransporterResource.PrefName
                                </th>
                                <th class="bg-grey">
                                    @EcPrefTransporterResource.TransporterName
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "EcPrefTransporter", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.EcPrefTransporterResult.EcPrefTransporters.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("EcPrefTransporters[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="setIsCheck('@(key + "IsCheck")'); setButtonStatus();" />
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.EcPrefTransporterResult.EcPrefTransporters.PageNumber - 1) * Model.EcPrefTransporterResult.EcPrefTransporters.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.PrefId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.PrefName)
                                        </td>
                                        <td class="align-middle">
                                            <div>@Html.DisplayFor(m => cModel.v.TransporterId)</div>
                                            <div>@Html.DisplayFor(m => cModel.v.TransporterName)</div>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.CenterId, new { Name = key + "CenterId" })
                                            @Html.HiddenFor(modelItem => cModel.v.PrefId, new { Name = key + "PrefId" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        <button type="submit" id="btnUpdate" class="btn btn-dark btnsize_large" form="frmUpdate" formmethod="post" formaction=@Url.Action("Edit", "EcPrefTransporter", new { area = "Master", controller = "EcPrefTransporter", action = "Edit" })>@FormsResource.BTN_DETAIL</button>
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        $(window).on('load', function () {
            setButtonStatus();
        });

        // 表示順ドロップダウンリスト選択時
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());

            $("#frmSearch").submit();

        }

        // 一覧のラジオボタンのチェック状態を隠し項目にセット
        function setIsCheck(id) {
            $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
            $('#listData input[type=checkbox][id="' + id + '"]').prop("checked", true);
        }

        // 詳細画面へボタン 活性非活性切り替え
        function setButtonStatus() {
            if ($("input[name='IsCheck']:checked").length === 1) {
                $("#btnUpdate").removeAttr('disabled');
            } else {
                $("#btnUpdate").attr('disabled', 'disabled');
            }
        }
    </script>
}