@using Resources = Wms.Areas.Returns.Resources;
@model Wms.Areas.Returns.ViewModels.PurchaseCorrection.PurchaseCorrectionSearchConditions
<div id="vendorReturnSearchModalDialog">
    <div id="vendorReturnSearchResult">
        <span class="ui-helper-hidden-accessible"><input type="image" /></span>
        <h5>@Resources.PurchaseCorrectionResource.CaseModalTitle</h5>
        <br />
        <div class="d_continer main">
            @if (Model.caseViewModel.Count == 0)
            {
                <h5>@Resources.PurchaseCorrectionResource.CASE_NOT_ERR</h5>
            }
            else
            {
                <div class="modalheadareaheight">
                    <table class="headtable">
                        <tr>
                            <td>
                                @Resources.PurchaseCorrectionResource.JanS
                                @Html.DisplayFor(model => Model.caseViewModel[0].Jan)
                            </td>
                            <td>
                                @Resources.PurchaseCorrectionResource.SkuS
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemSkuId)
                            </td>
                            <td>
                                @Resources.PurchaseCorrectionResource.ItemS
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemId)
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemName)
                            </td>
                        </tr>
                        <tr>
                            <td>
                                @Resources.PurchaseCorrectionResource.ItemColorS
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemColorId)
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemColorName)
                            </td>
                            <td>
                                @Resources.PurchaseCorrectionResource.ItemSizeS
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemSizeId)
                                @Html.DisplayFor(model => Model.caseViewModel[0].ItemSizeName)
                            </td>
                            <td></td>
                        </tr>
                        <tr>
                            <td>
                                @Resources.PurchaseCorrectionResource.LocationCdS
                                @Html.DisplayFor(model => Model.caseViewModel[0].LocationCd)
                            </td>
                            <td>
                                @Resources.PurchaseCorrectionResource.LocationClassS
                                @Html.DisplayFor(model => Model.caseViewModel[0].LocationClass)
                            </td>
                            <td>
                                @Resources.PurchaseCorrectionResource.GradeIdS
                                @Html.DisplayFor(model => Model.caseViewModel[0].GradeId)
                            </td>
                        </tr>
                    </table>
                </div>
                <div class="sublbarea">
                    <div class="sortarea">
                        <ul>
                            <li class="totalcount">
                                @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.totalCnt)
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="Container">
                    <div>
                        <div class="tb_scroll">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th class="bg-grey w_checkbox"></th>
                                        <th class="bg-grey">
                                            No
                                        </th>
                                        <th class="bg-grey">
                                            @Resources.PurchaseCorrectionResource.BoxNo
                                        </th>
                                        <th class="bg-grey">
                                            @Resources.PurchaseCorrectionResource.StockQty
                                        </th>
                                        <th class="bg-grey">
                                            @Resources.PurchaseCorrectionResource.CaseAllocQty
                                        </th>
                                        <th class="bg-grey">
                                            @Resources.PurchaseCorrectionResource.KanouQty
                                        </th>
                                        <th class="bg-grey">
                                            @Resources.PurchaseCorrectionResource.InvoiceBatch
                                        </th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < Model.caseViewModel.Count(); i++)
                                    {

                                        var idx = i + 1;
                                        var id = "hidCase" + i;
                                        var stockCaseQty = "hidCaseStock" + i;
                                        <tr>
                                            <td class="align-middle chk_cell">
                                                <label>
                                                    @Html.RadioButton("SelectIndex", i.ToString(), new { @id = "CaseReturnSelectIndex" + i.ToString(), @class = "radio_input", @onclick = "chkRadioCase(" + i + ")" })
                                                    <span class="radio_parts"></span>
                                                </label>
                                            </td>
                                            <td class="text-right w_no">
                                                @idx
                                            </td>
                                            <td>
                                                <span id=@id>
                                                    @Html.DisplayFor(model => Model.caseViewModel[i].BoxNo)
                                                </span>
                                            </td>
                                            <td class="text-right">
                                                <span id=@stockCaseQty>
                                                    @Html.DisplayFor(model => Model.caseViewModel[i].StockQty)
                                                </span>
                                            </td>
                                            <td class="text-right">
                                                @Html.DisplayFor(model => Model.caseViewModel[i].AllocQty)
                                            </td>
                                            <td class="text-right">
                                                @Html.DisplayFor(model => Model.caseViewModel[i].KanouQty)
                                            </td>
                                            <td>
                                                @Html.DisplayFor(model => Model.caseViewModel[i].InvoiceNo)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
            <div class="bottomnav">
                <div class="btnarea">
                    <button id="CaseReturnClose" type="button" class="btn btn-outline-dark" onclick="closeDialogCase()">@FormsResource.Close</button>
                    <button id="CaseReturnSelect" type="button" class="btn btn-dark" onclick="chkDialogCase()">@FormsResource.BTN_SELECT</button>
                </div>
            </div>
            <input type="hidden" id="chkIndexCase" value="" />
        </div>
    </div>
</div>