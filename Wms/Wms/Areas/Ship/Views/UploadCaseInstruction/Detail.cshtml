@if (Model.Results.CaseDetails != null && Model.SearchConditions.HidShipKindName == UploadCaseInstructionResource.KindCase)
{
    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.CaseDetails.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div class="head">
                <table class="headtable">
                    <tr>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.StoreQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidStoreQty
                        </td>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.CaseQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidCaseQty
                        </td>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.DetailRowQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidDetailRowQty
                        </td>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.SkuQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidPicJanQty
                        </td>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.PlanQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidPicInsQty
                        </td>
                        <td class="tdtitle ltWidthS">
                            @UploadCaseInstructionResource.HikiErrQty :
                        </td>
                        <td class="ltWidthS">
                            @Model.SearchConditions.HidHikiErrQty
                        </td>
                </table>
            </div>
            <div>
                <div class="tb_scroll" style="height:59vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.ShipPlanDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.CaseNo
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.ShipToStoreName
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.PrioritOrder
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.SkuQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @UploadCaseInstructionResource.InstructQtyDetail
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var cModel in Model.Results.CaseDetails.Select((v, i) => new { v, i }))
                            {
                                var key = String.Format("CaseDetails[{0}].", cModel.i);
                                <tr>
                                    <td class="align-middle  w_no">
                                        @Html.DisplayFor(modelItem => cModel.v.LineNo)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ShipPlanDate)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.BoxNo)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ShipToStoreId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.StoreName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.PriorityOrder)
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.SkuQty)
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.InstructQty)
                                    </td>
                                    <td class="template" hidden>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}
