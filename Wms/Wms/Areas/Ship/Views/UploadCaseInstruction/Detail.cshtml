@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@using Wms.Areas.Ship.ViewModels.UploadCaseInstruction;
@model Wms.Areas.Ship.ViewModels.UploadCaseInstruction.UploadCaseInstructionViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_STK_UploadCaseInstruction;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Styles.Render("~/bundles/FileUploadCss")
@* Head *@
@using (Html.BeginForm("SearchDetail", "UploadCaseInstruction", FormMethod.Post, new { id = "frmSearch" }))
{
    <div id="div_search" class="head">
        <table class="headtable">
            <tr>
                <td class="tdtitle ltWidthS">
                    @UploadCaseInstructionResource.BatchNo :
                </td>
                <td class="ltWidthS">
                    @Model.SearchConditions.HidBatchNo
                </td>
                <td class="ltWidthS">
                    @Model.SearchConditions.HidShipInstructName
                </td>
            </tr>
            <tr>
                <td class="tdtitle">
                    @UploadCaseInstructionResource.ShipKind :
                </td>
                <td>
                    @Model.SearchConditions.HidShipKindName
                </td>
            </tr>
        </table>
    </div>
    <input type="hidden" name="SearchConditions.HidPage" id="hidPage" value="@Model.SearchConditions.HidPage" />
    @Html.HiddenFor(model => model.SearchConditions.HidCenterId, new { id = "hidCenterId" })
    @Html.HiddenFor(model => model.SearchConditions.HidShipKind, new { id = "hidShipKind" })
    @Html.HiddenFor(model => model.SearchConditions.HidBatchNo, new { id = "hidBatchNo" })
    @Html.HiddenFor(model => model.SearchConditions.HidShipInstructName, new { id = "hidShipInstructName" })
    @Html.HiddenFor(model => model.SearchConditions.HidStoreQty, new { id = "hidStoreQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidCaseQty, new { id = "hidCaseQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidDetailRowQty, new { id = "hidDetailRowQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidPicJanQty, new { id = "hidPicJanQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidPicInsQty, new { id = "hidPicInsQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidHikiErrQty, new { id = "hidHikiErrQty" })
    @Html.HiddenFor(model => model.SearchConditions.HidShipKindName, new { id = "hidShipKindName" })
    @Html.HiddenFor(model => model.SearchConditions.Seq, new { id = "hidSeq" })
    @Html.HiddenFor(model => model.SearchConditions.HidIndexPage, new { id = "hidIndexPage" })
    @Html.HiddenFor(model => model.SearchConditions.PageSize, new { id = "hidIndexPageSize" })
    @Html.HiddenFor(model => model.SearchConditions.DetailCaseKey, new { id = "hidDetailCaseKey" })
    @Html.HiddenFor(model => model.SearchConditions.DetailJanKey, new { id = "hidDetailJanKey" })
    @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
    @Html.HiddenFor(model => model.SearchConditions.HidSort, new { id = "hidSortPage" })
    @Html.HiddenFor(model => model.SearchConditions.HidKey, new { id = "hidKeyPage" })
}
@if (Model.Results.CaseDetails != null && Model.Results.CaseDetails.Count() > 0 && Model.SearchConditions.HidShipKindName == UploadCaseInstructionResource.KindCase)
{
    @* Sublbarea *@
    <div class="sublbarea no_border">
        <div class="sortarea mainpagearea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.DetailCaseKey, new { Name = "SearchConditions.DetailCaseKey", @id = "ddlDetailCaseKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.CaseDetails.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.Results.CaseDetails.Count() > 0)
            {
                @Html.PagedListPager(Model.Results.CaseDetails, Page => Url.Action("SearchDetail", "UploadCaseInstruction", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>
}
