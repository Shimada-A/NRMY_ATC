            */
            $(EcConfirmProgressView.SELECTORS.btnUnCheckAll).click(function () {
                if ($("#listData").length) {
                    $("#hidSearchType").val("SortPage");
                    var urlAction = '@Url.Action("UnSelectedSearch", "EcConfirmProgress", new { area= "Ship" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "POST");
                    $form.submit();
                }
            });
        },

        /**
        * Enable/Disable button Edit
        */
        setButtonStatus: function (difCnt) {
            // Display row is selected
            $(EcConfirmProgressView.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
            // Enable/Disable button Edit
            if ($(EcConfirmProgressView.SELECTORS.rowSelected).text() >= 1 && getUsable_Class() == 3) {
                $(EcConfirmProgressView.SELECTORS.btnShipConfirm).removeAttr('disabled');
            } else {
                $(EcConfirmProgressView.SELECTORS.btnShipConfirm).attr('disabled', 'disabled');
            }
        },
    }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        EcConfirmProgressView.init();
        $("#ddlSortKey").removeClass("input-validation-error");

        @* Pageを変更時 *@
        $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
            var urlAction ='@Url.Action("Search", "EcConfirmProgress", new { area= "Ship" })';
            var pageUrl = urlAction + '?Page=';
            var page = $(item).attr("href").replace(pageUrl, "");
            page = page.replace("&class=btn-outline-dark", "");
