@section LayoutScripts{
    <script>
    $("#btnDownload").on("click", function () {
        var urlAction = '@Url.Action("Download", "EcConfirmProgress", new { area = "Ship" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "Post");
        $form.submit();
    });
    $("#btnDownloadDetail").on("click", function () {
        var urlAction = '@Url.Action("DownloadDetail", "EcConfirmProgress", new { area = "Ship" })';
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "Post");
        $form.submit();
    });

    /**
        * Country class
        */
    var curentSelectedCnt = 0;
    var curentSelectedCntDiff = 0;
    var EcConfirmProgressView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            btnShipConfirm: '#btnShipConfirm',
            ddlSortKey: '#ddlSortKey',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
        },

        /**
            * Init data
            */
        init: function () {
            this.registerEvent();
            this.setButtonStatus(0);
            curentSelectedCnt = $(EcConfirmProgressView.SELECTORS.chkCheckedInTable).length;
        },

        /**
            * Register event for control
            */
        registerEvent: function () {

            /**
            * Stop event fired when click to checkbox
            */
            $(EcConfirmProgressView.SELECTORS.chkLabel).click(function (evt) {
                evt.stopPropagation();
            });

            /**
            * Check box click
            */
            $(EcConfirmProgressView.SELECTORS.chkInTable).click(function (evt) {
                evt.stopPropagation();
                curentSelectedCntDiff = curentSelectedCnt - $(EcConfirmProgressView.SELECTORS.chkCheckedInTable).length;
                EcConfirmProgressView.setButtonStatus(curentSelectedCntDiff);
            });

            /**
            * Dropdownlist change item
            */
            $(EcConfirmProgressView.SELECTORS.ddlSort).change(function (val) {
                $(EcConfirmProgressView.SELECTORS.btnSearch).click();
            });

            /**
            * Dropdownlist change item
            */
            $(EcConfirmProgressView.SELECTORS.ddlSortKey).change(function (val) {
                $(EcConfirmProgressView.SELECTORS.btnSearch).click();
            });

            /**
            * Button check all clicked
            */
            $(EcConfirmProgressView.SELECTORS.btnCheckAll).click(function () {
                if ($("#listData").length) {
                    $("#hidSearchType").val("SortPage");
                    var urlAction = '@Url.Action("AllSelectedSearch", "EcConfirmProgress", new { area= "Ship" })';
                    var $form = $("#frmSearch");
                    $form.attr("action", urlAction);
                    $form.attr("method", "POST");
                    $form.submit();
                }
            });

            /**
