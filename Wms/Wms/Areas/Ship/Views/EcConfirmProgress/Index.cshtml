                                <th class="bg-grey">
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "EcConfirmProgress", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.EcConfirmProgress01s.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("EcConfirmProgress01s[{0}].", cModel.i);
                            <tr>
                                <td class="w_checkbox align-middle">
                                    <label class="checkboxgroup">
                                        @if (cModel.v.ShipStatusName != BtoBReferenceResource.Print && cModel.v.ShipStatusName != BtoBReferenceResource.InvoicePrint)
                                        {
                                            @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")", disabled = true })
                                        }
                                        else
                                        {
                                            @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")" })
                                        }
                                        @*@Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")" })*@
                                        <span class="chk_parts"></span>
                                    </label>
                                </td>
                                <td class="align-middle text-right w_no">
                                    @((cModel.i + 1) + (Model.Results.EcConfirmProgress01s.PageNumber - 1) * Model.Results.EcConfirmProgress01s.PageSize)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.ShipPlanDate)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.ShipInstructId)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.OrderDate)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.TransporterName)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.ArriveRequestDate)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.AllocDate)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.ShipStatusName)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.KakuDate)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.EcShipClassName)
                                </td>
                                <td class="align-middle text-right">
                                    @Html.DisplayFor(modelItem => cModel.v.OrderQty)
                                </td>
                                <td class="align-middle text-right">
                                    @Html.DisplayFor(modelItem => cModel.v.StockoutQty)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.CancelFlag)
                                </td>
                                <td class="align-middle" style="width:100px;">
                                    <button type="button" class="btn btn-dark btn-sm" onclick="Detail(@cModel.v.Seq,@cModel.v.LineNo)">@EcConfirmProgressResource.BtnPackageDetail</button>
                                </td>
                                <td class="template" hidden>
                                    @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                    @Html.HiddenFor(modelItem => cModel.v.LineNo, new { Name = key + "LineNo" })
                                </td>
                            </tr>
                                }
                            }
