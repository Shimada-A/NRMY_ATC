@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@model Wms.Areas.Ship.ViewModels.EcConfirmProgress.EcConfirmProgress02ViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_SHP_EcConfirmProgress02;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
@using (Html.BeginForm("SearchDetail", "EcConfirmProgress", FormMethod.Post, new { id = "frmDetailSearch" }))
{
    @Html.AntiForgeryToken()
    <div class="headarea sortheadareaheight">
        @if (Model.DetailResults.EcConfirmProgress02s != null && Model.DetailResults.EcConfirmProgress02s.Count() > 0)
        {
            <table class="headtable">
                <tr>
                    <td>@EcConfirmProgressResource.ShipPlanDateS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().ShipPlanDate)
                    </td>
                    <td>@EcConfirmProgressResource.MakeDateS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().AllocDate)
                    </td>
                </tr>
                <tr>
                    <td>@EcConfirmProgressResource.ShipInstructIdS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().ShipInstructId)
                    </td>
                    <td>@EcConfirmProgressResource.OrderDateS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().OrderDate)
                    </td>
                    <td>@EcConfirmProgressResource.RelatedOrderNoS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().RelatedOrderNo)
                    </td>
                </tr>
                <tr>
                    <td>@EcConfirmProgressResource.DestPrefNameS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().DestPrefName)
                    </td>
                    <td>@EcConfirmProgressResource.TransporterS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().TransporterName)
                    </td>
                    <td>@EcConfirmProgressResource.DeliShiwakeCdS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().DeliShiwakeCd)
                    </td>
                </tr>
                <tr>
                    <td>@EcConfirmProgressResource.EcShipClassS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().EcShipClass)
                    </td>
                    <td>@EcConfirmProgressResource.ArriveRequestDateS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().ArriveRequestDate)
                    </td>
                    <td>@EcConfirmProgressResource.ArriveRequestTimeS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().ArriveRequestTime)
                    </td>
                </tr>
                <tr>
                    <td>@EcConfirmProgressResource.BatchNoS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().BatchNo)
                    </td>
                    <td>@EcConfirmProgressResource.GASBatchNoS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().GASBatchNo)
                    </td>
                    <td>@EcConfirmProgressResource.GasMaguchiNoS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().GasMaguchiNo)
                    </td>
                </tr>
                <tr>
                    <td>@EcConfirmProgressResource.KenDateS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().KenDate)
                    </td>
                    <td>@EcConfirmProgressResource.KenUserS</td>
                    <td>
                        @Html.DisplayFor(modelItem => modelItem.DetailResults.EcConfirmProgress02s.FirstOrDefault().KenUserName)
                    </td>
                </tr>
            </table>
        }
    </div>

    <div class="message-area">
        @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
        @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
    </div>

    if (Model.DetailResults.EcConfirmProgress02s != null)
    {
        if (Model.DetailResults.EcConfirmProgress02s.Count() > 0)
        {
            <div class="sublbarea no_border">
                <div class="sortarea mainpagearea">
                    <ul>
                        @if (ViewBag.PermissionLevel == PermissionLevelClasses.PermissionLevelSystemManager)
                        {
                            <li>
                                <button type="button" id="btnPrint" class="download" style="width:200px">
                                    <img src="~/Content/img/print.png" />
                                    @EcConfirmProgressResource.BtnPrint
                                </button>
                            </li>
                        }
                        <li>
                            @if (Model.DetailResults.EcConfirmProgress02s.FirstOrDefault().EcShipClass != "シングル")
                            {
                                @FormsResource.DISPLAY_SHORT
                            }
                            <div class="sort">
                                <div class="sort_inner">
                                    @if (Model.DetailResults.EcConfirmProgress02s.FirstOrDefault().EcShipClass != "シングル")
                                    {
                                        @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                                    }
                                    @Html.HiddenFor(model => model.SearchConditions.CenterId)
                                    @Html.HiddenFor(model => model.SearchConditions.ShipStatus)
                                    @Html.HiddenFor(model => model.SearchConditions.Seq)
                                    @Html.HiddenFor(model => model.SearchConditions.LineNo)
                                </div>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="sublbarea no_border stock_detail_head">
                @EcConfirmProgressResource.DetailTitle
                <div class="sortarea">
                    <ul>
                        <li>
                            @EcConfirmProgressResource.BoxNoSum @Html.DisplayFor(model => model.SearchConditions.BoxNoSum)
                        </li>
                        @if (Model.DetailResults.EcConfirmProgress02s.FirstOrDefault().EcShipClass != "シングル")
                        {
                            <li>
                                @EcConfirmProgressResource.SkuQtySum @Html.DisplayFor(model => model.SearchConditions.ItemSkuSum)
                            </li>
                        }
                        <li>
                            @EcConfirmProgressResource.ResultQtySum @Html.DisplayFor(model => model.SearchConditions.ResultQtySum)
                        </li>
                    </ul>
                </div>
            </div>
        }
    }
    if (Model.DetailResults.EcConfirmProgress02s != null)
    {

        @* Container *@
        <div class="Container">

            @* Content *@
            @if (Model.DetailResults.EcConfirmProgress02s.Count() == 0)
            {
                <div>
                    <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
                </div>
            }
            else
            {
                <div>
                    <div class="tb_scroll">
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.No
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.BoxNo
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.DeliNo
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.ShipInstructSeqs
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.CategoryName1
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.Item
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.Color
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.Size
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.JAN
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.OrderQty
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.ResultQtys
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @EcConfirmProgressResource.NouhinPrnUserId
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var pkey = 0;
                                }
                                @foreach (var cModel in Model.DetailResults.EcConfirmProgress02s.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("EcConfirmProgress02s[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle text-right">
                                            @(cModel.i + 1)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.BoxNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.DeliNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipInstructSeq)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CategoryName1)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemColorId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemColorName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSizeId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSizeName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.Jan)
                                        </td>
                                        <td class="align-middle text-right">
                                            @if (cModel.v.ShipInstructSeq != pkey)
                                            {
                                                @Html.DisplayFor(modelItem => cModel.v.AllocQty)
                                            }
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.NouhinPrnUserId)
                                        </td>
                                    </tr>
                                    pkey = cModel.v.ShipInstructSeq;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>  }
}

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        @Html.ActionLink(FormsResource.BTN_RETURN, "IndexSearch", "EcConfirmProgress", new { area = "Ship" }, new { type = "button", @class = "btn btn-outline-dark btnsize" })
    </div>
}
@** スクリプト *@
@section LayoutScripts{
    <script>
        // Sort
        function getSortData() {
            var $form = $("#frmDetailSearch");
            var urlAction ='@Url.Action("DetailSearch", "EcConfirmProgress", new { area= "Ship" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }

        $("#btnPrint").on("click", function () {
            var urlAction = '@Url.Action("Print", "EcConfirmProgress", new { area = "Ship" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.attr("target", "newtab");
            $form.submit();
            $form.attr("target", "_self");
        });
    </script>
}