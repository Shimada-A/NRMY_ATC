@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@using Wms.Areas.Ship.ViewModels.TransferReference;
@model Wms.Areas.Ship.ViewModels.TransferReference.TransferReferenceViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_SHP_TransferReference01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "TransferReference", FormMethod.Post, new { id = "frmSearch" }))
    {
        @Html.AntiForgeryToken()
        <table>
            <tr>
                <td class="tdtitle">@TransferReferenceResource.Center</td>
                <td colspan="2">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.CenterDropDownFor(
                                model => model.SearchConditions.CenterId
                                , Wms.Common.Profile.User.UserId
                                , "", new { @id = "ddlCenterId", tabindex = "1" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@TransferReferenceResource.ShipKind</td>
                <td colspan="2">
                    <label>
                        @Html.RadioButtonFor(model => model.SearchConditions.ShipKind, "Dc", new { tabindex = "2", @class = "radio_input" })
                        <span class="radio_parts"></span>
                        <span>@TransferReferenceResource.DcShip</span>
                    </label>
                    <label>
                        @Html.RadioButtonFor(model => model.SearchConditions.ShipKind, "Case", new { tabindex = "3", @class = "radio_input", })
                        <span class="radio_parts"></span>
                        <span>@TransferReferenceResource.CaseShip</span>
                    </label>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@TransferReferenceResource.AllocDate</td>
                <td>
                    <div class="sortarea" style="width:600px;">
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocDateFrom, new { htmlAttributes = new { tabindex = "4", @placeholder = "", @class = "startDate flatpickr", @style = "height:30px;" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        -
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocDateTo, new { htmlAttributes = new { tabindex = "5", @placeholder = "", @class = "endDate flatpickr", @style = "height:30px;" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                    </div>
                    <div>
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocDateFrom, "", new { })
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocDateTo, "", new { })
                    </div>
                </td>
                <td class="tdtitle">@TransferReferenceResource.BatchName</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.BatchName, new { htmlAttributes = new { @class = "w_30_normal", @id = "txtBatchName", tabindex = "6", @style = "outline:none;" } })
                    @Html.LikeMark(CommonsResource.Like)
                </td>
            </tr>
        </table>
        <p class="py-3"></p>
        <table>
            <tr>
                <td class="tdtitle"></td>
                <td class="w_80_normal" style="width:704px"></td>
                <td>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "TransferReference", new { area = "Ship" }, new { type = "button", @class = "btn btn-outline-dark", tabindex = "7" })
                    <button class="btn btn-outline-dark" id="btnSearch" type="button" tabindex="8" onclick="Search();">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        @Html.HiddenFor(model => model.SearchConditions.ShipPlanDate, new { id = "hidShipPlanDate" })
        @Html.HiddenFor(model => model.SearchConditions.BatchNo, new { id = "hidBatchNo" })
        @Html.HiddenFor(model => model.SearchConditions.ShipKind, new { id = "hidShipKind" })
        @Html.HiddenFor(model => model.SearchConditions.AllocDateFrom, new { id = "hidAllocDateFrom" })
        @Html.HiddenFor(model => model.SearchConditions.AllocDateTo, new { id = "hidAllocDateTo" })
        @Html.HiddenFor(model => model.SearchConditions.BatchName, new { id = "hidBatchName" })
    }

</div>
<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>
@*【DC出荷作業進捗】*@
