@** スクリプト *@
@section LayoutScripts{
    <script>
        function Search() {
                var urlAction = '@Url.Action("Search", "TransferReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
        }
        function BtoBInstructionReference() {
            var urlAction = '@Url.Action("BtoBInstructionSearch", "BtoBInstructionReference", new { area = "Ship" })';
            var $form = $("#frmSearch");
            if ($('#hidShipKind').val() == 'TC') {
                $("#hidBatchNo").val('');
            }
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function EcConfirmProgress() {
                var urlAction = '@Url.Action("EcConfirmProgressSearch", "EcConfirmProgress", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
        }
        // ピック情報出力、CSVダウンロードリクエスト
        $("#btnDownLoadPickInfo").on("click", function () {
            var urlAction = '@Url.Action("DownloadPickInfo", "TransferReference", new { area = "Ship" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
            enableSubmit();
        });

        $('#btnBatchReference').on("click", function () {
            var urlAction ='@Url.Action("Cancel", "TransferReference", new { area = "Ship" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        function SetCheckValue(shipKind,shipPlanDate,batchNo) {
            if (shipKind == 'TC') {
                $("#btnItemDetail").removeAttr('disabled');
                $("#btnLaneSortDetail").removeAttr('disabled');
                $("#btnStoreSortOrderPicDetail").removeAttr('disabled');
                $("#btnBtoBInstruction").removeAttr('disabled');
            } else if (shipKind == 'DC') {
                $("#btnDownLoadPickInfo").removeAttr('disabled');
                $("#btnPickSortDetail").removeAttr('disabled');
                $("#btnLaneSortDetail").removeAttr('disabled');
                $("#btnStoreSortOrderPicDetail").removeAttr('disabled');
                $("#btnBtoBInstruction").removeAttr('disabled');
            } else if (shipKind == 'EC') {
                $("#btnPickSortDetail").removeAttr('disabled');
                $("#btnEcunitReference").removeAttr('disabled');
                $("#btnEcConfirmProgress").removeAttr('disabled');
            }

            if (shipKind != 'TC') {
                $("#btnPickResult").removeAttr('disabled');
            }

            $("#hidShipKind").val(shipKind);
            $("#hidShipPlanDate").val(shipPlanDate);
            $("#hidBatchNo").val(batchNo);
        }

        function SetCheckValueStore(itemSkuId, batchNo) {
            $("#btnPickSortDetailStore").removeAttr('disabled');
            $("#hidItemSkuId").val(itemSkuId);
            $("#hidBatchNoStore").val(batchNo);
        }
        //ﾎﾟﾝﾁ (ECユニット仕分)
        var current_scrollY;
        $(function () {
            $("#dialog").dialog({
                autoOpen: false,
                width: 1100,
                Height: 100,
                modal: true,
                position: { my: 'center top+30', at: 'center top', of: "body" },
                dialogClass: 'modalct',
                resizable: false
            });

            $("#dialogStore").dialog({
                autoOpen: false,
                width: 1100,
                Height: 100,
                modal: true,
                position: { my: 'center top+30', at: 'center top', of: "body" },
                dialogClass: 'modalct',
                resizable: false
            });

            $(".ui-icon-closethick").on("click",
                function () {
                    $('.wrap').attr({ style: '' });
                    $('html, body').prop({ scrollTop: current_scrollY });

                    if ($("#btnDetailsStoreClose").is(":hidden")) {
                        $("#dialog").dialog("close");
                    } else {
                        $("#dialogStore").dialog("close");
                    }
                    document.activeElement.blur(); /* フォーカス解除 IE11 */
                });

            $("#btnDetailsClose").on("click",
                function () {
                    $('.wrap').attr({ style: '' });
                    $('html, body').prop({ scrollTop: current_scrollY });
                    /*$("#dialog").dialog("close");*/
                    document.activeElement.blur(); /* フォーカス解除 IE11 */
                });

        });
        $(document.body).on("click",
            ".ui-widget-overlay",
            function () {
                $.each($(".ui-dialog"),
                    function () {
                        var $dialog = $(this).children(".ui-dialog-content");
                        if ($dialog.dialog("option", "modal")) {
                            $('.wrap').attr({ style: '' });
                            $('html, body').prop({ scrollTop: current_scrollY });
                            $dialog.dialog("close");
                        }
                    });
            });
        function ShowDetails(action) {
            current_scrollY = $(window).scrollTop();
            $('.wrap').css({
                position: 'fixed',
                width: '100%',
                top: -1 * current_scrollY
            });
            $("#dialog").dialog("open");
            searchDialogData(action);
            }

        function searchDialogData(action) {
            var urlAction = '../TransferReference/'+action;
            $.ajax({
                method: 'POST',
                url: urlAction,
                dataType: "html",
                async: false,
                data: {
                    shipKind: $("#hidShipKind").val(),
                    centerId: $("#ddlCenterId").val(),
                    shipPlanDate: $("#hidShipPlanDate").val(),
                    batchNo: $("#hidBatchNo").val(),
                    batchName: $("#hidBatchName").val(),
                    allocDateFrom: $("#hidAllocDateFrom").val(),
                    allocDateTo: $("#hidAllocDateTo").val()
                },
                success: function (data) {
                    $("#dialog").html("");
                    $("#dialog").html(data);
                    $("#dialog").dialog(
                        {
                            width: 1200,
                            height:800
                        });
                },
                error: function (XMLHttpRequest, textStatus, errorThrown) {

                }
            });
        }
        function closeDialog() {
            $('.wrap').attr({ style: '' });
            $('html, body').prop({ scrollTop: current_scrollY });
            $('#dialog').dialog('close');
        }

        //店別仕分状況モーダル用
        function ShowDetailsStore() {
            current_scrollY = $(window).scrollTop();
            $('.wrap').css({
                position: 'fixed',
                width: '100%',
                top: -1 * current_scrollY
            });
            $("#dialogStore").dialog("open");
            searchDialogDataStore();
        }

        function searchDialogDataStore() {
            var urlAction = '../TransferReference/PickSortDetailStore';
            $.ajax({
                method: 'POST',
                url: urlAction,
                dataType: "html",
                async: false,
                data: {
                    centerId: $("#ddlCenterId").val(),
                    batchNo: $("#hidBatchNoStore").val(),
                    itemSkuId: $("#hidItemSkuId").val()
                },
                success: function (data) {
                    $("#dialogStore").html("");
                    $("#dialogStore").html(data);
                    $("#dialogStore").dialog(
                        {
                            width: 1200,
                            height: 800
                        });
                },
                error: function (XMLHttpRequest, textStatus, errorThrown) {

                }
            });
        }
        function closeDialogStore() {
            $('.wrap').attr({ style: '' });
            $('html, body').prop({ scrollTop: current_scrollY });
            $('#dialogStore').dialog('close');
        }

    </script>
}