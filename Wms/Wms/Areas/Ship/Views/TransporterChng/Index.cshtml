@** スクリプト *@
@section LayoutScripts{
    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")
    <script>
    /**
     * Country class
     */
        var curentSelectedCnt = 0;
        var curentSelectedCntDiff = 0;
    var TransporterChngView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            BtnUpdate: '#BtnUpdate',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnTransporterArea: '#btnTransporterArea',
            txtTransporterArea: '#txtTransporterArea',
            txtTransporterAreaName: '#txtTransporterAreaName',
            deliareaGroupSelect: '#deliareaGroupSelect',
            btnTransporter: '#btnTransporter',
            txtTransporterId: '#txtTransporterId',
            txtTransporterName: '#txtTransporterName',
            transporterSelect: '#transporterSelect',
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(TransporterChngView.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(TransporterChngView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(TransporterChngView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(TransporterChngView.SELECTORS.chkCheckedInTable).length;
                    TransporterChngView.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * ブランド検索ダイアログの設定
                */
                $(TransporterChngView.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                * 配送業者検索ダイアログの設定
                */
                $(TransporterChngView.SELECTORS.btnTransporter).on("click", transporterSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(TransporterChngView.SELECTORS.deliareaGroupSelect).on("click", function () {

                    var ids = [];
                    var names = [];

                    $('#deliareaGroupSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var area = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var areaName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        ids.push(area);
                        names.push(areaName);
                    });
                    ids = ids.toString().split(',');
                    names = names.join('、').split('、');

                    ids = Array.from(new Set(ids));
                    names = Array.from(new Set(names));
                    //$.unique(ids.sort());
                    //$.unique(names.sort());

                    $(TransporterChngView.SELECTORS.txtTransporterArea).val(ids.toString());
                    $(TransporterChngView.SELECTORS.txtTransporterAreaName).val(names.join('、'));

                });
                /**
                 *Click button get data Brand
                 */
                $(TransporterChngView.SELECTORS.transporterSelect).on("click", function () {
                    $(TransporterChngView.SELECTORS.txtTransporterId).val("");
                    $(TransporterChngView.SELECTORS.txtTransporterName).val("");
                    $('#transporterSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var transporterId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var transporterName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        if ($(TransporterChngView.SELECTORS.txtTransporterId).val() == "") {
                            $(TransporterChngView.SELECTORS.txtTransporterId).val(transporterId);
                            $(TransporterChngView.SELECTORS.txtTransporterName).val(transporterName);
                        } else {
                            $(TransporterChngView.SELECTORS.txtTransporterId).val($(TransporterChngView.SELECTORS.txtTransporterId).val() + ',' + transporterId);
                            $(TransporterChngView.SELECTORS.txtTransporterName).val($(TransporterChngView.SELECTORS.txtTransporterName).val() + '、' + transporterName);
                        }

                    })
                });

                /**
