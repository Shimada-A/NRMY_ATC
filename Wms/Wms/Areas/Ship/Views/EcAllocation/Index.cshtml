                        <span class="chk_parts">
                        </span>
                    </label>
                    @EcAllocationResource.Order
                    (
                    <label class="chklist">
                        @Html.CheckBoxFor(model => model.SearchConditions.OrderBatchNo, new { tabindex = "14", @placeholder = "", @class = "check-box" })
                        <span class="chk_parts">
                        </span>
                    </label>
                    @EcAllocationResource.OrderBatchNo
