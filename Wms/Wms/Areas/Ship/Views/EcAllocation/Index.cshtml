@section LayoutScripts{
    <script>
        $("#btnItemPrint").on("click", function () {

            var urlAction = '@Url.Action("ItemPrintCheck", "EcAllocation", new { area = "Ship" })';

            $.ajax({
                method: 'POST',
                url: urlAction,
                dataType: "html",
                async: false,
                success: function (data) {
                    if (data != null) {
                        if (data ==0) {
                            var urlAction = '@Url.Action("ItemPrint", "EcAllocation", new { area = "Ship" })';
                            window.open("about:blank", "newtab");
                                var $form = $("#frmSearch");
                                $form.attr("action", urlAction);
                                $form.attr("method", "POST");
