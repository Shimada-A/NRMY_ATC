                    @EcAllocationResource.Gas
                    (
                    <label class="chklist">
                        @Html.CheckBoxFor(model => model.SearchConditions.BatchNoInUnit, new { tabindex = "16", @placeholder = "", @class = "check-box" })
                        <span class="chk_parts">
                        </span>
                    </label>
                    @EcAllocationResource.BatchNoInUnit
                    )
                </td>
            </tr>
            <tr class="addcondition">
                <td class="tdtitle"></td>
                <td colspan="4">
                    <label class="chklist">
                        @Html.CheckBoxFor(model => model.SearchConditions.All, new { tabindex = "17", @placeholder = "", @class = "check-box", @onclick = "CheckboxChange()" })
                        <span class="chk_parts">
                        </span>
                    </label>
                    @EcAllocationResource.All
                    (
                    <label class="chklist">
                        @Html.CheckBoxFor(model => model.SearchConditions.AllOrderBatchNo, new { tabindex = "18", @placeholder = "", @class = "check-box" })
                        <span class="chk_parts">
                        </span>
                    </label>
                    @EcAllocationResource.AllOrderBatchNo
                    )
                </td>
            </tr>
            <tr class="addcondition">
                <td class="tdtitle">@EcAllocationResource.TransporterId</td>
                <td colspan="4">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.TransporterId,
                                (IEnumerable<SelectListItem>)ViewBag.TransporterList,
                                CommonResource.None, new { id = "ddlTransporterId", tabindex = "19" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr class="addcondition">
                <td class="tdtitle">@EcAllocationResource.TransporterDateClass</td>
                <td colspan="4">
                    @Html.EnumRadioButtonListFor(model => model.SearchConditions.TransporterDateClass, new { onchange = "TransporterDateClassChange()" })
                    <span class="date_input">
                        @Html.EditorFor(model => model.SearchConditions.TransporterDate, new { htmlAttributes = new { tabindex = "23", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input", @style = "height:30px;", id = "ddlTransporterDate" } })
