                    @Html.EditorFor(model => model.SearchConditions.TransporterAreaName, new { htmlAttributes = new { @class = "w_50_normal overflow", @id = "txtTransporterAreaName", tabindex = "25", @readonly = "readonly" } })
                    @Html.HiddenFor(model => model.SearchConditions.TransporterArea, new { id = "txtTransporterArea" })
                </td>
            </tr>
            <tr class="addcondition">
                <td colspan="5">
                    <button type="button" id="btnHideCondition" class="btnhidecondition">
                        <img src="~/Content/img/hidecondition.png" />
                        <span>
                            @EcAllocationResource.BtnHideCondition
                        </span>
                    </button>
                </td>
            </tr>
            <tr>
                <td colspan="5">
                    <div class="sortarea" style="width:60rem">
                        <ul>
                            <li>
                                <button type="button" id="btnItemPrint" class="download" style="width:11vw" tabindex="30">
                                    <img src="~/Content/img/print.png" />
                                    @EcAllocationResource.BtnAllocErrItemPrint
                                </button>
                            </li>
                            <li>
                                <button type="button" id="btnOrderPrint" class="download" style="width:11vw" tabindex="31">
                                    <img src="~/Content/img/print.png" />
                                    @EcAllocationResource.BtnAllocErrOrderPrint
                                </button>
                            </li>
                            <li>
                                <button type="button" id="btnItemDownload" class="download" style="width:9vw" tabindex="32">
                                    <img src="~/Content/img/download.png" />
                                    @EcAllocationResource.BtnAllocErrItemDownload
                                </button>
                            </li>
                            <li>
                                <button type="button" id="btnOrderDownload" class="download" style="width:9vw" tabindex="33">
                                    <img src="~/Content/img/download.png" />
                                    @EcAllocationResource.BtnAllocErrOrderDownload
                                </button>
                            </li>
                        </ul>
                    </div>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "EcAllocation", new { area = "Ship" }, new { type = "button", @class = "btn btn-outline-dark", tabindex = "34" })
                    <button class="btn btn-outline-dark" id="btnSearch" type="button" tabindex="35" onclick="Search();">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        <input type="hidden" name="SearchConditions.Page" id="hidPage" value="@Model.SearchConditions.Page" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.SearchType, new { id = "hidSearchType" })
        @Html.HiddenFor(model => model.SearchConditions.AllocationName, new { id = "hidAllocationName" })
        <input type="hidden" name="SearchConditions.ItemSkuSum" id="hidItemSkuSum" value="@Model.SearchConditions.ItemSkuSum" />
        <input type="hidden" name="SearchConditions.Seq" id="hidSeq" value='@Model.SearchConditions.Seq' />
        @Html.HiddenFor(model => model.SearchConditions.AllocationName, new { id = "hidAllocationName" })
        @Html.HiddenFor(model => model.SearchConditions.Print, new { id = "hidPrint" })
        <div style="display:none">
            <table>
                @if (Model.Results.EcAllocations != null)
                {
                    for (int i = 0; i < Model.Results.EcAllocations.Count; i++)
                    {
                        var id = String.Format("SearchConditions.EcAllocations[{0}].", i);
                        <tr>
                            <td class="template" hidden>
                                @Html.CheckBoxFor(modelItem => Model.Results.EcAllocations[i].IsCheck, new { @id = (id + "CheckedValue"), @class = "check-box", Name = id + "IsCheck" })
                                @Html.HiddenFor(modelItem => Model.Results.EcAllocations[i].Seq, new { @id = (id + "Seq"), Name = id + "Seq" })
                                @Html.HiddenFor(modelItem => Model.Results.EcAllocations[i].LineNo, new { @id = (id + "LineNo"), Name = id + "LineNo" })
                            </td>
                        </tr>
                    }
                }
            </table>
        </div>
