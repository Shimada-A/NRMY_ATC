            </tr>
            <tr class="addcondition">
                <td class="tdtitle"></td>
                <td colspan="4">
                    <label class="chklist">
                        @Html.CheckBoxFor(model => model.SearchConditions.Gas, new { tabindex = "15", @placeholder = "", @class = "check-box", @onclick = "CheckboxChange()" })
                        <span class="chk_parts">
