</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.Results.EcAllocations != null)
{
    if (Model.Results.EcAllocations.Count() > 0)
    {
        @* Sublbarea *@
        <div class="sublbarea no_border">
            <div class="sortarea">
                <ul>
                    <li>
                        @FormsResource.DISPLAY_SHORT
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                            </div>
                        </div>
                    </li>
                    <li>
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                            </div>
                        </div>
                    </li>
                    <li class="totalcount">
                        @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.EcAllocations.TotalItemCount.ToString("N0"))
                    </li>
                </ul>
                @if (Model.Results.EcAllocations.Count() > 0)
                {
                    @Html.PagedListPager(Model.Results.EcAllocations, Page => Url.Action("Search", "EcAllocation", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
                }
            </div>
        </div>
        <div class="sublbarea no_border stock_detail_head" style="height:50px">
            <table>
                <tr>
                    <td>@EcAllocationResource.AllocName</td>
                    <td>
                        @Html.RequiredMark()
                        @Html.EditorFor(model => model.SearchConditions.AllocationName, new { htmlAttributes = new { @onblur = "AllocationNameBlur()", @class = "w_40_normal", @id = "txtAllocationName", tabindex = "3", @placeholder = @DcAllocationResource.AllocationNamePH } })
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocationName, "", new { id = "msgAllocationName" })
                    </td>
                </tr>
            </table>
            <div class="sortarea">
                <ul>
                    <li>
                        @EcAllocationResource.OrderSum @Html.DisplayFor(model => model.SearchConditions.OrderSum)
                    </li>
                    <li>
                        @EcAllocationResource.ItemSkuSum @Html.DisplayFor(model => model.SearchConditions.ItemSkuSum)
                    </li>
                    <li>
                        @EcAllocationResource.InstructQtySum @Html.DisplayFor(model => model.SearchConditions.InstructQtySum)
                    </li>
                </ul>
            </div>
        </div>
    }

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.EcAllocations.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:69vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">&nbsp;</th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.ShipRequestDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.ShipInstructId
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.OrderDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.TransporterName
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.TransporterDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.AllocUpDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.EcShipClass
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.InstructQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @EcAllocationResource.AllocState
                                </th>
                                <th class="bg-grey align-middle">
                                </th>
                                <th hidden>
                                </th>
                            </tr>

                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "EcAllocation", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.EcAllocations.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("EcAllocations[{0}].", cModel.i);
                                    <tr>
                                        <td class="w_checkbox align-middle">
                                            <label class="checkboxgroup">
                                                @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")" })
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.Results.EcAllocations.PageNumber - 1) * Model.Results.EcAllocations.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipRequestDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipInstructId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.OrderDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransporterName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ArriveRequestDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.DataDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.EcShipClass)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.OrderQty)
                                        </td>
                                        <td class="align-middle">
                                            @if (cModel.v.AllocFlag == 0)
                                            {
                                                <span>@EcAllocationResource.NoAlloc</span>
                                            }
                                            else if (cModel.v.OrderQty > cModel.v.AllocQty && cModel.v.AllocQty > 0)
                                            {
                                                <span>@EcAllocationResource.AllocErrHas</span>
                                            }
                                            else if (cModel.v.AllocQty == 0)
                                            {
                                                <span>@EcAllocationResource.AllocAllErr</span>
                                            }
                                        </td>
                                        <td class="align-middle" style="width:100px;">
                                            <button type="button" id=@("Detail"+ cModel.i) class="btn btn-dark" onclick="ShowDetails('@(cModel.v.Seq)','@(cModel.v.LineNo)')">@EcAllocationResource.BtnDetail</button>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.AllocFlag, new { Name = key + "AllocFlag", id = key + "AllocFlag" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div id="dialog" class="i02_01">
            </div>
        }

    </div> }
