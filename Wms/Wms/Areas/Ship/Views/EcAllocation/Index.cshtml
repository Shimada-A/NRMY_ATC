                        var $dialog = $(this).children(".ui-dialog-content");
                        if ($dialog.dialog("option", "modal")) {
                            $('.wrap').attr({ style: '' });
                            $('html, body').prop({ scrollTop: current_scrollY });
                            $dialog.dialog("close");
                        }
                    });
            });
        function ShowDetails(seq,lineNo) {
            current_scrollY = $(window).scrollTop();
            $('.wrap').css({
                position: 'fixed',
                width: '100%',
                top: -1 * current_scrollY
            });
            $("#dialog").dialog("open");
            searchDialogData(seq,lineNo);
            }

        function searchDialogData(seq,lineNo) {
            var urlAction = '@Url.Action("Detail", "EcAllocation", new { area = "Ship" })';
            $.ajax({
                method: 'POST',
                url: urlAction,
                dataType: "html",
                async: false,
                data: {
                    Seq: seq,
                    LineNo: lineNo
                },
                success: function (data) {
                    $("#dialog").html("");
                    $("#dialog").html(data);
                    $("#dialog").dialog(
                        {
                            width: 1200,
                            height:800
                        });
                },
                error: function (XMLHttpRequest, textStatus, errorThrown) {

                }
            });
        }
        function closeDialog() {
            $('.wrap').attr({ style: '' });
            $('html, body').prop({ scrollTop: current_scrollY });
            $('#dialog').dialog('close');
        }
    </script>
}


