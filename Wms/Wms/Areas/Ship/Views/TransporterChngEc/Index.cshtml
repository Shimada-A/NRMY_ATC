                return;
            } else if ($("#txtSize").val() !="" ) {
                var urlAction = '@Url.Action("CheckSize", "TransporterChngEc", new { area = "Ship"})';
                $.ajax({
                    url: urlAction,
                    type: "POST",
                    data: {
                        size: $("#txtSize").val()
                    },
                    success: function (data) {
                        if (data.cnt == 0) {
                            $("#SizeMsg").html('<span id="Size_error" class="">'+'@string.Format(Share.Common.Resources.MessagesResource.MasterNotExistsError, TransporterChngEcResource.Size)' +'</span>');
                            $("#SizeMsg").addClass("field-validation-error");
                            $("#txtSize").addClass("input-validation-error");
                            return;
                        } else {
                            $("#SizeMsg").html("");
                            $("#SizeMsg").removeClass("field-validation-error");
                            $("#txtSize").removeClass("input-validation-error");
                            TransporterChange2();
                        }
                    }
                });
            }else {
                $("#SizeMsg").html("");
                $("#SizeMsg").removeClass("field-validation-error");
                $("#txtSize").removeClass("input-validation-error");
                TransporterChange2();
            }
        }
