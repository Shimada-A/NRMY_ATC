}
@Html.Partial("~/Areas/Master/Views/Shared/_DeliareaGroupSearchModal.cshtml", areaConditions)
@Html.Partial("_CreateConfirmMessageDialog", TransporterChngEcResource.UpdateMsg)
@Html.Partial("_ErrorMessageDialog", new Wms.Models.MessageDialog() { Id = "ErrMsg", Message = (string)ViewBag.ErrorMessage })
@** スクリプト *@
@section LayoutScripts{
    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")
    <script>
    /**
     * Country class
     */
        var curentSelectedCnt = 0;
        var curentSelectedCntDiff = 0;
        var TransporterChngEcView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            BtnUpdate: '#BtnUpdate',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnTransporterArea: '#btnTransporterArea',
            txtTransporterArea: '#txtTransporterArea',
            txtTransporterAreaName: '#txtTransporterAreaName',
            deliareaGroupSelect: '#deliareaGroupSelect'
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(TransporterChngEcView.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(TransporterChngEcView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(TransporterChngEcView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(TransporterChngEcView.SELECTORS.chkCheckedInTable).length;
                    TransporterChngEcView.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * ブランド検索ダイアログの設定
                */
                $(TransporterChngEcView.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(TransporterChngEcView.SELECTORS.deliareaGroupSelect).on("click", function () {

                    var ids = [];
                    var names = [];

                    $('#deliareaGroupSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var area = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var areaName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        ids.push(area);
                        names.push(areaName);
                    });
                    ids = ids.toString().split(',');
                    names = names.join('、').split('、');

                    ids = Array.from(new Set(ids));
                    names = Array.from(new Set(names));
                    //$.unique(ids.sort());
                    //$.unique(names.sort());

                    $(TransporterChngEcView.SELECTORS.txtTransporterArea).val(ids.toString());
                    $(TransporterChngEcView.SELECTORS.txtTransporterAreaName).val(names.join('、'));

                });
      

                /**
                 * Button check all clicked
                 */
                $(TransporterChngEcView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("AllSelectedSearch", "TransporterChngEc", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });

                /**
                 * Button UnCheck all clicked
                 */
                $(TransporterChngEcView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("UnSelectedSearch", "TransporterChngEc", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
                // Display row is selected
                $(TransporterChngEcView.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
                // Enable/Disable button Edit
                if ($(TransporterChngEcView.SELECTORS.rowSelected).text() >= 1) {
                    if (getUsable_Class() != 1) {
                        $(TransporterChngEcView.SELECTORS.BtnUpdate).removeAttr('disabled');
                    }
                } else {
                    $(TransporterChngEcView.SELECTORS.BtnUpdate).attr('disabled', 'disabled');
                }
            },
        }
    /**
    * Page loaded
    */
    $(document).ready(function () {
        TransporterChngEcView.init();
        if ('@ViewBag.Status' != '@ProcedureStatus.Success' && '@ViewBag.Status' != '') {
            $("#btnErrorMessage").click();
        }
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var urlAction ='@Url.Action("Search", "TransporterChngEc", new { area= "Ship" })';
                var pageUrl = urlAction + '?Page=';
                var page = $(item).attr("href").replace(pageUrl, "");
                page = page.replace("&class=btn-outline-dark", "");
                $(item).attr("href", "javascript:void(0);").click(function () {
                    $("#hidPage").val(page);
                    $("#hidSearchType").val("SortPage");
                    $("#frmSearch").attr("action", urlAction);
                    $("#frmSearch").attr("method", "POST");
                    $("#frmSearch").submit();
                });
            });
        if ('@Model.SearchConditions.AllocStatus' == 'Printed') {
            $(".print").show();
            $("#txtAllocDateFrom").attr('disabled', 'disabled');
            $("#txtAllocDateFrom").val("");
            $("#txtAllocTimeFrom").attr('disabled', 'disabled');
            $("#txtAllocTimeFrom").val("");
            $("#txtAllocDateTo").attr('disabled', 'disabled');
            $("#txtAllocDateTo").val("");
            $("#txtAllocTimeTo").attr('disabled', 'disabled');
            $("#txtAllocTimeTo").val("");
