<script>
        $("#btnDownload").on("click", function () {
                var urlAction = '@Url.Action("Download", "BtoBReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
        });

        $("#btnDownloadCase").on("click", function () {
                var urlAction = '@Url.Action("DownloadCase", "BtoBReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
        });

    /**
     * Country class
     */
        var curentSelectedCnt = 0;
        var curentSelectedCntDiff = 0;
    var BtoBReference01View = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            btnShipConfirm: '#btnShipConfirm',
            ddlSortKey: '#ddlSortKey',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnBrandId: '#btnBrandId',
            brandId:'#txtBrandId',
            brandName:'#txtBrandName',
            brandSelect: '#brandSelect',
            btnMainVendor:'#btnMainVendor',
            mainVendorId:'#txtMainVendorId',
            mainVendorName:'#txtMainVendorName',
            vendorSelect: '#vendorSelect',
            btnTransporterArea: '#btnTransporterArea',
            txtTransporterArea: '#txtTransporterArea',
            txtTransporterAreaName: '#txtTransporterAreaName',
            deliareaGroupSelect: '#deliareaGroupSelect',
            btnTransporter: '#btnTransporter',
            txtTransporterId: '#txtTransporterId',
            txtTransporterName: '#txtTransporterName',
            transporterSelect: '#transporterSelect',
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(BtoBReference01View.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(BtoBReference01View.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(BtoBReference01View.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(BtoBReference01View.SELECTORS.chkCheckedInTable).length;
                    BtoBReference01View.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * Dropdownlist change item
                */
                $(BtoBReference01View.SELECTORS.ddlSort).change(function (val) {
                    $(BtoBReference01View.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(BtoBReference01View.SELECTORS.ddlSortKey).change(function (val) {
                    $(BtoBReference01View.SELECTORS.btnSearch).click();
                });

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBReference01View.SELECTORS.btnBrandId).on("click", brandSearchModal.open);

                /**
                * 仕入先検索ダイアログの設定
                */
                $(BtoBReference01View.SELECTORS.btnMainVendor).on("click", vendorSearchModal.open);

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBReference01View.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                * 配送業者検索ダイアログの設定
                */
                $(BtoBReference01View.SELECTORS.btnTransporter).on("click", transporterSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(BtoBReference01View.SELECTORS.brandSelect).on("click", function () {
                    $('#brandSearchResult input[type=radio]:checked').each(function (index, item) {
                        var brandId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var brandName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(BtoBReference01View.SELECTORS.brandId).val(brandId);
                        $(BtoBReference01View.SELECTORS.brandName).val(brandName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(BtoBReference01View.SELECTORS.vendorSelect).on("click", function () {
                    $('#vendorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var vendorId = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var vendorName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        $(BtoBReference01View.SELECTORS.mainVendorId).val(vendorId);
                        $(BtoBReference01View.SELECTORS.mainVendorName).val(vendorName);
                    })
                });
                /**
                 *Click button get data Brand
                 */
                $(BtoBReference01View.SELECTORS.transporterSelect).on("click", function () {
                    $(BtoBReference01View.SELECTORS.txtTransporterId).val("");
                    $(BtoBReference01View.SELECTORS.txtTransporterName).val("");
                    $('#transporterSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var transporterId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var transporterName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        if ($(BtoBReference01View.SELECTORS.txtTransporterId).val() == "") {
                            $(BtoBReference01View.SELECTORS.txtTransporterId).val(transporterId);
                            $(BtoBReference01View.SELECTORS.txtTransporterName).val(transporterName);
                        } else {
                            $(BtoBReference01View.SELECTORS.txtTransporterId).val($(BtoBReference01View.SELECTORS.txtTransporterId).val() + ',' + transporterId);
                            $(BtoBReference01View.SELECTORS.txtTransporterName).val($(BtoBReference01View.SELECTORS.txtTransporterName).val() + '、' + transporterName);
                        }

                    })
                });

                /**
                 * Button check all clicked
                 */
                $(BtoBReference01View.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("AllSelectedSearch", "BtoBReference", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });

                /**
                 * Button UnCheck all clicked
                 */
                $(BtoBReference01View.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("UnSelectedSearch", "BtoBReference", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
                // Display row is selected
                $(BtoBReference01View.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
                // Enable/Disable button Edit
                if ($(BtoBReference01View.SELECTORS.rowSelected).text() >= 1) {
                    if (getUsable_Class() != 1) {
                        $(BtoBReference01View.SELECTORS.btnShipConfirm).removeAttr('disabled');
                    }
                } else {
                    $(BtoBReference01View.SELECTORS.btnShipConfirm).attr('disabled', 'disabled');
                }
            },
        }
    /**
    * Page loaded
    */
    $(document).ready(function () {
        BtoBReference01View.init();
        if ($("#ddlCategoryId1").val() != '') {
            $("#ddlCategoryId2").removeAttr('disabled');
        }
        if ($("#ddlCategoryId2").val() != '') {
                $("#ddlCategoryId3").removeAttr('disabled');
        }
        if ($("#ddlCategoryId3").val() != '') {
                $("#ddlCategoryId4").removeAttr('disabled');
        }
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var urlAction ='@Url.Action("Search", "BtoBReference", new { area= "Ship" })';
                var pageUrl = urlAction + '?Page=';
                var page = $(item).attr("href").replace(pageUrl, "");
                page = page.replace("&class=btn-outline-dark", "");
                $(item).attr("href", "javascript:void(0);").click(function () {
                    $("#hidPage").val(page);
                    $("#hidSearchType").val("SortPage");
                    $("#frmSearch").attr("action", urlAction);
                    $("#frmSearch").submit();
                });
            });

            if ($("#txtShipBoxStatus").val() == "") {
                $("#txtShipBoxStatusOld").removeAttr('disabled');
            } else {
                $("#txtShipBoxStatusOld").attr('disabled', 'disabled');
                $("#txtShipBoxStatusOld").prop("checked",false);
            }
    });
        function ShipBoxStatusChange() {
            if ($("#txtShipBoxStatus").val() == "") {
                $("#txtShipBoxStatusOld").removeAttr('disabled');
            } else {
                $("#txtShipBoxStatusOld").attr('disabled', 'disabled');
                $("#txtShipBoxStatusOld").prop("checked",false);
            }
        }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());
            $("#hidSearchType").val("SortPage");

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "BtoBReference", new { area= "Ship" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function GetCategoryList(id) {
                    var urlAction = '@Url.Action("GetCategoryList","ItemSku",new { area = "Master"})';
                    $.ajax({
                        url: urlAction,
                        type: "POST",
                        data: {
                            id: id + 1,
                            category1: $("#ddlCategoryId1").val(),
                            category2: $("#ddlCategoryId2").val(),
                            category3: $("#ddlCategoryId3").val()
                        },
                        success: function (data) {
                            $("#ddlCategoryId" + (id + 1)).html("");
                            $("#ddlCategoryId" + (id + 1)).html(data.html);
                        }
                    });
        }
        function CategoryChange(id) {
            if ($("#ddlCategoryId" + id).val() != '') {
                GetCategoryList(id);
                $("#ddlCategoryId" + (id + 1)).removeAttr('disabled');
                if (id == 1) {
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            } else {
                if (id == 1) {
                    $("#ddlCategoryId2").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId2").val('');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 3){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            }
        }
        function SetCheckValue(lineNo) {
            $('input[type=checkbox][id$="SearchConditions.BtoBReference01s[' + lineNo + '].CheckedValue"]').each(function (i, item) {
                $(item).trigger('click');
                });
        }
        function TimeBlur() {
            var idFromtime = '#SearchConditions_MakeTimeFrom';
            var idTotime = '#SearchConditions_MakeTimeTo';
            var msgFromtime = '#MakeTimeFromMessage';
            var msgTotime = '#MakeTimeToMessage';

            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                if (!IsTime($(idFromtime).val().replace(":",""))) {
                    $(msgFromtime).html('<span id="MakeTimeFromError" class="">'+'@BtoBReferenceResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="MakeTimeToError" class="">'+'@BtoBReferenceResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
        }
        function ConditionsCheck(mod) {
            var msgAllocationName = '#msgAllocationName';
            var idAllocationName = '#txtAllocationName';
            var iddateFrom = '#SearchConditions_MakeDateFrom';
            var iddateTo = '#SearchConditions_MakeDateTo';
            var idFromtime = '#SearchConditions_MakeTimeFrom';
            var idTotime = '#SearchConditions_MakeTimeTo';
            var msgdateFrom = '#MakeDateFromMessage';
            var msgdateTo = '#MakeDateToMessage';
            var msgFromtime = '#MakeTimeFromMessage';
            var msgTotime = '#MakeTimeToMessage';

            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                if (!IsTime($(idFromtime).val().replace(":",""))) {
                    $(msgFromtime).html('<span id="MakeTimeFromError" class="">'+'@BtoBReferenceResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="MakeTimeToError" class="">'+'@BtoBReferenceResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(iddateFrom).val()=="" && $(idFromtime).val()!="") {
                $(msgdateFrom).html('<span id="SearchConditions_MakeDateFrom_error" class="">'+'@BtoBReferenceResource.ErrNoDate' +'</span>');
                $(msgdateFrom).addClass("field-validation-error");
                $(iddateFrom).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateFrom).html("")
                $(msgdateFrom).removeClass("field-validation-error")
                $(iddateFrom).removeClass("input-validation-error")
            }
            if ($(iddateTo).val()=="" && $(idTotime).val()!="") {
                $(msgdateTo).html('<span id="SearchConditions_MakeDateTo_error" class="">'+'@BtoBReferenceResource.ErrNoDate' +'</span>');
                $(msgdateTo).addClass("field-validation-error");
                $(iddateTo).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateTo).html("")
                $(msgdateTo).removeClass("field-validation-error")
                $(iddateTo).removeClass("input-validation-error")
            }
                var date1 = $(iddateFrom).val().replace(/\//g, "");
                var date2 = $(iddateTo).val().replace(/\//g, "");
                var time1 = $(idFromtime).val().replace(/\:/g, "");
                var time2 = $(idTotime).val().replace(/\:/g, "");
                var msg = "@String.Format(MessagesResource.ERR_DATE_MINMAX, BtoBReferenceResource.MakeDateTimeFrom, BtoBReferenceResource.MakeDateTimeTo)";
            if (!(validateDate.checkDate(date1, time1, date2, time2, "SearchConditions_MakeDateFrom", "SearchConditions.MakeDateFrom", msg))) return false;
            return true;
        }
        function Search() {
            if (ConditionsCheck('search')) {
                $("#hidSearchType").val("Search");
                var urlAction = '@Url.Action("Search", "BtoBReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();}
            }
        function IsDate(value) {
            value = value.replace(/\//g, "-");
            return value.match(/^(?:(?!0000)[0-9]{4}-(?:(?:0[1-9]|1[0-2])-(?:0[1-9]|1[0-9]|2[0-8])|(?:0[13-9]|1[0-2])-(?:29|30)|(?:0[13578]|1[02])-31)|(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:0[48]|[2468][048]|[13579][26])00)-02-29)$/);
        }
        function IsTime(value) {
            value = value.replace(":", "");
            return value.match(/^([01][0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$/);
        }
        $('#btnShipConfirm').on("click", function () {
            if (!validateForm($('#frmSearch')) || !ConditionsCheck('upd')) {
                return;
            }
            $('#btnShipConfirmHidden').click();
        });
        $('#ShipConfirm').on("click", function () {
            var urlAction = '@Url.Action("ShipConfirm", "BtoBReference", new { area = "Ship" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        function Detail(seq,lineNo) {
                $("#hidSeq").val(seq);
                $("#hidLineNo").val(lineNo);
                var urlAction = '@Url.Action("Detail", "BtoBReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            }
</script>
}