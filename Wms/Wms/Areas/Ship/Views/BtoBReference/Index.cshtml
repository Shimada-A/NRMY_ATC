}
@if (Model.Results.BtoBReference01s != null)
{

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.BtoBReference01s.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:70vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.BoxNo
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.ShipToStore
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.Transporter
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.ResultQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.BatchNo
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.ShipPlanDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.ShipStatus
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBReferenceResource.KakuDate
                                </th>
                                <th class="bg-grey align-middle">
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "Ship", FormMethod.Post, new { id = "frmList" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.BtoBReference01s.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("BtoBReference01s[{0}].", cModel.i);
                                    <tr>
                                        @*<td class="w_checkbox align-middle">
                                            <label class="checkboxgroup">
                                                @if ((cModel.v.ShipStatusName != BtoBReferenceResource.Print && cModel.v.ShipStatusName != BtoBReferenceResource.InvoicePrint) || cModel.v.StoreInvFlag == "1")
                                                {
                                                    @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")", disabled = true })
                                                }
                                                else
                                                {
                                                    @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")" })
                                                }
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>*@
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.Results.BtoBReference01s.PageNumber - 1) * Model.Results.BtoBReference01s.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.BoxNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipToStoreId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ShipToStoreName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransporterName)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.BatchNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipPlanDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipStatusName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.KakuDate)
                                        </td>
                                        <td class="align-middle"  style="width:100px;">
                                            <button type="button" class="btn btn-dark btn-sm" onclick="Detail(@cModel.v.Seq,@cModel.v.LineNo)">@BtoBReferenceResource.BtnPackageDetail</button>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                            @Html.HiddenFor(modelItem => cModel.v.LineNo, new { Name = key + "LineNo" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

