                        $("#txtBatchNo").removeAttr('disabled');
                        $("#txtJan").removeAttr('disabled');
                        $("#txtShipInstructId").attr('disabled', 'disabled');
                        $("#txtDeliNo").attr('disabled', 'disabled');
                        $("#btnRelease").hide();
                        $("#chkChkOldData").prop("checked", false);
                        $('#chkChkOldData').attr('disabled', 'disabled');

                    } else {
                        $("#txtBatchName").val("");
                        $("#txtBatchNo").val("");
                        $("#txtJan").val("");
