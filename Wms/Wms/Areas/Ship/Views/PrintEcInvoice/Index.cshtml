                //シングル選択
                $(PrintCaseLabelView.SELECTORS.chkInTableEcShip1).click(function (evt) {
                    $('#lblErrMassage1').val("");
                    $('#lblErrMassage2').val("");
                    $('#lblErrMassage3').val("");
                    $('#lblErrMassage4').val("");
                    $("#txtUnitCnt").val("");
                    $("#txtBoxNo").val("");
                    $("#txtUnitCnt").attr('disabled', 'disabled');
                    $("#txtBoxNo").attr('disabled', 'disabled');

                    //新規
