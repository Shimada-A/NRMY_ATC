            <td></td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.BoxNoS</td>
            <td colspan="11">
                @Html.EditorFor(model => model.BoxNo, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtBoxNo", tabindex = "8", onfocus = "this.select();" } })
                @Html.EditorFor(model => model.ErrMassage2, new { htmlAttributes = new { @style = "border:0; color:red;width:500px;outline:none;", @readonly = "readonly", @id = "lblErrMassage2" } })
            </td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.ShipInstructIdS</td>
            <td colspan="11">
                @Html.EditorFor(model => model.ShipInstructId, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtShipInstructId", tabindex = "9" } })
                @Html.EditorFor(model => model.ErrMassage3, new { htmlAttributes = new { @style = "border:0; color:red;width:500px;outline:none;", @readonly = "readonly", @id = "lblErrMassage3" } })
            </td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.DeliNoS</td>
            <td colspan="11">
                @Html.EditorFor(model => model.DeliNo, new { htmlAttributes = new { @class = "w_22_verylong", @id = "txtDeliNo", tabindex = "10" } })
                @Html.EditorFor(model => model.ErrMassage4, new { htmlAttributes = new { @style = "border:0; color:blue;width:500px;outline:none;margin-left:50px;", @readonly = "readonly", @id = "lblErrMassage4" } })
            </td>
        </tr>
        <tr>
            <td></td>
            <td colspan="11" style="text-align:center;margin-top:30px;">
                <button type="button" id="btnRelease" class="btn btn-dark btnsize _pm">@PrintEcInvoiceResource.RELEASES</button>
                @Html.EditorFor(model => model.ErrMassagePop, new { htmlAttributes = new { @style = "border:0; color:red;width:500px;outline:none;display: none;", @readonly = "readonly", @id = "lblErrMassagePop" } })
                @Html.HiddenFor(model => model.ErrShipInstructId, new { @id = "hidErrShipInstructId" })
            </td>
        </tr>
        <tr>
            <td colspan="12">
                <button class="btn btn-outline-dark" id="btnSet" type="button" tabindex="-1" onclick="KickChangePrintInfo();">@PrintInvoiceResource.SettingOkaiage</button>
                <button class="btn btn-outline-dark" id="btnSetRakuten" type="button" tabindex="-1" onclick="KickChangePrintInfoRakuten();">@PrintInvoiceResource.SettingRakuten</button>
                <button class="btn btn-outline-dark" id="btnSetWaKsnap" type="button" tabindex="-1" onclick="KickChangePrintInfoWaKsnap();">@PrintInvoiceResource.SettingWaKsnap</button>
                <button class="btn btn-outline-dark" id="btnSetDeliSagawa" type="button" tabindex="-1" onclick="KickChangeDeliSagawa();">@PrintInvoiceResource.SettingSagawa</button>
                <button class="btn btn-outline-dark" id="btnSetDeliYamato" type="button" tabindex="-1" onclick="KickChangeDeliYamato();">@PrintInvoiceResource.SettingYamato</button>
                <button class="btn btn-outline-dark" id="btnSetDeliNekoposu" type="button" tabindex="-1" onclick="KickChangeDeliNekoposu();">@PrintInvoiceResource.SettingNekoposu</button>

                @Html.HiddenFor(model => model.PermissonLavel, new { @id = "hidPermission" })
                @Html.HiddenFor(model => model.Ret, new { @id = "hidRet" })
            </td>
        </tr>
    </table>
    }
</div>
@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        <button id="btnErrorMessage" type="button" class="btn btn-dark btnsize" data-toggle="modal" data-target="#err_ErrMsg" hidden></button>
    </div>
}

@Html.Partial("_ErrorMessageDialog", new Wms.Models.MessageDialog() { Id = "ErrMsg",
    Message = Model.ErrMassagePop + @Environment.NewLine + @PrintEcInvoiceResource.ShipInstructIdS + Model.ErrShipInstructId + @Environment.NewLine + @PrintEcInvoiceResource.ErrMsgKanri })

@** スクリプト *@
