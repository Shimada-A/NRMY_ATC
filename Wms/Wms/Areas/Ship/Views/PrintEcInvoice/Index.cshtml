@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@model Wms.Areas.Ship.ViewModels.PrintEcInvoice.PrintEcInvoiceConditions
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_SHP_PrintEcInvoice;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div class="head head_white collapse show">
    @using (Html.BeginForm("Search", "PrintEcInvoice", FormMethod.Post, new { id = "frmPrint" }))
    {

        @Html.AntiForgeryToken()
    <table>
        <tr>
            <td class="tdtitle">@PrintEcInvoiceResource.CenterIdS</td>
            <td colspan="11">
                <div class="sort">
                    <div class="sort_inner">
                        @Html.CenterDropDownFor(
                            model => model.CenterId
                            , Wms.Common.Profile.User.UserId
                            , "", new { @id = "ddlCenterId", tabindex = "1" })
                    </div>
                </div>
            </td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.PrnClassS</td>
            <td colspan="11">
                @Html.EnumRadioButtonListFor(model => model.PrnClass, new { htmlAttributes = new { tabindex = "2" } })
                <label class="chklist">
                    @Html.CheckBoxFor(model => model.ChkOldData, new { id = "chkChkOldData", tabindex = "2", @placeholder = "", @class = "check-box" })
                    <span class="chk_parts">
                    </span>
                </label>
                @PrintInvoiceResource.ChkOldData
            </td>
            <td></td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.EcShipClassS</td>
            <td colspan="11">
                @Html.EnumRadioButtonListFor(model => model.EcShipClass, new { htmlAttributes = new { tabindex = "3" } })
            </td>
            <td></td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.UnitCntS</td>
            <td colspan="11">
                @Html.EditorFor(model => model.UnitCnt, new { htmlAttributes = new { @class = "w_5_normal", @id = "txtUnitCnt", tabindex = "4" } })
                <a style="color:blue; margin-left:30px;margin-top:-200px;">@PrintEcInvoiceResource.DispMsg</a>
            </td>
        </tr>
        <tr>
            <td>@PrintEcInvoiceResource.ItemSizeIdS</td>
            <td>
                1.@Html.EditorFor(model => model.BoxSize1, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize1", tabindex = "5" } })
            </td>
            <td>
                2.@Html.EditorFor(model => model.BoxSize2, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize2", tabindex = "5" } })
            </td>
            <td>
                3.@Html.EditorFor(model => model.BoxSize3, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize3", tabindex = "5" } })
            </td>
            <td>
                4.@Html.EditorFor(model => model.BoxSize4, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize4", tabindex = "5" } })
            </td>
            <td>
                5.@Html.EditorFor(model => model.BoxSize5, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize5", tabindex = "5" } })
            </td>
            <td>
                6.@Html.EditorFor(model => model.BoxSize6, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize6", tabindex = "5" } })
            </td>
            <td>
                7.@Html.EditorFor(model => model.BoxSize7, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize7", tabindex = "5" } })
            </td>
            <td>
                8.@Html.EditorFor(model => model.BoxSize8, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize8", tabindex = "5" } })
            </td>
            <td>
                9.@Html.EditorFor(model => model.BoxSize9, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize9", tabindex = "5" } })
            </td>
            <td>
                10.@Html.EditorFor(model => model.BoxSize10, new { htmlAttributes = new { @class = "w_3_veryshort", @id = "txtBoxSize10", tabindex = "5" } })
            </td>
            <td>
