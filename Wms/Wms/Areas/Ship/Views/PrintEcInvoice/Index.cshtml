                    $("#txtUnitCnt").removeAttr('disabled');
                    $("#txtBoxNo").removeAttr('disabled');
                }
            };
            //納品書再発行選択
            if ($('input[type=radio][id$="PrnClass-2"]').prop('checked')) {
                $("#txtShipInstructId").removeAttr('disabled');
                $("#btnRelease").show();
                $("#txtBatchNo").val("");
                $("#txtBatchName").val("");
                $("#txtJan").val("");
                $("#txtUnitCnt").val("");
                $("#txtBatchNo").attr('disabled', 'disabled');
                $("#txtJan").attr('disabled', 'disabled');
                $("#txtUnitCnt").attr('disabled', 'disabled');
                $("#txtDeliNo").removeAttr('disabled');
                $('#chkChkOldData').removeAttr('disabled');
                if ($('input[type=radio][id$="EcShipClass-1"]').prop('checked')) {
                    $("#txtBoxNo").val("");
                    $("#txtBoxNo").attr('disabled', 'disabled');
                } else {
                    $("#txtBoxNo").removeAttr('disabled');
                }
            };
            //送り状再発行選択
            if ($('input[type=radio][id$="PrnClass-3"]').prop('checked')) {
                $("#txtShipInstructId").removeAttr('disabled');
                $("#btnRelease").show();
                $("#txtBatchNo").val("");
                $("#txtBatchName").val("");
                $("#txtJan").val("");
                $("#txtBatchNo").attr('disabled', 'disabled');
                $("#txtJan").attr('disabled', 'disabled');
                $("#txtDeliNo").removeAttr('disabled');
                $('#chkChkOldData').removeAttr('disabled');
                $("#txtBoxNo").removeAttr('disabled');

                if ($('input[type=radio][id$="EcShipClass-1"]').prop('checked')) {
                    $("#txtUnitCnt").val("");
                    $("#txtUnitCnt").attr('disabled', 'disabled');
                } else {
                    $("#txtUnitCnt").removeAttr('disabled');
                   
                }
            };

            if ('@Model.ErrMassagePop' != '') {
                $("#btnErrorMessage").click();
            }
        });

        $('#txtBatchNo').on("keydown", function (e) {
            if (e.keyCode === 13) {
                var urlAction = '@Url.Action("GetBatchName", "PrintEcInvoice", new { area= "Ship" })';
                $.ajax({
                    url: urlAction,
                    type: "POST",
                    data: {
                        centerId: $("#ddlCenterId").val(),
                        batchId: $("#txtBatchNo").val()
                    },
                    success: function (data) {
                        if (data.batchName == '') {
                            $('#lblErrMassage1').val("存在しないバッチNoです");
                        } else {
                            $("#txtBatchName").val(data.batchName);
                            $('#txtJan').focus();
                        }
                    }
                });
            }
        });

        $('#txtBatchNo').change(function () {
            if ($(this).val() == "") {
                $('#txtBatchName').val("");
            }
            $('#lblErrMassage1').val("");
        })

        $('#txtJan').on("keydown", function (e) {
            if (e.keyCode === 13) {
                if ($(this).val() == "") {
                    $('#lblErrMassage1').val("JANは必須項目です");
                    return false;
                }
                if ($('#txtBatchNo').val() == "") {
                    $('#lblErrMassage1').val("バッチNoを指定してください");
                    return false;
                }

                $('#txtJan').attr('disabled', 'disabled');
                $('#lblErrMassage1').val("");
                $('#lblErrMassage4').val("");

                $.ajax({
                    url: '@Url.Action("PrintSigle", "PrintEcInvoice", new { area= "Ship" })',
                    type: "POST",
                    data: {
                        centerId: $("#ddlCenterId").val(),
                        batchId: $("#txtBatchNo").val(),
                        jan: $("#txtJan").val(),
                        boxSize: $("#txtBoxSize1").val(),
                        boxSize2: $("#txtBoxSize2").val(),
                        boxSize3: $("#txtBoxSize3").val(),
                        boxSize4: $("#txtBoxSize4").val(),
                        boxSize5: $("#txtBoxSize5").val(),
                        boxSize6: $("#txtBoxSize6").val(),
                        boxSize7: $("#txtBoxSize7").val(),
                        boxSize8: $("#txtBoxSize8").val(),
                        boxSize9: $("#txtBoxSize9").val(),
                        boxSize10: $("#txtBoxSize10").val()
                    },
                    success: function (data) {
                        if (data.status == 0) {
                            //納品書
                            cwebclient.CreatePrintingDataScriptUrl = data.printCcdUrlNouhin;
                            cwebclient.DataSendMethod = "GET";
                            cwebclient.MinimizedProgressDlg = 0;
                            cwebclient.SetClosedFinishing(data.fileNameNouhin);
                            cwebclient.PrintExecuteEx(data.fileNameNouhin);
                            //送り状
                            cwebclient.CreatePrintingDataScriptUrl = data.printCcdUrlDeli;
                            cwebclient.DataSendMethod = "GET";
                            cwebclient.MinimizedProgressDlg = 0;
                            cwebclient.SetClosedFinishing(data.fileNameDeli);
                            cwebclient.PrintExecuteEx(data.fileNameDeli);
                            $("#txtJan").removeAttr('disabled');
                            $("#txtJan").val("");
                            $("#txtJan").focus();
                            $('#lblErrMassage4').val("直近発行済注文番号：" + data.shipInstructId);
                            $("#lblErrMassage4").show();
                        } else {
                            if (data.status == 50 || data.status == 51) {
                                //キャンセルの場合
                                $("#lblErrMassagePop").val(data.errmessage);
                                $("#hidErrShipInstructId").val(data.errShipInstructId);
                                var urlAction ='@Url.Action("Search", "PrintEcInvoice", new { area= "Ship" })';
                                var $form = $("#frmPrint");
                                $form.attr("action", urlAction);
                                $form.attr("method", "POST");
                                $form.submit();
                            } else {
                                $("#lblErrMassage1").val(data.errmessage);
                                $("#lblErrMassage1").show();
                                $('#txtJan').removeAttr('disabled');
                                $('#txtJan').select();
                            }
                        }
                    }
                })
            }
        });

        $('#txtJan').change(function () {
            $('#lblErrMassage1').val("");
            $('#lblErrMassage4').val("");
        })

        $('#txtBoxNo').on("keydown", function (e) {
            if (e.keyCode === 13) {
                $('#lblErrMassage2').val("");
                $('#lblErrMassage4').val("");
                if ($(this).val() == "") {
                    $('#lblErrMassage2').val("ケースNoは必須項目です");
                    $('#txtBoxNo').focus();
                    return false;
                }
                if ($('input[type=radio][id$="PrnClass-2"]').prop('checked') == true || $('input[type=radio][id$="PrnClass-3"]').prop('checked') == true) {
                    $('#txtBoxNo').focus();
                    return false;
                }
                var radios = document.getElementsByName("EcShipClass");
                var ecShipClass;
                for (var i = 0; i < radios.length; i++) {
                    if (radios[i].checked) {
                        ecShipClass = radios[i].value;
                        break;
                    }
                }
          
                $.ajax({
                    url: '@Url.Action("PrintGasOrder", "PrintEcInvoice", new { area= "Ship" })',
                    type: "POST",
                    data: {
                        centerId: $("#ddlCenterId").val(),
                        unitCnt: $("#txtUnitCnt").val(),
                        boxNo: $("#txtBoxNo").val(),
                        ecShipClass: ecShipClass,
                        boxSize: $("#txtBoxSize1").val(),
                        boxSize2: $("#txtBoxSize2").val(),
                        boxSize3: $("#txtBoxSize3").val(),
                        boxSize4: $("#txtBoxSize4").val(),
                        boxSize5: $("#txtBoxSize5").val(),
                        boxSize6: $("#txtBoxSize6").val(),
                        boxSize7: $("#txtBoxSize7").val(),
                        boxSize8: $("#txtBoxSize8").val(),
                        boxSize9: $("#txtBoxSize9").val(),
                        boxSize10: $("#txtBoxSize10").val()

                    },
                    success: function (data) {
                        if (data.status == 0) {
                            //納品書
                            cwebclient.CreatePrintingDataScriptUrl = data.printCcdUrlNouhin;
                            cwebclient.DataSendMethod = "GET";
                            cwebclient.MinimizedProgressDlg = 0;
                            cwebclient.SetClosedFinishing(data.fileNameNouhin);
                            cwebclient.PrintExecuteEx(data.fileNameNouhin);
                            //送り状
                            cwebclient.CreatePrintingDataScriptUrl = data.printCcdUrlDeli;
                            cwebclient.DataSendMethod = "GET";
                            cwebclient.MinimizedProgressDlg = 0;
                            cwebclient.SetClosedFinishing(data.fileNameDeli);
                            cwebclient.PrintExecuteEx(data.fileNameDeli);
                            $("#txtBoxNo").val("");
                            $('#lblErrMassage4').val("直近発行済注文番号：" + data.shipInstructId);
                            $("#lblErrMassage4").show();
                        } else {
                            if (data.status == 100 || data.status == 101) {
                                //キャンセルの場合
                                $("#lblErrMassagePop").val(data.errmessage);
                                $("#hidErrShipInstructId").val(data.errShipInstructId);
                                var urlAction ='@Url.Action("Search", "PrintEcInvoice", new { area= "Ship" })';
                                var $form = $("#frmPrint");
                                $form.attr("action", urlAction);
                                $form.attr("method", "POST");
                                $form.submit();
                            } else {
                                $("#lblErrMassage2").val(data.errmessage);
                                $("#lblErrMassage2").show();
                                $('#txtBoxNo').focus();
                            }
                        }
                    }
                })
            }
        });

        $('#ErrMsg').click(function () {
            if ($('#txtBoxNo').val() != "") {
                $('#txtBoxNo').focus();
            }
        });

        $('#txtBoxNo').change(function () {
            $('#lblErrMassage2').val("");
            $('#lblErrMassage3').val("");
            $('#lblErrMassage4').val("");
        })


        $('#txtShipInstructId').change(function () {
            $('#lblErrMassage3').val("");
        })

        $('#txtDeliNo').change(function () {
            $('#lblErrMassage3').val("");
        })

        $('#btnRelease').on("click", function () {
            $('#lblErrMassage2').val("");
            $('#lblErrMassage3').val("");
            $('#lblErrMassage4').val("");

        if (!validateForm($('#frmPrint'))) {
            return false;
        }
        var radios = document.getElementsByName("PrnClass");
        var prnClass;
        for (var i = 0; i < radios.length; i++) {
            if (radios[i].checked) {
                prnClass = radios[i].value;
                break;
            }
        }
        if ($('#txtBoxNo').val() == "" && $('#txtShipInstructId').val() == "" && $('#txtDeliNo').val() == "") {
            $('#lblErrMassage3').val("発行対象を指定してください");
            return false;
        };

        if ($("#chkChkOldData").prop('checked')) {
            chkOldData = 1;
        } else {
            chkOldData = 0;
        };

        $.ajax({
             url: '@Url.Action("PrintReissue", "PrintEcInvoice", new { area= "Ship" })',
             type: "POST",
             data: {
                 centerId: $("#ddlCenterId").val(),
                 unitCnt: $("#txtUnitCnt").val(),
                 boxNo: $("#txtBoxNo").val(),
                 shipInstructId: $("#txtShipInstructId").val(),
                 prnClass: prnClass,
                 deliNo: $("#txtDeliNo").val(),
                 chkOldData: chkOldData,
                 boxSize: $("#txtBoxSize1").val(),
                 boxSize2: $("#txtBoxSize2").val(),
                 boxSize3: $("#txtBoxSize3").val(),
                 boxSize4: $("#txtBoxSize4").val(),
                 boxSize5: $("#txtBoxSize5").val(),
                 boxSize6: $("#txtBoxSize6").val(),
                 boxSize7: $("#txtBoxSize7").val(),
                 boxSize8: $("#txtBoxSize8").val(),
                 boxSize9: $("#txtBoxSize9").val(),
                 boxSize10: $("#txtBoxSize10").val()
             },
             success: function (data) {
                 if (data.status == 0) {
                     if (data.prnClass == "1") {
                         //納品書再発行
                         window.open("about:blank", "newtab");
                         $("#hidRet").val(data.retPath);
                         urlAction = '@Url.Action("PrintReRun", "PrintEcInvoice", new { area= "Ship" })';
                         var $form = $("#frmPrint");
                         $form.attr("action", urlAction);
                         $form.attr("method", "POST");
                         $form.attr("target", "newtab");
                         $form.submit();
                         $form.attr("target", "_self");
                         $("#txtBoxNo").val("");
                         $("#txtDeliNo").val("");
                     } else {
                         //送り状再発行
                         cwebclient.CreatePrintingDataScriptUrl = data.retPath;
                         cwebclient.DataSendMethod = "GET";
                         cwebclient.MinimizedProgressDlg = 0;
                         cwebclient.SetClosedFinishing(data.fileNameDeli);
                         cwebclient.PrintExecuteEx(data.fileNameDeli);
                         $("#txtBoxNo").val("");
                         $("#txtDeliNo").val("");
                     }

                 } else {
                     if (data.status == 160 || data.status == 161) {
                         //キャンセルの場合
                         $("#lblErrMassagePop").val(data.errmessage);
                         $("#hidErrShipInstructId").val(data.errShipInstructId);
                         var urlAction ='@Url.Action("Search", "PrintEcInvoice", new { area= "Ship" })';
                         var $form = $("#frmPrint"); 
                         $form.attr("action", urlAction);
                         $form.attr("method", "POST");
                         $form.submit();
                     } else {
                         $("#lblErrMassage3").val(data.errmessage);
                          $("#lblErrMassage3").show();
                     }
                 }
             }
         })
        });

        //印刷定義設定
        function KickChangePrintInfo() {
            // 引数に帳票名（Job ファイル名）を指定します
            cwebclient.ChangePrintInfo("PrintEcInvoice");
        }

        function KickChangePrintInfoRakuten() {
            // 引数に帳票名（Job ファイル名）を指定します
            cwebclient.ChangePrintInfo("PrintEcRakutenInvoice");
        }

        function KickChangePrintInfoWaKsnap() {
            // 引数に帳票名（Job ファイル名）を指定します
            cwebclient.ChangePrintInfo("PrintEcWaKsnapInvoice");
        }

        function KickChangeDeliSagawa() {
            cwebclient.ChangePrintInfo("invoice_sagawa");
        }

        function KickChangeDeliYamato() {
            cwebclient.ChangePrintInfo("invoice_yamato");
        }

        function KickChangeDeliNekoposu() {
            cwebclient.ChangePrintInfo("invoice_nekoposu");
        }
        

    </script>
}


