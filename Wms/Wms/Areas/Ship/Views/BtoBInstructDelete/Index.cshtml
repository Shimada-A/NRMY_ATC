@if (Model.Results.BtoBInstructDeletes != null)
{

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.BtoBInstructDeletes.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:69vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">&nbsp;</th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.ShipPlanDateD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.InstructClassD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.EmergencyClassD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.ShipInstructIdD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.ItemSkuQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.ShipToQtyD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.PlanQtyD
                                </th>
                                <th class="bg-grey align-middle">
                                    @BtoBInstructDeleteResource.AllocDateTimeD
                                </th>
                                <th class="bg-grey align-middle"></th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "Ship", FormMethod.Post, new { id = "frmList" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.BtoBInstructDeletes.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("BtoBInstructDeletes[{0}].", cModel.i);
                                    <tr>
                                        <td class="w_checkbox align-middle">
                                            <label class="checkboxgroup">
                                                @Html.CheckBoxFor(modelItem => cModel.v.IsCheck, new { @id = (key + "CheckedValue"), @class = "check-box", onclick = "SetCheckValue(" + @cModel.i + ")" })
                                                <span class="chk_parts"></span>
                                            </label>
                                        </td>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.Results.BtoBInstructDeletes.PageNumber - 1) * Model.Results.BtoBInstructDeletes.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipPlanDate)
                                        </td>
                                        <td class="align-middle">
                                            @(EnumHelper<InstructClasses>.GetDisplayValue(cModel.v.InstructClass).ToString())
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.EmergencyClassName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipInstructId)
                                        </td>
                                        <td class="align-middle  text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSkuQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipToQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.InstructQty)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.AllocDate)
                                        </td>
                                        <td class="align-middle" style="width:100px;">
                                            <button type="button" class="btn btn-dark btn-sm" onclick="Detail('@cModel.v.ShipInstructId')">@BtoBInstructDeleteResource.BtnDetail</button>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                            @Html.HiddenFor(modelItem => cModel.v.LineNo, new { Name = key + "LineNo" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

