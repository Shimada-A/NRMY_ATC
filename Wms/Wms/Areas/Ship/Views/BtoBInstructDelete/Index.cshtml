    <script>
    /**
     * Country class
     */
        var curentSelectedCnt = 0;
        var curentSelectedCntDiff = 0;
    var BtoBInstructDeleteView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            btnDelete: '#BtnDelete',
            ddlSortKey: '#ddlSortKey',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnBrandId: '#btnBrandId',
            brandId:'#txtBrandId',
            brandName:'#txtBrandName',
            brandSelect: '#brandSelect',
            btnMainVendor:'#btnMainVendor',
            mainVendorId:'#txtMainVendorId',
            mainVendorName:'#txtMainVendorName',
            vendorSelect: '#vendorSelect',
            btnTransporterArea: '#btnTransporterArea',
            txtTransporterArea: '#txtTransporterArea',
            txtTransporterAreaName: '#txtTransporterAreaName',
            deliareaGroupSelect: '#deliareaGroupSelect',
            btnTransporter: '#btnTransporter',
            txtTransporterId: '#txtTransporterId',
            txtTransporterName: '#txtTransporterName',
            transporterSelect: '#transporterSelect',
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(BtoBInstructDeleteView.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(BtoBInstructDeleteView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(BtoBInstructDeleteView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(BtoBInstructDeleteView.SELECTORS.chkCheckedInTable).length;
                    BtoBInstructDeleteView.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * Dropdownlist change item
                */
                $(BtoBInstructDeleteView.SELECTORS.ddlSort).change(function (val) {
                    $(BtoBInstructDeleteView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(BtoBInstructDeleteView.SELECTORS.ddlSortKey).change(function (val) {
                    $(BtoBInstructDeleteView.SELECTORS.btnSearch).click();
                });

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBInstructDeleteView.SELECTORS.btnBrandId).on("click", brandSearchModal.open);

                /**
                * 仕入先検索ダイアログの設定
                */
                $(BtoBInstructDeleteView.SELECTORS.btnMainVendor).on("click", vendorSearchModal.open);

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBInstructDeleteView.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                * 配送業者検索ダイアログの設定
                */
                $(BtoBInstructDeleteView.SELECTORS.btnTransporter).on("click", transporterSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(BtoBInstructDeleteView.SELECTORS.brandSelect).on("click", function () {
                    $('#brandSearchResult input[type=radio]:checked').each(function (index, item) {
                        var brandId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var brandName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(BtoBInstructDeleteView.SELECTORS.brandId).val(brandId);
                        $(BtoBInstructDeleteView.SELECTORS.brandName).val(brandName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(BtoBInstructDeleteView.SELECTORS.vendorSelect).on("click", function () {
                    $('#vendorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var vendorId = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var vendorName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        $(BtoBInstructDeleteView.SELECTORS.mainVendorId).val(vendorId);
                        $(BtoBInstructDeleteView.SELECTORS.mainVendorName).val(vendorName);
                    })
                });
                /**
                 *Click button get data Brand
                 */
                $(BtoBInstructDeleteView.SELECTORS.deliareaGroupSelect).on("click", function () {

                    var ids = [];
                    var names = [];

                    $('#deliareaGroupSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var area = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var areaName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        ids.push(area);
                        names.push(areaName);
                    });
                    ids = ids.toString().split(',');
                    names = names.join('、').split('、');

                    ids = Array.from(new Set(ids));
                    names = Array.from(new Set(names));
                    //$.unique(ids.sort());
                    //$.unique(names.sort());

                    $(BtoBInstructDeleteView.SELECTORS.txtTransporterArea).val(ids.toString());
                    $(BtoBInstructDeleteView.SELECTORS.txtTransporterAreaName).val(names.join('、'));

                });
                /**
                 *Click button get data Brand
                 */
                $(BtoBInstructDeleteView.SELECTORS.transporterSelect).on("click", function () {
                    $(BtoBInstructDeleteView.SELECTORS.txtTransporterId).val("");
                    $(BtoBInstructDeleteView.SELECTORS.txtTransporterName).val("");
                    $('#transporterSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var transporterId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var transporterName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        if ($(BtoBInstructDeleteView.SELECTORS.txtTransporterId).val() == "") {
                            $(BtoBInstructDeleteView.SELECTORS.txtTransporterId).val(transporterId);
                            $(BtoBInstructDeleteView.SELECTORS.txtTransporterName).val(transporterName);
                        } else {
                            $(BtoBInstructDeleteView.SELECTORS.txtTransporterId).val($(BtoBInstructDeleteView.SELECTORS.txtTransporterId).val() + ',' + transporterId);
                            $(BtoBInstructDeleteView.SELECTORS.txtTransporterName).val($(BtoBInstructDeleteView.SELECTORS.txtTransporterName).val() + '、' + transporterName);
                        }

                    })
                });

                /**
                 * Button check all clicked
                 */
                $(BtoBInstructDeleteView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("AllSelectedSearch", "BtoBInstructDelete", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });

                /**
                 * Button UnCheck all clicked
                 */
                $(BtoBInstructDeleteView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("UnSelectedSearch", "BtoBInstructDelete", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
                // Display row is selected
                $(BtoBInstructDeleteView.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
                // Enable/Disable button Edit
                if ($(BtoBInstructDeleteView.SELECTORS.rowSelected).text() >= 1) {
                    if (getUsable_Class() != 1) {
                        $(BtoBInstructDeleteView.SELECTORS.btnDelete).removeAttr('disabled');
                    }
                } else {
                    $(BtoBInstructDeleteView.SELECTORS.btnDelete).attr('disabled', 'disabled');
                }
            },
        }
    /**
    * Page loaded
    */
    $(document).ready(function () {
        BtoBInstructDeleteView.init();
        if ('@ViewBag.Status' != '@ProcedureStatus.Success' && '@ViewBag.Status' != '') {
            $("#btnErrorMessage").click();
        }
        if ($("#hidSortKey").val() == '@BtoBInstructDeleteSearchConditions.BtoBInstructDeleteSortKey.InstructId' || $("#hidSortKey").val() == 1) {
            $("#ddlSortKey").val(1);
        } else {
            $("#ddlSortKey").val(0);
        }
        if ($("#hidSort").val() == '@BtoBInstructDeleteSearchConditions.AscDescSort.Desc' || $("#hidSort").val() == 1) {
            $("#ddlSort").val(1);
        } else {
            $("#ddlSort").val(0);
        }
        $("#ddlSortKey").removeClass("input-validation-error");
        if ($("#ddlCategoryId1").val() != '') {
            $("#ddlCategoryId2").removeAttr('disabled');
        }
        if ($("#ddlCategoryId2").val() != '') {
                $("#ddlCategoryId3").removeAttr('disabled');
        }
        if ($("#ddlCategoryId3").val() != '') {
                $("#ddlCategoryId4").removeAttr('disabled');
        }
        if ('@Model.Results.BtoBInstructDeletes' == null || '@Model.Results' == null) {
            $("#spnCheckedCounter").text(0);
        }
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var urlAction ='@Url.Action("Search", "BtoBInstructDelete", new { area= "Ship" })';
                var pageUrl = urlAction + '?Page=';
