@section LayoutScripts{
    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")
    <script>
        $("#btnDownload").on("click", function () {
        if ('@Model.SearchConditions.ResultType' == '@Wms.Areas.Ship.ViewModels.BtoBInstructionReference.ResultTypes.Sku')
        {
            var urlAction = '@Url.Action("Download", "BtoBInstructionReference", new { area = "Ship" })';
        }
        else
        {
            var urlAction = '@Url.Action("DownloadDetail", "BtoBInstructionReference", new { area = "Ship" })';
        }
        var $form = $("#frmSearch");
        $form.attr("action", urlAction);
        $form.attr("method", "Post");
            $form.submit();

        setTimeout(function () {
            if ($(BtoBInstructionReferenceView.SELECTORS.rowSelected).text() >= 1) {
                $(BtoBInstructionReferenceView.SELECTORS.btnDetail).removeAttr('disabled');
            }
        }, 1000);
    });


    /**
     * Country class
     */
        var curentSelectedCnt = 0;
        var curentSelectedCntDiff = 0;
    var BtoBInstructionReferenceView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=checkbox][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            btnDetail: '#btnDetail',
            btnCancel: '#btnCancel',
            ddlSortKey: '#ddlSortKey',
            ddlDetailSortKey: '#ddlDetailSortKey',
            chkChecked: ':checkbox:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnBrandId: '#btnBrandId',
            brandId:'#txtBrandId',
            brandName:'#txtBrandName',
            brandSelect: '#brandSelect',
            btnMainVendor:'#btnMainVendor',
            mainVendorId:'#txtMainVendorId',
            mainVendorName:'#txtMainVendorName',
            vendorSelect: '#vendorSelect',
            btnTransporterArea: '#btnTransporterArea',
            txtTransporterArea: '#txtTransporterArea',
            txtTransporterAreaName: '#txtTransporterAreaName',
            deliareaGroupSelect: '#deliareaGroupSelect',
            btnTransporter: '#btnTransporter',
            txtTransporterId: '#txtTransporterId',
            txtTransporterName: '#txtTransporterName',
            transporterSelect: '#transporterSelect',
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(BtoBInstructionReferenceView.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(BtoBInstructionReferenceView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(BtoBInstructionReferenceView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(BtoBInstructionReferenceView.SELECTORS.chkCheckedInTable).length;
                    BtoBInstructionReferenceView.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * Dropdownlist change item
                */
                $(BtoBInstructionReferenceView.SELECTORS.ddlSort).change(function (val) {
                    $(BtoBInstructionReferenceView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(BtoBInstructionReferenceView.SELECTORS.ddlSortKey).change(function (val) {
                    $(BtoBInstructionReferenceView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(BtoBInstructionReferenceView.SELECTORS.ddlDetailSortKey).change(function (val) {
                    $(BtoBInstructionReferenceView.SELECTORS.btnSearch).click();
                });

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBInstructionReferenceView.SELECTORS.btnBrandId).on("click", brandSearchModal.open);

                /**
                * 仕入先検索ダイアログの設定
                */
                $(BtoBInstructionReferenceView.SELECTORS.btnMainVendor).on("click", vendorSearchModal.open);

                /**
                * ブランド検索ダイアログの設定
                */
                $(BtoBInstructionReferenceView.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                * 配送業者検索ダイアログの設定
                */
                $(BtoBInstructionReferenceView.SELECTORS.btnTransporter).on("click", transporterSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(BtoBInstructionReferenceView.SELECTORS.brandSelect).on("click", function () {
                    $('#brandSearchResult input[type=radio]:checked').each(function (index, item) {
                        var brandId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var brandName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(BtoBInstructionReferenceView.SELECTORS.brandId).val(brandId);
                        $(BtoBInstructionReferenceView.SELECTORS.brandName).val(brandName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(BtoBInstructionReferenceView.SELECTORS.vendorSelect).on("click", function () {
                    $('#vendorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var vendorId = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var vendorName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        $(BtoBInstructionReferenceView.SELECTORS.mainVendorId).val(vendorId);
                        $(BtoBInstructionReferenceView.SELECTORS.mainVendorName).val(vendorName);
                    })
                });
                /**
                 *Click button get data Brand
                 */
                $(BtoBInstructionReferenceView.SELECTORS.transporterSelect).on("click", function () {
                    $(BtoBInstructionReferenceView.SELECTORS.txtTransporterId).val("");
                    $(BtoBInstructionReferenceView.SELECTORS.txtTransporterName).val("");
                    $('#transporterSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var transporterId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var transporterName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        if ($(BtoBInstructionReferenceView.SELECTORS.txtTransporterId).val() == "") {
                            $(BtoBInstructionReferenceView.SELECTORS.txtTransporterId).val(transporterId);
                            $(BtoBInstructionReferenceView.SELECTORS.txtTransporterName).val(transporterName);
                        } else {
                            $(BtoBInstructionReferenceView.SELECTORS.txtTransporterId).val($(BtoBInstructionReferenceView.SELECTORS.txtTransporterId).val() + ',' + transporterId);
                            $(BtoBInstructionReferenceView.SELECTORS.txtTransporterName).val($(BtoBInstructionReferenceView.SELECTORS.txtTransporterName).val() + '、' + transporterName);
                        }

                    })
                });

                /**
                 * Button check all clicked
                 */
                $(BtoBInstructionReferenceView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("AllSelectedSearch", "BtoBInstructionReference", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });

                /**
                 * Button UnCheck all clicked
                 */
                $(BtoBInstructionReferenceView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("UnSelectedSearch", "BtoBInstructionReference", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
                // Display row is selected
                $(BtoBInstructionReferenceView.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
                // Enable/Disable button Edit
                if ($(BtoBInstructionReferenceView.SELECTORS.rowSelected).text() >= 1) {
                    $(BtoBInstructionReferenceView.SELECTORS.btnDetail).removeAttr('disabled');
                } else {
                    $(BtoBInstructionReferenceView.SELECTORS.btnDetail).attr('disabled', 'disabled');
                }
                if ($(BtoBInstructionReferenceView.SELECTORS.rowSelected).text() >= 1) {
                    if (getUsable_Class() != 1) {
                        //$(BtoBInstructionReferenceView.SELECTORS.btnCancel).removeAttr('disabled');
                    }
                } else {
                    $(BtoBInstructionReferenceView.SELECTORS.btnCancel).attr('disabled', 'disabled');
                }
            },
        }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        BtoBInstructionReferenceView.init();
        $("#ddlDetailSortKey").removeClass("input-validation-error");
        $("#ddlSortKey").removeClass("input-validation-error");
        if ($("#ddlCategoryId1").val() != '') {
            $("#ddlCategoryId2").removeAttr('disabled');
        }
        if ($("#ddlCategoryId2").val() != '') {
                $("#ddlCategoryId3").removeAttr('disabled');
        }
        if ($("#ddlCategoryId3").val() != '') {
                $("#ddlCategoryId4").removeAttr('disabled');
        }
        if ('@Model.SearchConditions.ResultType' == '@Wms.Areas.Ship.ViewModels.BtoBInstructionReference.ResultTypes.Detail')
        {
            $("#lblDetail").addClass("active");
            $("#lblSku").removeClass("active");
            $("#Detail").prop("checked", true);
            $("#Sku").prop("checked", false);
        } else {
            $("#lblSku").addClass("active");
            $("#lblDetail").removeClass("active");
            $("#Detail").prop("checked", false);
            $("#Sku").prop("checked", true);
        }
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var urlAction ='@Url.Action("Search", "BtoBInstructionReference", new { area= "Ship" })';
                var pageUrl = urlAction + '?Page=';
                var page = $(item).attr("href").replace(pageUrl, "");
                page = page.replace("&class=btn-outline-dark", "");
                $(item).attr("href", "javascript:void(0);").click(function () {
                    $("#hidPage").val(page);
                    $("#hidSearchType").val("SortPage");
                    $("#frmSearch").attr("action", urlAction);
                    $("#frmSearch").attr("method", "POST");
                    $("#frmSearch").submit();
                });
            });
            if ($("#txtShipAllocStatus").val() == "" || $("#txtShipAllocStatus").val() == "2") {
                $("#txtShipAllocStatusOld").removeAttr('disabled');
            } else {
                $("#txtShipAllocStatusOld").attr('disabled', 'disabled');
                $("#txtShipAllocStatusOld").prop("checked",false);
            }
    });
        function ShipAllocStatusChange() {
            if ($("#txtShipAllocStatus").val() == "" || $("#txtShipAllocStatus").val() == "2") {
                $("#txtShipAllocStatusOld").removeAttr('disabled');
            } else {
                $("#txtShipAllocStatusOld").attr('disabled', 'disabled');
                $("#txtShipAllocStatusOld").prop("checked",false);
            }
        }
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());
            $("#hidDetailSortKey").val($("#ddlDetailSortKey").val());
            $("#hidSearchType").val("SortPage");

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "BtoBInstructionReference", new { area= "Ship" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function GetCategoryList(id) {
                    var urlAction = '@Url.Action("GetCategoryList","ItemSku",new { area = "Master"})';
                    $.ajax({
                        url: urlAction,
                        type: "POST",
                        data: {
                            id: id + 1,
                            category1: $("#ddlCategoryId1").val(),
                            category2: $("#ddlCategoryId2").val(),
                            category3: $("#ddlCategoryId3").val()
                        },
                        success: function (data) {
                            $("#ddlCategoryId" + (id + 1)).html("");
                            $("#ddlCategoryId" + (id + 1)).html(data.html);
                        }
                    });
        }
        function CategoryChange(id) {
            if ($("#ddlCategoryId" + id).val() != '') {
                GetCategoryList(id);
                $("#ddlCategoryId" + (id + 1)).removeAttr('disabled');
                if (id == 1) {
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            } else {
                if (id == 1) {
                    $("#ddlCategoryId2").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId2").val('');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 3){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            }
        }
        function SetCheckValue(lineNo) {
            $('input[type=checkbox][id$="SearchConditions.BtoBInstructionReference01s[' + lineNo + '].CheckedValue"]').each(function (i, item) {
                $(item).trigger('click');
                });
        }
        function Search() {
            if (ConditionsCheck('search')) {
                $("#hidResultType").val("Sku");
                $("#hidSearchType").val("Search");
                var urlAction = '@Url.Action("Search", "BtoBInstructionReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            }
            }
            $("#Sku").on("click", function () {
                $("#hidResultType").val("Sku");
                $("#hidSearchType").val("Search");
                $("#hidDetailFlag").val("List");
                var urlAction = '@Url.Action("Search", "BtoBInstructionReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            });
            $("#Detail").on("click", function () {
                $("#hidResultType").val("Detail");
                $("#hidSearchType").val("Search");
                $("#hidDetailFlag").val("List");
                var urlAction = '@Url.Action("Search", "BtoBInstructionReference", new { area = "Ship" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            });
        $('#btnCancel').on("click", function () {
            if (!validateForm($('#frmSearch')) || !ConditionsCheck('upd')) {
                return;
            }
            $('#btnCancelHidden').click();
        });
        $('#ShipCancel').on("click", function () {
            var urlAction = '@Url.Action("ShipCancel", "BtoBInstructionReference", new { area = "Ship" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        $('#btnDetail').on("click", function () {
