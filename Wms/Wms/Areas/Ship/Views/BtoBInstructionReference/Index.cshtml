            </label>
            <label class="btn btn-outline-dark" id="lblDetail">
                <input type="radio" name="options" id="Detail" autocomplete="off"> @BtoBInstructionReferenceResource.BtnInstructDetail
            </label>
        </div>
        <div class="sortarea mainpagearea">
