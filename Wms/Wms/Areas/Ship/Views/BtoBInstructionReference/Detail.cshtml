@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@using Wms.Areas.Ship.ViewModels.BtoBInstructionReference;
@model Wms.Areas.Ship.ViewModels.BtoBInstructionReference.BtoBInstructionReference02ViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_SHP_BtoBInstructionReference03;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
@using (Html.BeginForm("DetailSearch", "BtoBInstructionReference", FormMethod.Post, new { id = "frmDetailSearch" }))
{
    @Html.AntiForgeryToken()
    <div class="headarea sortheadareaheight">
        <table class="headtable">
            <tr>
                <td>
                    @BtoBInstructionReferenceResource.ShipPlanDateS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.ShipPlanDate)
                </td>
                <td>
                    @BtoBInstructionReferenceResource.AllocDateTimeS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.AllocDate)
                </td>
                <td>
                </td>
            </tr>
            <tr>
                <td>
                    @BtoBInstructionReferenceResource.InstructClassS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.InstructClassName)
                    &nbsp;&nbsp;
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.EmergencyClassName)
                </td>
                <td>
                    @BtoBInstructionReferenceResource.InstructIdS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.ShipInstructId)
                    @Html.HiddenFor(modelItem => modelItem.SearchConditions.ShipInstructId)
                </td>
                <td>
                    @BtoBInstructionReferenceResource.InstructSeqS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.ShipInstructSeq)
                    @Html.HiddenFor(modelItem => modelItem.SearchConditions.ShipInstructSeq)
                </td>
            </tr>
            <tr>
                <td>
                    @BtoBInstructionReferenceResource.ShipToStoreS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.ShipToStoreId)
                    &nbsp;&nbsp;
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.ShipToStoreName)
                </td>
                <td>
                    @BtoBInstructionReferenceResource.TransporterS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.TransporterName)
                </td>
                <td>
                    @BtoBInstructionReferenceResource.DeliShiwakeCdS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.DeliShiwakeCd)
                </td>
            </tr>
            <tr>
                <td colspan="3">
                    @BtoBInstructionReferenceResource.BatchNoS
                    @Html.DisplayFor(modelItem => modelItem.SearchConditions.BatchNo)
                </td>
            </tr>
        </table>
        @Html.HiddenFor(modelItem => modelItem.SearchConditions.CenterId)
    </div>

    <div class="message-area">
        @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
        @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
    </div>

    <div class="sublbarea no_border stock_detail_head">
        @BtoBInstructionReferenceResource.ListDetail
    </div>
    <div class="Container">
        <div>
            <div class="tb_scroll">
                <table class="table table-bordered" id="listData">
                    <thead>
                        <tr>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.No
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.CategoryName1
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.Item
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ItemColor
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ItemSize
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.JAN
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.InstructQty
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.AllocQty
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.StockOutFixQty
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ResultQty
                            </th>
                            <th hidden>
                            </th>
                        </tr>
                    </thead>
                    @if (Model.DetailResults.BtoBInstructionReference02Details != null && Model.DetailResults.BtoBInstructionReference02Details.Count() > 0)
                    {
                        <tbody>
                            @foreach (var cModel in Model.DetailResults.BtoBInstructionReference02Details.Select((v, i) => new { v, i }))
                            {
                                var key = String.Format("BtoBInstructionReference02s[{0}].", cModel.i);
                                <tr>
                                    <td class="align-middle text-right w_no">
                                        @(cModel.i + 1)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.CategoryName1)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemColorId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemColorName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemSizeId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemSizeName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.Jan)
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.InstructQty)
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.AllocQty)
                                        @Html.HiddenFor(modelItem => cModel.v.AllocQty, new { id = key + "AllocQty" })
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.StockOutFixQty)
                                        @Html.HiddenFor(modelItem => cModel.v.StockOutFixQty, new { id = key + "StockOutFixQty" })
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        @Html.HiddenFor(modelItem => cModel.v.ResultQty, new { id = key + "ResultQty" })
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="sublbarea no_border stock_detail_head">
        @BtoBInstructionReferenceResource.ListPackageDetail
        <div class="sortarea">
            <ul>
                <li>
                    @BtoBInstructionReferenceResource.ResultQtySum @Html.DisplayFor(model => model.SearchConditions.ResultQtySum)
                </li>
            </ul>
        </div>
    </div>
    @* Container *@
    <div class="Container">
        <div>
            <div class="tb_scroll">
                <table class="table table-bordered" id="listData">
                    <thead>
                        <tr>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.No
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.BoxNo
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.DeliNo
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ShipStatusName
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ShipPlanDate
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.CategoryName1
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.Item
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ItemColor
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ItemSize
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.JAN
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.ResultQty
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.AsortUserName
                            </th>
                            <th class="bg-grey align-middle">
                                @BtoBInstructionReferenceResource.NouhinPrnUserName
                            </th>
                            <th hidden>
                            </th>
                        </tr>
                    </thead>
                    @if (Model.PackageDetailResults.BtoBInstructionReference02PackageDetails != null && Model.PackageDetailResults.BtoBInstructionReference02PackageDetails.Count() > 0)
                    {
                        <tbody>
                            @foreach (var cModel in Model.PackageDetailResults.BtoBInstructionReference02PackageDetails.Select((v, i) => new { v, i }))
                            {
                                var key = String.Format("BtoBInstructionReference02PackageDetails[{0}].", cModel.i);
                                <tr>
                                    <td class="align-middle text-right w_no">
                                        @(cModel.i + 1)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.BoxNo)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.DeliNo)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ShipStatusName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ShipPlanDate)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.CategoryName1)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemColorId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemColorName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.ItemSizeId)<br />
                                        @Html.DisplayFor(modelItem => cModel.v.ItemSizeName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.Jan)
                                    </td>
                                    <td class="align-middle text-right">
                                        @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.AsortUserName)
                                    </td>
                                    <td class="align-middle">
                                        @Html.DisplayFor(modelItem => cModel.v.NouhinPrnUserName)
                                        @Html.HiddenFor(modelItem => cModel.v.StockOutFixDate, new { id = key + "StockOutFixDate" })
                                        @Html.HiddenFor(modelItem => cModel.v.SortStatus, new { id = "hidSortStatus" })
                                    </td>
                                </tr>
                            }
                        </tbody>
                    }
                </table>
            </div>
        </div>
    </div>
}

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        @Html.ActionLink(FormsResource.BTN_RETURN, "IndexSearch", "BtoBInstructionReference", new { area = "Ship" }, new { type = "button", @class = "btn btn-outline-dark btnsize" })
        <button id="btnStockOutFixHidden" type="button" class="btn btn-outline-danger _pm" data-toggle="modal" data-target="#confirm_StockOutFix" hidden></button>
        @if (Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().StockOutRegDispFlag == 1 &&
            ((Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().AllocQty == null ? 0 : Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().AllocQty) !=
            (Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().StockOutFixQty == null ? 0 : Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().StockOutFixQty) +
            (Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().ResultQty == null ? 0 : Model.DetailResults.BtoBInstructionReference02Details.FirstOrDefault().ResultQty)))
        {
            <button type="submit" id="btnStockOutFix" class="btn btn-outline-danger btnsize _pm">@BtoBInstructionReferenceResource.StockOutFixQty</button>
        }
        <button id="btnErrorMessage" type="button" class="btn btn-dark btnsize" data-toggle="modal" data-target="#err_Error" hidden></button>
    </div>
}
@Html.Partial("_ConfirmMessageDialog", new Wms.Models.MessageDialog() { Id = "StockOutFix", Message = BtoBInstructionReferenceResource.MsgStockOutFix })
@Html.Partial("_ErrorMessageDialog", new Wms.Models.MessageDialog() { Id = "Error", Message = (string)ViewBag.Message })
@** スクリプト *@
@section LayoutScripts{
    <script>
        $('#btnStockOutFix').on("click", function () {
            //仕分中データは欠品確定不可
            if ($('#hidSortStatus').val() == 1) {
                alert('@BtoBInstructionReferenceResource.ErrSorting')
            } else {
                $('#btnStockOutFixHidden').click();
            }
        });
        $('#StockOutFix').on("click", function () {
            var urlAction = '@Url.Action("StockOutFix", "BtoBInstructionReference", new { area = "Ship" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        $(document).ready(function () {
            if ('@ViewBag.Status' != '@ProcedureStatus.Success' && '@ViewBag.Status' != '') {
                $("#btnErrorMessage").click();
            }
        });
    </script>
}