                /**
                * ブランド検索ダイアログの設定
                */
                $(DcAllocationView.SELECTORS.btnBrandId).on("click", brandSearchModal.open);

                /**
                * 仕入先検索ダイアログの設定
                */
                $(DcAllocationView.SELECTORS.btnMainVendor).on("click", vendorSearchModal.open);

                /**
                * ブランド検索ダイアログの設定
                */
                $(DcAllocationView.SELECTORS.btnTransporterArea).on("click", deliareaGroupSearchModal.open);

                /**
                * 配送業者検索ダイアログの設定
                */
                $(DcAllocationView.SELECTORS.btnTransporter).on("click", transporterSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(DcAllocationView.SELECTORS.brandSelect).on("click", function () {
                    $('#brandSearchResult input[type=radio]:checked').each(function (index, item) {
                        var brandId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var brandName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(DcAllocationView.SELECTORS.brandId).val(brandId);
                        $(DcAllocationView.SELECTORS.brandName).val(brandName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(DcAllocationView.SELECTORS.vendorSelect).on("click", function () {
                    $('#vendorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var vendorId = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var vendorName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        $(DcAllocationView.SELECTORS.mainVendorId).val(vendorId);
                        $(DcAllocationView.SELECTORS.mainVendorName).val(vendorName);
                    })
                });
                /**
                 *Click button get data Brand
                 */
                $(DcAllocationView.SELECTORS.deliareaGroupSelect).on("click", function () {

                    var ids = [];
                    var names = [];

                    $('#deliareaGroupSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var area = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var areaName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        ids.push(area);
                        names.push(areaName);
                    });
                    ids = ids.toString().split(',');
                    names = names.join('、').split('、');

                    ids = Array.from(new Set(ids));
                    names = Array.from(new Set(names));
                    //$.unique(ids.sort());
                    //$.unique(names.sort());

                    $(DcAllocationView.SELECTORS.txtTransporterArea).val(ids.toString());
                    $(DcAllocationView.SELECTORS.txtTransporterAreaName).val(names.join('、'));

                });
                /**
                 *Click button get data Brand
                 */
                $(DcAllocationView.SELECTORS.transporterSelect).on("click", function () {
                    $(DcAllocationView.SELECTORS.txtTransporterId).val("");
                    $(DcAllocationView.SELECTORS.txtTransporterName).val("");
                    $('#transporterSearchResult input[type=checkbox]:checked').each(function (index, item) {
                        var transporterId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var transporterName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        if ($(DcAllocationView.SELECTORS.txtTransporterId).val() == "") {
                            $(DcAllocationView.SELECTORS.txtTransporterId).val(transporterId);
                            $(DcAllocationView.SELECTORS.txtTransporterName).val(transporterName);
                        } else {
                            $(DcAllocationView.SELECTORS.txtTransporterId).val($(DcAllocationView.SELECTORS.txtTransporterId).val() + ',' + transporterId);
                            $(DcAllocationView.SELECTORS.txtTransporterName).val($(DcAllocationView.SELECTORS.txtTransporterName).val() + '、' + transporterName);
                        }

                    })
                });

                /**
                 * Button check all clicked
                 */
                $(DcAllocationView.SELECTORS.btnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("AllSelectedSearch", "DcAllocation", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });

                /**
                 * Button UnCheck all clicked
                 */
                $(DcAllocationView.SELECTORS.btnUnCheckAll).click(function () {
                    if ($("#listData").length) {
                        $("#hidSearchType").val("SortPage");
                        var urlAction = '@Url.Action("UnSelectedSearch", "DcAllocation", new { area= "Ship" })';
                        var $form = $("#frmSearch");
                        $form.attr("action", urlAction);
                        $form.attr("method", "POST");
                        $form.submit();
                    }
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
                // Display row is selected
                $(DcAllocationView.SELECTORS.rowSelected).text(@Model.SearchConditions.SelectedCnt - difCnt );
                // Enable/Disable button Edit
                if ($(DcAllocationView.SELECTORS.rowSelected).text() >= 1) {
                    if (getUsable_Class() != 1) {
                        if ('@Model.SearchConditions.ResultType' == '@Wms.Areas.Ship.ViewModels.DcAllocation.ResultTypes.Sku') {
                            if ($(DcAllocationView.SELECTORS.txtShipToId).val() == "" && $(DcAllocationView.SELECTORS.txtTransporterId).val() == "" && $(DcAllocationView.SELECTORS.txtTransporterArea).val() == "") {
                                $(DcAllocationView.SELECTORS.btnAlloc).removeAttr('disabled');
                            } else {
                                $(DcAllocationView.SELECTORS.btnAlloc).attr('disabled', 'disabled');
                            }
                        } else {
                            $(DcAllocationView.SELECTORS.btnAlloc).removeAttr('disabled');
                        }
                    }
                } else {
                    $(DcAllocationView.SELECTORS.btnAlloc).attr('disabled', 'disabled');
                }
                if ($(DcAllocationView.SELECTORS.rowSelected).text() >= 1) {
                        $(DcAllocationView.SELECTORS.btnInstructDetailGo).removeAttr('disabled');
                } else {
                    $(DcAllocationView.SELECTORS.btnInstructDetailGo).attr('disabled', 'disabled');
                }
            },
        }
    /**
