                    $.ajax({
                        url: urlAction,
                        type: "POST",
                        data: {
                            id: id + 1,
                            category1: $("#ddlCategoryId1").val(),
                            category2: $("#ddlCategoryId2").val(),
                            category3: $("#ddlCategoryId3").val()
                        },
                        success: function (data) {
                            $("#ddlCategoryId" + (id + 1)).html("");
                            $("#ddlCategoryId" + (id + 1)).html(data.html);
                        }
                    });
        }
        function CategoryChange(id) {
            if ($("#ddlCategoryId" + id).val() != '') {
                GetCategoryList(id);
                $("#ddlCategoryId" + (id + 1)).removeAttr('disabled');
                if (id == 1) {
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            } else {
                if (id == 1) {
                    $("#ddlCategoryId2").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId2").val('');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 3){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            }
        }
        function SetCheckValue(lineNo) {
            $('input[type=checkbox][id$="SearchConditions.DcAllocations[' + lineNo + '].CheckedValue"]').each(function (i, item) {
                $(item).trigger('click');
                });
        }
        function AllocationNameBlur() {
            var msgAllocationName = '#msgAllocationName';
            var idAllocationName = '#txtAllocationName';
                    $(msgAllocationName).html("")
                    $(msgAllocationName).removeClass("field-validation-error")
                    $(idAllocationName).removeClass("input-validation-error")
        }
        function TimeBlur() {
            var idFromtime = '#SearchConditions_AllocTimeFrom';
            var idTotime = '#SearchConditions_AllocTimeTo';
            var msgFromtime = '#AllocTimeFromMessage';
            var msgTotime = '#AllocTimeToMessage';

            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                if (!IsTime($(idFromtime).val().replace(":",""))) {
                    $(msgFromtime).html('<span id="AllocTimeFromError" class="">'+'@DcAllocationResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="AllocTimeToError" class="">'+'@DcAllocationResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
        }
        function byteLength(str) {
            var len = 0;
            for (var i=0; i<str.length; i++) {
             var c = str.charCodeAt(i);
             if ((c >= 0x0001 && c <= 0x007e) || (0xff60<=c && c<=0xff9f)) {
               len++;
             }
             else {
              len+=2;
             }
            }
            return len;
        }
        function ConditionsCheck(mod) {
            var msgAllocationName = '#msgAllocationName';
            var idAllocationName = '#txtAllocationName';
            var iddateFrom = '#SearchConditions_AllocDateFrom';
            var iddateTo = '#SearchConditions_AllocDateTo';
            var idFromtime = '#SearchConditions_AllocTimeFrom';
            var idTotime = '#SearchConditions_AllocTimeTo';
            var msgdateFrom = '#AllocDateFromMessage';
            var msgdateTo = '#AllocDateToMessage';
            var msgFromtime = '#AllocTimeFromMessage';
            var msgTotime = '#AllocTimeToMessage';
            var idSlipDate = '#ddlSlipDate';
            var msgSlipDate = '#SlipDateMessage';

            if (mod=='upd') {
                if ($(idAllocationName).val()=="") {
                    $(msgAllocationName).html('<span id="AllocationNameError" class="">'+'@DcAllocationResource.AllocationNmRequired' +'</span>');
                    $(msgAllocationName).addClass("field-validation-error");
                    $(idAllocationName).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgAllocationName).html("")
                    $(msgAllocationName).removeClass("field-validation-error")
                    $(idAllocationName).removeClass("input-validation-error")
                }
                if ($(idAllocationName).val()!="" && byteLength($(idAllocationName).val()) > 40) {
                    $(msgAllocationName).html('<span id="AllocationNameError" class="">'+'@DcAllocationResource.AllocationNmMaxLength' +'</span>');
                    $(msgAllocationName).addClass("field-validation-error");
                    $(idAllocationName).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgAllocationName).html("")
                    $(msgAllocationName).removeClass("field-validation-error")
                    $(idAllocationName).removeClass("input-validation-error")
                }

                if ($(idSlipDate).val()=="") {
                    $(msgSlipDate).html('<span id="SlipDateError" class="">'+'@DcAllocationResource.SlipDateRequired' +'</span>');
                    $(msgSlipDate).addClass("field-validation-error");
                    $(idSlipDate).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgSlipDate).html("")
                    $(msgSlipDate).removeClass("field-validation-error")
                    $(idSlipDate).removeClass("input-validation-error")
                }
            }

            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                if (!IsTime($(idFromtime).val().replace(":",""))) {
                    $(msgFromtime).html('<span id="AllocTimeFromError" class="">'+'@DcAllocationResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="AllocTimeToError" class="">'+'@DcAllocationResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(iddateFrom).val()=="" && $(idFromtime).val()!="") {
                $(msgdateFrom).html('<span id="SearchConditions_AllocDateFrom_error" class="">'+'@DcAllocationResource.ErrNoDate' +'</span>');
                $(msgdateFrom).addClass("field-validation-error");
                $(iddateFrom).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateFrom).html("")
                $(msgdateFrom).removeClass("field-validation-error")
                $(iddateFrom).removeClass("input-validation-error")
            }
            if ($(iddateTo).val()=="" && $(idTotime).val()!="") {
                $(msgdateTo).html('<span id="SearchConditions_AllocDateTo_error" class="">'+'@DcAllocationResource.ErrNoDate' +'</span>');
                $(msgdateTo).addClass("field-validation-error");
                $(iddateTo).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateTo).html("")
                $(msgdateTo).removeClass("field-validation-error")
                $(iddateTo).removeClass("input-validation-error")
            }
                var date1 = $(iddateFrom).val().replace(/\//g, "");
                var date2 = $(iddateTo).val().replace(/\//g, "");
                var time1 = $(idFromtime).val().replace(/\:/g, "");
                var time2 = $(idTotime).val().replace(/\:/g, "");
                var msg = "@String.Format(MessagesResource.ERR_DATE_MINMAX, DcAllocationResource.AllocDateTimeFrom, DcAllocationResource.AllocDateTimeTo)";
            if (!(validateDate.checkDate(date1, time1, date2, time2, "SearchConditions_AllocDateFrom", "SearchConditions.AllocDateFrom", msg))) return false;
            return true;
        }
