                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocDateFrom, new { htmlAttributes = new { tabindex = "2", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocTimeFrom, new { htmlAttributes = new { tabindex = "3", @placeholder = "", @class = "time_input", @onblur = "TimeBlur();" } })
                        </span>
                        -
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocDateTo, new { htmlAttributes = new { tabindex = "4", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.AllocTimeTo, new { htmlAttributes = new { tabindex = "5", @placeholder = "", @class = "time_input", @onblur = "TimeBlur();" } })
                        </span>
                    </div>
                    <div>
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocDateFrom, "", new { id = "AllocDateFromMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocTimeFrom, "", new { id = "AllocTimeFromMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocDateTo, "", new { id = "AllocDateToMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.AllocTimeTo, "", new { id = "AllocTimeToMessage" })
                    </div>
                </td>
                <td class="tdtitle">@DcAllocationResource.Brand</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.BrandId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtBrandId", tabindex = "17" } })
                    @Html.EditorFor(model => model.SearchConditions.BrandName, new { htmlAttributes = new { @class = "w_18_normal", @id = "txtBrandName", tabindex = "18" } })
                    <div class="search">
                        <button type="button" id="btnBrandId" class="search_btn" tabindex="19" />
                    </div>
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.ShipPlanDate</td>
                <td>
                    <div class="sortarea" style="width:600px;">
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.ShipPlanDateFrom, new { htmlAttributes = new { tabindex = "6", @placeholder = "", @class = "startDate flatpickr", @style = "height:30px;" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        -
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.ShipPlanDateTo, new { htmlAttributes = new { tabindex = "7", @placeholder = "", @class = "endDate flatpickr", @style = "height:30px;" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                    </div>
                    <div>
                        @Html.ValidationMessageFor(model => model.SearchConditions.ShipPlanDateFrom, "", new { })
                        @Html.ValidationMessageFor(model => model.SearchConditions.ShipPlanDateTo, "", new { })
                    </div>
                </td>
                <td class="tdtitle">@DcAllocationResource.MainVendor</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.MainVendorId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtMainVendorId", tabindex = "20" } })
                    @Html.EditorFor(model => model.SearchConditions.MainVendorName, new { htmlAttributes = new { @class = "w_18_normal", @id = "txtMainVendorName", tabindex = "21" } })
                    <div class="search">
                        <button type="button" id="btnMainVendor" class="search_btn" tabindex="22" />
                    </div>
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.DeliveryDate</td>
                <td>
                    <div class="sortarea" style="width:600px;">
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.DeliveryDate, new { htmlAttributes = new { tabindex = "8", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input", @style = "height:30px;" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                    </div>
                    <div>
                        @Html.ValidationMessageFor(model => model.SearchConditions.DeliveryDate, "", new { })
                    </div>
                </td>
                <td class="tdtitle">@DcAllocationResource.Category</td>
                <td colspan="4">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.CategoryId1,
                                (IEnumerable<SelectListItem>)ViewBag.Category1List,
                                CommonResource.None, new { id = "ddlCategoryId1", tabindex = "23", onchange = "CategoryChange(1)" })
                        </div>
                    </div>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.CategoryId2,
                                (IEnumerable<SelectListItem>)ViewBag.Category2List,
                                CommonResource.None, new { id = "ddlCategoryId2", tabindex = "24", disabled = "disabled", onchange = "CategoryChange(2)" })
                        </div>
                    </div>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.CategoryId3,
                                (IEnumerable<SelectListItem>)ViewBag.Category3List,
                                CommonResource.None, new { id = "ddlCategoryId3", tabindex = "25", disabled = "disabled", onchange = "CategoryChange(3)" })
                        </div>
                    </div>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.CategoryId4,
                                (IEnumerable<SelectListItem>)ViewBag.Category4List,
                                CommonResource.None, new { id = "ddlCategoryId4", tabindex = "26", disabled = "disabled" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.ShipToClass</td>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.GeneralDropDownFor(
                                model => model.SearchConditions.ShipToClass
                                , "STORE_CLASS", Model.SearchConditions.CenterId
                                , CommonResource.None, new { @class = "w_10_normal", @id = "txtShipToClass", tabindex = "9" })
                        </div>
                    </div>
                </td>
                <td class="tdtitle">@DcAllocationResource.ItemCode</td>
                <td colspan="2">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.ItemCode,
                                (IEnumerable<SelectListItem>)ViewBag.ItemList,
                                CommonResource.None, new { id = "ddlItemCode", tabindex = "27" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.ShipToId</td>
                <td>
                    <button type="button" class="btn btn-outline-dark" id="btnShipTo" tabindex="10" data-toggle="modal" data-flag="" data-target="#SyukkasakiModal" data-id="#txtShipToId" data-name="#txtShipToName">@DcAllocationResource.BtnShipToSelect</button><br />
                </td>
                <td class="tdtitle">@DcAllocationResource.ItemId</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.ItemId, new { htmlAttributes = new { @id = "txtItemId", tabindex = "28" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle"></td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.ShipToName, new { htmlAttributes = new { @class = "w_50_normal overflow", @id = "txtShipToName", tabindex = "11", @readonly = "readonly" } })
                    @Html.HiddenFor(model => model.SearchConditions.ShipToId, new { id = "txtShipToId" })
                </td>
                <td class="tdtitle">@DcAllocationResource.Jan</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.Jan, new { htmlAttributes = new { @id = "txtJan", tabindex = "29" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.TransporterId</td>
                <td>
                    <button type="button" class="btn btn-outline-dark" id="btnTransporter" tabindex="12">@DcAllocationResource.BtnTransporter</button><br />
                </td>
                <td class="tdtitle">@DcAllocationResource.ItemSkuId</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.ItemSkuId, new { htmlAttributes = new { @id = "txtItemSkuId", tabindex = "30" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle"></td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.TransporterName, new { htmlAttributes = new { @class = "w_50_normal overflow", @id = "txtTransporterName", tabindex = "13", @readonly = "readonly" } })
                    @Html.HiddenFor(model => model.SearchConditions.TransporterId, new { id = "txtTransporterId" })
                </td>
                <td class="tdtitle">@DcAllocationResource.ShipInstructId</td>
                <td>
                    <span>
                        @Html.EditorFor(model => model.SearchConditions.ShipInstructIdFrom, new { htmlAttributes = new { @class = "column_byte_20", @id = "txtShipInstructIdFrom", tabindex = "31" } })
                    </span>
                    <span>～</span>
                    <span>
                        @Html.EditorFor(model => model.SearchConditions.ShipInstructIdTo, new { htmlAttributes = new { @class = "column_byte_20", @id = "txtShipInstructIdTo", tabindex = "32" } })
                    </span>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.TransporterArea</td>
                <td>
                    <button type="button" class="btn btn-outline-dark" id="btnTransporterArea" tabindex="14">@DcAllocationResource.BtnTransporterArea</button>
                </td>
                <td class="tdtitle">@DcAllocationResource.EmergencyClass</td>
                <td colspan="4">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.GeneralDropDownFor(
                                model => model.SearchConditions.EmergencyClass
                                , "EMERGENCY_CLASS", Model.SearchConditions.CenterId
                                , CommonResource.None, new { @class = "w_10_normal", @id = "txtEmergencyClass", tabindex = "33" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle"></td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.TransporterAreaName, new { htmlAttributes = new { @class = "w_50_normal overflow", @id = "txtTransporterAreaName", tabindex = "15", @readonly = "readonly" } })
                    @Html.HiddenFor(model => model.SearchConditions.TransporterAreaName, new { id = "hideTransporterAreaName" })
                    @Html.HiddenFor(model => model.SearchConditions.TransporterArea, new { id = "txtTransporterArea" })
                </td>
                <td class="tdtitle">@DcAllocationResource.SalesClass</td>
                <td colspan="4">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.GeneralDropDownFor(
                                model => model.SearchConditions.SalesClass
                                , "SALE_CLASS", Model.SearchConditions.CenterId
                                , CommonResource.None, new { @class = "w_10_normal", @id = "ddlSalesClass", tabindex = "34" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td colspan="2"></td>
                <td colspan="3" class="bluecolor">
                    @DcAllocationResource.Comment
                </td>
            </tr>
            <tr>
                <td colspan="7">
                    <div class="sortarea">
                        <ul class="text-right">
                            <li>
                                <button type="button" id="btnAllocErrItemDownload" class="download" style="width:9vw" tabindex="35">
                                    <img src="~/Content/img/download.png" />
                                    @DcAllocationResource.BtnAllocErrItem
                                </button>
                            </li>
                            <li>
                                <button type="button" id="btnAllocErrShipInstructIdDownload" class="download" style="width:12vw" tabindex="36">
                                    <img src="~/Content/img/download.png" />
                                    @DcAllocationResource.BtnAllocErrShipInstructId
                                </button>
                            </li>
                        </ul>
                    </div>
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "DcAllocation", new { area = "Ship" }, new { type = "button", @class = "btn btn-outline-dark", tabindex = "37" })
                    <button class="btn btn-outline-dark" id="btnSearch" type="button" tabindex="38" onclick="Search();">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        <input type="hidden" name="SearchConditions.Page" id="hidPage" value="@Model.SearchConditions.Page" />
        @Html.HiddenFor(model => model.SearchConditions.SortKey, new { id = "hidSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.DetailSortKey, new { id = "hidDetailSortKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.ResultType, new { id = "hidResultType" })
        <input type="hidden" name="SearchConditions.Seq" id="hidSeq" value='@Model.SearchConditions.Seq' />
        <input type="hidden" name="SearchConditions.OldSeq" id="hidOldSeq" value='@Model.SearchConditions.OldSeq' />
        @Html.HiddenFor(model => model.SearchConditions.SearchType, new { id = "hidSearchType" })
        <input type="hidden" name="SearchConditions.DetailFlag" id="hidDetailFlag" value="@Model.SearchConditions.DetailFlag" />
        <input type="hidden" name="SearchConditions.CheckedStockoutFlag" id="hidCheckedStockoutFlag" value="0" />
        <div style="display:none">
            @if (Model.Results.DcAllocations != null && Model.Results.DcAllocations.Count() > 0)
            {
                <table>
                    @for (int i = 0; i < Model.Results.DcAllocations.Count; i++)
                    {
                        var id = String.Format("SearchConditions.DcAllocations[{0}].", i);
                        <tr>
                            <td class="template" hidden>
                                @Html.CheckBoxFor(modelItem => Model.Results.DcAllocations[i].IsCheck, new { @id = (id + "CheckedValue"), @class = "check-box", Name = id + "IsCheck" })
                                @Html.HiddenFor(modelItem => Model.Results.DcAllocations[i].Seq, new { @id = (id + "Seq"), Name = id + "Seq" })
                                @Html.HiddenFor(modelItem => Model.Results.DcAllocations[i].LineNo, new { @id = (id + "LineNo"), Name = id + "LineNo" })
                            </td>
                        </tr>
                    }
                </table>
            }
        </div>

    </div>

    <div class="message-area">
        @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
        @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
    </div>

    if (Model.Results.DcAllocations != null && Model.Results.DcAllocations.Count() > 0)
    {
        @* Sublbarea *@
        <div class="sublbarea no_border">
            <div class="btn-group btn-group-toggle" data-toggle="buttons">
                <label class="btn btn-outline-dark active" id="lblSku">
                    <input type="radio" name="options" id="Sku" autocomplete="off"> @DcAllocationResource.BtnItemSkuList
                </label>
                <label class="btn btn-outline-dark" id="lblDetail">
                    <input type="radio" name="options" id="Detail" autocomplete="off"> @DcAllocationResource.BtnInstructDetail
                </label>
            </div>
            <div class="sortarea mainpagearea">
                <ul>
                    <li>
                        @FormsResource.DISPLAY_SHORT
                        <div class="sort">
                            <div class="sort_inner">
                                @if (Model.SearchConditions.ResultType == Wms.Areas.Ship.ViewModels.DcAllocation.ResultTypes.Sku)
                                {
                                    @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                                }
                                else
                                {
                                    @Html.EnumDropDownListFor(model => model.SearchConditions.DetailSortKey, new { Name = "SearchConditions.DetailSortKey", @id = "ddlDetailSortKey", @onchange = "getSortData();" })
                                }
                            </div>
                        </div>
                    </li>
                    <li>
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                            </div>
                        </div>
                    </li>
                    <li class="totalcount">
                        @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.DcAllocations.TotalItemCount.ToString("N0"))
                    </li>
                </ul>
                @if (Model.Results.DcAllocations.Count() > 0)
                {
                    @Html.PagedListPager(Model.Results.DcAllocations, Page => Url.Action("Search", "DcAllocation", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
                }
            </div>
        </div>
        if (Model.Results.DcAllocations.Count() > 0)
        {
            <div class="sublbarea no_border stock_detail_head" style="height:100px">
                <table>
                    <tr>
                        <td class="tdtitle_large">
                            @DcAllocationResource.AllocationName
                            @Html.RequiredMark()
                        </td>
                        <td>
                            @Html.EditorFor(model => model.SearchConditions.AllocationName, new { htmlAttributes = new { @onblur = "AllocationNameBlur()", @class = "w_40_normal", @id = "txtAllocationName", tabindex = "39", @placeholder = @DcAllocationResource.AllocationNamePH } })
                            @Html.ValidationMessageFor(model => model.SearchConditions.AllocationName, "", new { id = "msgAllocationName" })
                        </td>
                        <td class="pl-4 pr-3">
                            @DcAllocationResource.SlipDate
                            @Html.RequiredMark()
                        </td>
                        <td>
                            <div>
                                <span class="date_input">
                                    @Html.EditorFor(model => model.SearchConditions.SlipDate, new { htmlAttributes = new { tabindex = "40", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input", @id = "ddlSlipDate" } })
                                    <span class="arrow">&nbsp;</span>
                                </span>
                            </div>
                            <div>
                                @Html.ValidationMessageFor(model => model.SearchConditions.SlipDate, "", new { id = "SlipDateMessage" })
                            </div>
                        </td>
                        <td class="pl-4">
                            <label class="chklist">
                                @Html.CheckBoxFor(model => model.SearchConditions.ChkViaCenter, new { id = "chkChkViaCenter", tabindex = "41", @placeholder = "", @class = "check-box" })
                                <span class="chk_parts">
                                </span>
                            </label>
                            @DcAllocationResource.ChkViaCenter
                        </td>
                    </tr>
                    <tr>
                        <td class="tdtitle">@DcAllocationResource.PickKind</td>
                        <td>
                            @Html.EnumRadioButtonListFor(model => model.SearchConditions.PickKind, new { @id = "radioPickKind", name = "radioPickKind", onclick = "clickPickKind();" })
                        </td>
                        <td class="pl-4">
                            <label class="chklist">
                                @Html.CheckBoxFor(model => model.SearchConditions.IsTotalPicked, new { id = "chkIsTotalPicked", tabindex = "42", @placeholder = "", @class = "check-box" })
                                <span class="chk_parts">
                                </span>
                            </label>
                            @DcAllocationResource.IsToralPicked
                        </td>
                    </tr>
                </table>
            </div>
            <div class="sublbarea no_border stock_detail_head" style="height:40px">
                <div class="sortarea">
                    <ul>
                        @if (Model.SearchConditions.ResultType == Wms.Areas.Ship.ViewModels.DcAllocation.ResultTypes.Sku)
                        {
                            <li>
                                @DcAllocationResource.ShipInstructIdSum @Html.DisplayFor(model => model.SearchConditions.InstructIdSum)
                            </li>
                        }
                        <li>
                            @DcAllocationResource.ItemSkuSum @Html.DisplayFor(model => model.SearchConditions.ItemSkuSum)
                        </li>
                        @if (Model.SearchConditions.ResultType == Wms.Areas.Ship.ViewModels.DcAllocation.ResultTypes.Detail)
                        {
                            <li>
                                @DcAllocationResource.DetailQtySum @Html.DisplayFor(model => model.SearchConditions.DetailSum)
                            </li>
                        }
                        <li>
                            @DcAllocationResource.PlanQtySum @Html.DisplayFor(model => model.SearchConditions.PlanQtySum)
                        </li>
                    </ul>
                </div>
            </div>
        }
    }
}
@if (Model.Results.DcAllocations != null)
{

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.DcAllocations.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:69vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">&nbsp;</th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.ShipPlanDateD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.EmergencyClassD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.ShipInstructIdD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.InstructClassD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.SalesClassD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.OffRateD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.ItemD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.ItemColorD
                                </th>
                                <th class="bg-grey align-middle">
                                    @DcAllocationResource.ItemSizeD
                                </th>
                                @if (Model.SearchConditions.ResultType == Wms.Areas.Ship.ViewModels.DcAllocation.ResultTypes.Sku)
                                {
                                    <th class="bg-grey align-middle">
                                        @DcAllocationResource.JanD
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @DcAllocationResource.ShipToQtyD
