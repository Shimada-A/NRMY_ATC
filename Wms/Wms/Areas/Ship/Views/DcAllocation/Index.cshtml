                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.InstructClass</td>
                <td>
                    @Html.EnumRadioButtonListFor(model => model.SearchConditions.InstructKbn)
                </td>
                <td class="tdtitle">@DcAllocationResource.DivisionId</td>
                <td colspan="2">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.DivisionId,
                                (IEnumerable<SelectListItem>)ViewBag.DivisionList,
                                CommonResource.None, new { id = "ddlDivisionId", tabindex = "16" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
            </tr>
            <tr>
                <td class="tdtitle">@DcAllocationResource.AllocDateTime</td>
                <td>
