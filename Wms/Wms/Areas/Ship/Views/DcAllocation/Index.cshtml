                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
                deliareaGroupSearchModal.init();
                transporterSearchModal.init();
                curentSelectedCnt = $(DcAllocationView.SELECTORS.chkCheckedInTable).length;
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Stop event fired when click to checkbox
                 */
                $(DcAllocationView.SELECTORS.chkLabel).click(function (evt) {
                    evt.stopPropagation();
                });

                /**
                 * Check box click
                 */
                $(DcAllocationView.SELECTORS.chkInTable).click(function (evt) {
                    evt.stopPropagation();
                    curentSelectedCntDiff = curentSelectedCnt - $(DcAllocationView.SELECTORS.chkCheckedInTable).length;
                    DcAllocationView.setButtonStatus(curentSelectedCntDiff);
                });

                /**
                * Dropdownlist change item
                */
                $(DcAllocationView.SELECTORS.ddlSort).change(function (val) {
                    $(DcAllocationView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(DcAllocationView.SELECTORS.ddlSortKey).change(function (val) {
                    $(DcAllocationView.SELECTORS.btnSearch).click();
                });

                /**
                 * Dropdownlist change item
                 */
                $(DcAllocationView.SELECTORS.ddlDetailSortKey).change(function (val) {
                    $(DcAllocationView.SELECTORS.btnSearch).click();
