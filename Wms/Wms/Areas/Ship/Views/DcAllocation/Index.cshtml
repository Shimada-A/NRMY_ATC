@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Ship.Resources;
@using Wms.Areas.Ship.ViewModels.DcAllocation;
@model Wms.Areas.Ship.ViewModels.DcAllocation.DcAllocationViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_SHP_DcAllocation01;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
@Html.Partial("_WaitDialog")
@using (Html.BeginForm("Search", "DcAllocation", FormMethod.Post, new { id = "frmSearch" }))
{
    <div id="div_search" class="head head_white collapse">
        @Html.AntiForgeryToken()
        <table>
            <tr>
