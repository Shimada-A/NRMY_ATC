@model List<Wms.Areas.Styleguide.Models.CheckList>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@using (Html.BeginForm("Edit", "CheckBox"))
{

<div class="head head_white">
    <div class="pgtitlearea">
        <h1>CheckBox</h1>
        <p class="pg_caption">CheckBoxの使い方</p>
    </div>
</div>

<div class="container">
    <div class="content of">
        <h3>タイトル</h3>
        <div class="mtop20">
            @* foreachの場合 *@
            @{ var i = 0;}
            @foreach (var list in Model)
                {
            <label>
                @Html.EditorFor(item => list.IsCheck, "", $"model[{i++}].IsCheck")
                <span class="chk_parts">@list.Name </span>
            </label>
                }

            @* forの場合 *@
            @*@for (int i = 0; i < Model.Count(); i++)
                {
                    <label>
                        @Html.CheckBoxFor(model => model[i].IsCheck, new { @class = "check-box" })
                        <span class="chk_parts">@Html.TextBoxFor(model => model[i].Name)</span>
                    </label>
                }*@
        </div>
        <div class="codearea">
            <p>
                Should use @@CheckBoxFor. Don't use @@EditorFor.<br />
                Should not create by Enum.<br />
                Enumから生成するとモデルバインドできないためクラスのコレクションを使う。
            </p>
        </div>
    </div>
    <button type="submit" class="btn btn1">送信</button>
</div>
}