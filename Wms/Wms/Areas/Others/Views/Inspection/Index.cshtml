@using Share.Common;
@using PagedList.Mvc;
@using Wms.Areas.Others.Resources;
@using Wms.Helpers;
@model Wms.Areas.Others.ViewModels.Inspection.InspectionViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_OTH_Inspection;
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Inspection", FormMethod.Post, new { id = "frmSearch", @class = "show_scroll" }))
    {
        @Html.AntiForgeryToken()
        <table>
            <tr>
                <td class="tdtitle">@InspectionResource.LCenterId</td>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.CenterDropDownFor(
                                model => model.SearchConditions.CenterId
                                , Wms.Common.Profile.User.UserId
                                , "", new { @id = "ddlCenterId", tabindex = "1" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@InspectionResource.LMakeDate</td>
                <td>
                    <div class="sortarea" style="width:600px;">
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.MakeDateFrom, new { htmlAttributes = new { tabindex = "2", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.MakeTimeFrom, new { htmlAttributes = new { tabindex = "3", @placeholder = "", @class = "time_input", @onblur = "TimeBlur();"} })
                        </span>
                        -
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.MakeDateTo, new { htmlAttributes = new { tabindex = "4", @placeholder = "", @class = "flatpickr flatpickr_single flatpickr-input" } })
                            <span class="arrow">&nbsp;</span>
                        </span>
                        <span class="date_input">
                            @Html.EditorFor(model => model.SearchConditions.MakeTimeTo, new { htmlAttributes = new { tabindex = "5", @placeholder = "", @class = "time_input", @onblur = "TimeBlur();" } })
                        </span>
                    </div>
                    <div>
                        @Html.ValidationMessageFor(model => model.SearchConditions.MakeDateFrom, "", new { id = "MakeDateFromMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.MakeTimeFrom, "", new { id = "MakeTimeFromMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.MakeDateTo, "", new { id = "MakeDateToMessage" })
                        @Html.ValidationMessageFor(model => model.SearchConditions.MakeTimeTo, "", new { id = "MakeTimeToMessage" })
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle_large">@InspectionResource.LProcessingId</td>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.GeneralDropDownFor(
                                model => model.SearchConditions.ProcessingId
                                     , "PROCESSING_ID", Model.SearchConditions.CenterId
                                , CommonResource.None, new { @class = "w_10_normal", @id = "txtProcessingId", tabindex = "6" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@InspectionResource.LMakeUserId</td>
                <td>
                    @Html.EditorFor(model => model.SearchConditions.MakeUserId, new { htmlAttributes = new { @id = "txtMakeUserId", tabindex = "7" } })
                </td>
            </tr>
            <tr>
                <td colspan="2" class="text-right">
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "Inspection", new { area = "Others" }, new { type = "button", @class = "btn btn-outline-dark" })
                    <button class="btn btn-outline-dark head-btn" onclick="btnSearch();">@Share.Common.Resources.FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>

    }
</div>
@if (Model.Results.Inspections != null)
{
    <div class="sublbarea no_border">
        <div class="sortarea mainpagearea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.Inspections.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.Results.Inspections.Count() > 0)
            {
                @Html.PagedListPager(Model.Results.Inspections, Page => Url.Action("Search", "Inspection", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>
}
@* Container *@
<div class="Container">

    @* Content
        @if (Model.Results.Inspections.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:70vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">
                                    &nbsp;
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.No
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.MakeDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.MakeUserId
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.WorkContent
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.ProCessingDetail
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.Item
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.Color
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.Size
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.Jan
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.LoccationCd
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.ResultQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.ShipToStoreId
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.BoxNo
                                </th>
                                <th class="bg-grey align-middle">
                                    @InspectionResource.BoxNo2
                                </th>
                                <th hidden>
                                </th>
                            </tr>

                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Update", "Inspection", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.Inspections.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("Inspections[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.Results.Inspections.PageNumber - 1) * Model.Results.Inspections.PageSize)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.MakeDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.MakeUserId)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.WorkContent)
                                        </td>
                                        <td class="align-middle text-left">
                                            @Html.DisplayFor(modelItem => cModel.v.ProCessingDetail)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ColorId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ColorName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.SizeId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.SizeName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.Jan)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.LoccationCd)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ShipToStoreId)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.BoxNo)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.BoxNo2)
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }*@
</div>
}
@* スクリプト *@
@section LayoutScripts{
    <script>

        // 日時チェック
        function IsDate(value) {
            value = value.replace(/\//g, "-");
            return value.match(/^(?:(?!0000)[0-9]{4}-(?:(?:0[1-9]|1[0-2])-(?:0[1-9]|1[0-9]|2[0-8])|(?:0[13-9]|1[0-2])-(?:29|30)|(?:0[13578]|1[02])-31)|(?:[0-9]{2}(?:0[48]|[2468][048]|[13579][26])|(?:0[48]|[2468][048]|[13579][26])00)-02-29)$/);
        }
        function IsTime(value) {
            value = value.replace(":", "");
            return value.match(/^([01][0-9]|2[0-3])([0-5][0-9])([0-5][0-9])$/);
        }

        function ConditionsCheck(mod) {
            var iddateFrom = '#SearchConditions_MakeDateFrom';
            var iddateTo = '#SearchConditions_MakeDateTo';
            var idFromtime = '#SearchConditions_MakeTimeFrom';
            var idTotime = '#SearchConditions_MakeTimeTo';
            var msgdateFrom = '#MakeDateFromMessage';
            var msgdateTo = '#MakeDateToMessage';
            var msgFromtime = '#MakeTimeFromMessage';
            var msgTotime = '#MakeTimeToMessage';

            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                if (!IsTime($(idFromtime).val().replace(":",""))) {
                    $(msgFromtime).html('<span id="MakeTimeFromError" class="">'+'@InspectionResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="MakeTimeToError" class="">'+'@InspectionResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(iddateFrom).val()=="" && $(idFromtime).val()!="") {
                $(msgdateFrom).html('<span id="SearchConditions_MakeDateFrom_error" class="">'+'@InspectionResource.ErrNoDate' +'</span>');
                $(msgdateFrom).addClass("field-validation-error");
                $(iddateFrom).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateFrom).html("")
                $(msgdateFrom).removeClass("field-validation-error")
                $(iddateFrom).removeClass("input-validation-error")
            }
            if ($(iddateTo).val()=="" && $(idTotime).val()!="") {
                $(msgdateTo).html('<span id="SearchConditions_MakeDateTo_error" class="">'+'@InspectionResource.ErrNoDate' +'</span>');
                $(msgdateTo).addClass("field-validation-error");
                $(iddateTo).addClass("input-validation-error");
                return false;
            } else {
                $(msgdateTo).html("")
                $(msgdateTo).removeClass("field-validation-error")
                $(iddateTo).removeClass("input-validation-error")
            }
                var date1 = $(iddateFrom).val().replace(/\//g, "");
                var date2 = $(iddateTo).val().replace(/\//g, "");
                var time1 = $(idFromtime).val().replace(/\:/g, "");
                var time2 = $(idTotime).val().replace(/\:/g, "");
                var msg = "@String.Format(MessagesResource.ERR_DATE_MINMAX, InspectionResource.MakeDateTimeFrom, InspectionResource.MakeDateTimeTo)";
            if (!(validateDate.checkDate(date1, time1, date2, time2, "SearchConditions_MakeDateFrom", "SearchConditions.MakeDateFrom", msg))) return false;
            return true;
        }

        function TimeBlur() {
            var idFromtime = '#SearchConditions_MakeTimeFrom';
            var idTotime = '#SearchConditions_MakeTimeTo';
            var msgFromtime = '#MakeTimeFromMessage';
            var msgTotime = '#MakeTimeToMessage';



            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {

                if (!IsTime($(idFromtime).val().replace(":", ""))) {

                    

                    $(msgFromtime).html('<span id="MakeTimeFromError" class="">'+'@InspectionResource.ErrTime' +'</span>');
                    $(msgFromtime).addClass("field-validation-error");
                    $(idFromtime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgFromtime).html("")
                    $(msgFromtime).removeClass("field-validation-error")
                    $(idFromtime).removeClass("input-validation-error")
                }
            }

            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                if (!IsTime($(idTotime).val().replace(":",""))) {
                    $(msgTotime).html('<span id="MakeTimeToError" class="">'+'@InspectionResource.ErrTime' +'</span>');
                    $(msgTotime).addClass("field-validation-error");
                    $(idTotime).addClass("input-validation-error");
                    return false;
                } else {
                    $(msgTotime).html("")
                    $(msgTotime).removeClass("field-validation-error")
                    $(idTotime).removeClass("input-validation-error")
                }
            }
            var str = "";
            if ($(idFromtime).val() != "" && $(idFromtime).val() != undefined) {
                str = $(idFromtime).val().replace(":", "").replace(":", "");
                $(idFromtime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
            if ($(idTotime).val() != "" && $(idTotime).val() != undefined) {
                str = $(idTotime).val().replace(":", "").replace(":", "");
                $(idTotime).val(str.length == 6 ? (str.substring(0, 2) + ":" + str.substring(2, 4) + ":" + str.substring(4, 6)) : str);
            }
        }

        // submit
        function btnSearch() {

            ConditionsCheck('search')
            if (ConditionsCheck('search')) {
                var urlAction = '@Url.Action("Search", "Inspection", new { area = "Others" })';
                var $form = $("#frmSearch");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
            }
        };


    </script>
}