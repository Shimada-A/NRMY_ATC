                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (Model.SearchConditions.SearchKind == WorkingReferenceSearchConditions.SearchKinds.Store)
                {
                    <div class="tb_scroll" style="height:59vh;">
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey align-middle">
