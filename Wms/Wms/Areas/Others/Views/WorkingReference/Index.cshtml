@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Others.Resources;
@using Wms.Areas.Others.ViewModels.WorkingReference;
@model Wms.Areas.Others.ViewModels.WorkingReference.WorkingReferenceViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_STK_WorkingReference;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@Styles.Render("~/bundles/FileUploadCss")
@* Head *@
@using (Html.BeginForm("Search", "WorkingReference", FormMethod.Post, new { id = "frmSearch" }))
{
    <div id="div_search" class="head head_white collapse">
        @Html.AntiForgeryToken()
        <table>
            <colgroup>
                <col class="tdtitle" />
                <col width="1000px" />
                <col class="tdtitle_large" />
            </colgroup>
            <tr>
                <td class="tdtitle">@WorkingReferenceResource.CenterIdS : </td>
                <td>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.CenterDropDownFor(
                                model => model.SearchConditions.CenterId
                                , Wms.Common.Profile.User.UserId
                                , "", new { @id = "ddlCenterId", tabindex = "1", @onchange = "getCenterId();" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@WorkingReferenceResource.SearchKind :</td>
                <td>
                    @Html.RadioButtonFor(model => model.SearchConditions.SearchKind, 1, new { @checked = "checked", tabindex = "2", @class = "radio_input _pm", style = "display:inherit;" })
                    <span class="radio_txt">@WorkingReferenceResource.Shiire</span>
                    @Html.RadioButtonFor(model => model.SearchConditions.SearchKind, 2, new { tabindex = "3", @class = "radio_input _pm", style = "display:inherit;" })
                    <span class="radio_txt">@WorkingReferenceResource.Ido</span>
                </td>
            </tr>
            <tr>
                <td class="tdtitle"></td>
                <td>
                    @Html.RadioButtonFor(model => model.SearchConditions.SearchKind, 3, new { tabindex = "4", @class = "radio_input _pm", style = "display:inherit;" })
                    <span class="radio_txt">@WorkingReferenceResource.Pic</span>
                    @Html.RadioButtonFor(model => model.SearchConditions.SearchKind, 4, new { tabindex = "5", @class = "radio_input _pm", style = "display:inherit;" })
                    <span class="radio_txt">@WorkingReferenceResource.Store</span>
                    @Html.RadioButtonFor(model => model.SearchConditions.SearchKind, 5, new { tabindex = "6", @class = "radio_input _pm", style = "display:inherit;" })
                    <span class="radio_txt">@WorkingReferenceResource.Stock</span>
                </td>
            </tr>
            <tr>
                <td colspan="2" class="alignright">
                    @Html.ActionLink(FormsResource.BTN_CLEAR, "Index", "WorkingReference", new { area = "Others" }, new { type = "button", @class = "btn btn-outline-dark" })
                    <button class="btn btn-outline-dark" id="btnSearch" tabindex="7" onclick="Search();">@FormsResource.BTN_SEARCH</button>
                </td>
            </tr>
        </table>
        <input type="hidden" name="page" id="page" value="" />
        @Html.HiddenFor(model => model.SearchConditions.ShiireKey, new { id = "hidShiireKey" })
        @Html.HiddenFor(model => model.SearchConditions.IdoKey, new { id = "hidIdoKey" })
        @Html.HiddenFor(model => model.SearchConditions.PicKey, new { id = "hidPicKey" })
        @Html.HiddenFor(model => model.SearchConditions.StoreKey, new { id = "hidStoreKey" })
        @Html.HiddenFor(model => model.SearchConditions.StockKey, new { id = "hidStockKey" })
        @Html.HiddenFor(model => model.SearchConditions.Sort, new { id = "hidSort" })
        @Html.HiddenFor(model => model.SearchConditions.SearchType, new { id = "hidSearchType" })
        @Html.HiddenFor(model => model.SearchConditions.InvoiceNo, new { id = "hidInvoiceNo" })
        @Html.HiddenFor(model => model.SearchConditions.ItemSkuId, new { id = "hidItemSkuId" })
        @Html.HiddenFor(model => model.SearchConditions.SlipNo, new { id = "hidSlipNo" })
        @Html.HiddenFor(model => model.SearchConditions.BoxNo, new { id = "hidBoxNo" })
        @Html.HiddenFor(model => model.SearchConditions.HaitaSeq, new { id = "hidHaitaSeq" })
        <input type="hidden" name="SearchConditions.Seq" id="hidSeq" value="@Model.SearchConditions.Seq" />
        <input type="hidden" name="SearchConditions.Page" id="hidPage" value="@Model.SearchConditions.Page" />
        <input type="hidden" name="SearchConditions.SearchKind" id="hidSearchKind" value="@Model.SearchConditions.SearchKind" />
    </div>
}
<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.Results.WorkingReferences != null && Model.Results.WorkingReferences.Count() > 0 && Model.SearchConditions.SearchKind == WorkingReferenceSearchConditions.SearchKinds.Shiire)
{
    @* Sublbarea *@
    <div class="sublbarea no_border">
        <div class="sortarea mainpagearea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.ShiireKey, new { Name = "SearchConditions.ShiireKey", @id = "ddlShiireKey", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.WorkingReferences.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.Results.WorkingReferences.Count() > 0)
            {
                @Html.PagedListPager(Model.Results.WorkingReferences, Page => Url.Action("Search", "WorkingReference", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>
}
