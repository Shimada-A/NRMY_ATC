@if (Model.Results.WorkingReferences != null)
{
    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.WorkingReferences.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                @if (Model.SearchConditions.SearchKind == WorkingReferenceSearchConditions.SearchKinds.Shiire)
                {
                    <div class="tb_scroll" style="height:59vh;">
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey align-middle">&nbsp;</th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.No
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.StartDate
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.WorkUser
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.WorkMachine
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.InvoiceNo
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.ItemIdName
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.Color
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.Size
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.Jan
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cModel in Model.Results.WorkingReferences.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("WorkingReferences[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck(1,'@(cModel.v.InvoiceNo)','@(cModel.v.ItemSkuId)')" />
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                        </td>
                                        <td class="align-middle  w_no">
                                            @Html.DisplayFor(modelItem => cModel.v.LineNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StartDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.WorkUserId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.WorkUserName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TerminalInfo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.InvoiceNo)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemColorId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemColorName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSizeId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSizeName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.Jan)
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.InvoiceNo, new { Name = key + "InvoiceNo" })
                                            @Html.HiddenFor(modelItem => cModel.v.ItemSkuId, new { Name = key + "ItemSkuId" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                            @Html.HiddenFor(modelItem => cModel.v.CenterId, new { Name = key + "CenterId" })
                                            @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (Model.SearchConditions.SearchKind == WorkingReferenceSearchConditions.SearchKinds.Ido)
                {
                    <div class="tb_scroll" style="height:59vh;">
                        <table class="table table-bordered" id="listData">
                            <thead>
                                <tr>
                                    <th class="bg-grey align-middle">&nbsp;</th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.No
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.StartDate
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.WorkUser
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.SlipNo
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.TransferClass
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.TransFromStoreClass
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.TransFromStoreName
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.PlanQty
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @WorkingReferenceResource.ResultQty
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cModel in Model.Results.WorkingReferences.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("WorkingReferences[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck(2,'@(cModel.v.SlipNo)','@(cModel.v.HaitaSeq)')" />
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                        </td>
                                        <td class="align-middle  w_no">
                                            @Html.DisplayFor(modelItem => cModel.v.LineNo)
