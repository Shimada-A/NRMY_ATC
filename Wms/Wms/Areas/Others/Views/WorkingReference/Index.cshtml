                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.StartDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.WorkUserId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.WorkUserName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipNo)
                                        </td>
                                        <td class="align-middle">
                                            @if (cModel.v.TransferClass == 1)
                                            {
                                                @WorkingReferenceResource.BaseMove
                                            }
                                            else
                                            {
                                                @WorkingReferenceResource.StoreReturn
                                            }
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransFromStoreClass)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransferFromStoreName)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ArrivePlanQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.SlipNo, new { Name = key + "SlipNo" })
                                            @Html.HiddenFor(modelItem => cModel.v.UpdateCount, new { Name = key + "UpdateCount" })
                                            @Html.HiddenFor(modelItem => cModel.v.CenterId, new { Name = key + "CenterId" })
                                            @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                            @Html.HiddenFor(modelItem => cModel.v.HaitaSeq, new { Name = key + "HaitaSeq" })
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
