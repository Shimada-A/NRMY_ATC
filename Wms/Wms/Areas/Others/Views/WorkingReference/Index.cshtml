@Html.Partial("_ErrorMessageDialog", new Wms.Models.MessageDialog() { Id = "ErrMsg", Message = (string)ViewBag.ErrorMessage })
@** スクリプト *@
@section LayoutScripts{
    @Scripts.Render("~/bundles/FileUpload")
    <script>
    Dropzone.autoDiscover = false;
        $(document).ready(function () {
            if ('@ViewBag.Status' != '@ProcedureStatus.Success' && '@ViewBag.Status' != '') {
                $("#btnErrorMessage").click();
            }
            $('#btnDetails').attr('disabled', 'disabled');
            $('#btnDelete').attr('disabled', 'disabled');
            clearCheckBox();
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var $form = $("#frmSearch");
                var urlAction ='@Url.Action("Search", "WorkingReference", new { area= "Others" })';
                var pageUrl = urlAction + '?Page=';
                var page = $(item).attr("href").replace(pageUrl, "");
                page = page.replace("&class=btn-outline-dark", "");
                $(item).attr("href", "javascript:void(0);").click(function () {
                    $("#hidPage").val(page);
                    $("#hidSearchType").val("SortPage");
                    $form.attr("action", urlAction);
                    $form.attr("method", "POST");
                    $form.submit();
                });
            });
        });
        // Sort
        function getSortData() {
            $("#hidSort").val($("#ddlSort").val());
            if ($("#hidSearchKind").val() == '@WorkingReferenceSearchConditions.SearchKinds.Shiire') {
                $("#hidShiireKey").val($("#ddlShiireKey").val());
            } else if ($("#hidSearchKind").val() == '@WorkingReferenceSearchConditions.SearchKinds.Ido') {
                $("#hidIdoKey").val($("#ddlIdoKey").val());
            } else if ($("#hidSearchKind").val() == '@WorkingReferenceSearchConditions.SearchKinds.Pic') {
                $("#hidPicKey").val($("#ddlPicKey").val());
            } else if ($("#hidSearchKind").val() == '@WorkingReferenceSearchConditions.SearchKinds.Stock') {
                $("#hidStockKey").val($("#ddlStockKey").val());
            } else {
                $("#hidStoreKey").val($("#ddlStoreKey").val());
            }
            $("#hidSearchType").val("SortPage");

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "WorkingReference", new { area= "Others" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function Search() {
                var urlAction = '@Url.Action("Search", "WorkingReference", new { area = "Others" })';
                var $form = $("#frmSearch");
                $("#hidPage").val(1);
                $("#hidSearchType").val("Search");
                $form.attr("action", urlAction);
                $form.attr("method", "POST");
                $form.submit();
        }

    $('#btnDelete').on("click", function () {
        if ($('#listData input[type=radio][id$=".CheckedValue"]:checked').length == 0) {
            alert("対象データを選択してください");
            return;
        };
            var urlAction = '@Url.Action("Delete", "WorkingReference", new { area = "Others" })';
            var $form = $("#frmSearch");
            $("#hidSearchType").val("Search");
            $form.attr("action", urlAction);
            $('#btnDeleteHidden').click();
        });

    $('#Confirm').on("click", function () {
        var urlAction ='@Url.Action("Delete", "WorkingReference", new { area = "Others" })';
        var $form = $("#frmSearch");
        $("#hidSearchType").val("Search");
        $form.attr("action", urlAction);
        $form.attr("method", "Post");
        $form.submit();
    });
    function SetIsCheck(kbn, param1, param2) {
        setCheckBox($(this).parents('td'));
        if (kbn == 1) {
            $("#hidInvoiceNo").val(param1);
            $("#hidItemSkuId").val(param2);
        } else if (kbn == 2) {
            $("#hidSlipNo").val(param1);
            $("#hidHaitaSeq").val(param2);
        } else {
            $("#hidBoxNo").val(param1);
            $("#hidHaitaSeq").val(param2);
        }
        $('#btnDelete').removeAttr('disabled');
    };

    const clearCheckBox = function () {
        $('#listData td .check-box').prop('checked', false);
        $('#listData td .radio_input').prop('checked', false);
        };

    const setCheckBox = function (selector) {
            $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
            selector.find('.check-box').prop('checked', true);
            selector.find('.radio_input').prop('checked', true);
        };
    </script>
}
