</div>

<div class="message-area">
    @Html.Partial("_InformationMessageContent", TempData[AppConst.SUCCESS] ?? "")
    @Html.Partial("_ErrorMessageContent", TempData[AppConst.ERROR] ?? "")
</div>

@if (Model.Results.TransferReference01s != null)
{
    if (Model.Results.TransferReference01s.Count() > 0)
    {
        @* Sublbarea *@
        <div class="sublbarea no_border stock_detail_load">
            <div class="sortarea">
                <ul>
                    <li>
                        <button type="button" id="btnDownload" class="download">
                            <img src="~/Content/img/download.png" />
                            @FormsResource.BTN_DOWNLOAD
                        </button>
                    </li>
                </ul>
            </div>
        </div>
        <div class="sublbarea no_border">
            <div class="sortarea mainpagearea">
                <ul>
                    <li>
                        @FormsResource.DISPLAY_SHORT
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.EnumDropDownListFor(model => model.SearchConditions.SortKey, new { Name = "SearchConditions.SortKey", @id = "ddlSortKey", @onchange = "getSortData();" })
                            </div>
                        </div>
                    </li>
                    <li>
                        <div class="sort">
                            <div class="sort_inner">
                                @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                            </div>
                        </div>
                    </li>
                    <li class="totalcount">
                        @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.TransferReference01s.TotalItemCount.ToString("N0"))
                    </li>
                </ul>
                @if (Model.Results.TransferReference01s.Count() > 0)
                {
                    @Html.PagedListPager(Model.Results.TransferReference01s, Page => Url.Action("Search", "TransferReference", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
                }
            </div>
        </div>
        <div class="sublbarea no_border stock_detail_head">
            <div class="sortarea">
                <ul>
                    <li>
                        @TransferReferenceResource.ItemSkuQtySum @Html.DisplayFor(model => model.SearchConditions.ItemSkuQtySum)
                    </li>
                    <li>
                        @TransferReferenceResource.ArrivePlanQtySum @Html.DisplayFor(model => model.SearchConditions.ArrivePlanQtySum)
                    </li>
                    <li>
                        @TransferReferenceResource.ResultQtySum @Html.DisplayFor(model => model.SearchConditions.ResultQtySum)
                    </li>
                    <li>
                        @TransferReferenceResource.SlipNoPlanQtySum @Html.DisplayFor(model => model.SearchConditions.SlipNoPlanQtySum)
                    </li>
                    <li>
                        @TransferReferenceResource.SlipNoResultQtySum @Html.DisplayFor(model => model.SearchConditions.SlipNoResultQtySum)
                    </li>
                </ul>
            </div>
        </div>
    }

    @* Container *@
    <div class="Container">

        @* Content *@
        @if (Model.Results.TransferReference01s.Count() == 0)
        {
            <div>
                <p>@Share.Common.Resources.MessagesResource.MSG_NOT_FOUND</p>
            </div>
        }
        else
        {
            <div>
                <div class="tb_scroll" style="height:65vh;">
                    <table class="table table-bordered" id="listData">
                        <thead>
                            <tr>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.No
                                </th>
                                @*<th class="bg-grey align-middle">
                                    @TransferReferenceResource.ArrivePlanDate
                                </th>*@
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.TransferClass
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.DenpyoDate
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.TransferFromStore
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.SlipNoPlanQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.SlipNoResultQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.ItemSkuQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.ArrivePlanQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.ResultQty
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.TransferStatus
                                </th>
                                <th class="bg-grey align-middle">
                                    @TransferReferenceResource.ConfirmDate
                                </th>
                                <th class="bg-grey align-middle">
                                </th>
                                <th hidden>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            @using (Html.BeginForm("Edit", "TransferReference", FormMethod.Post, new { id = "frmUpdate" }))
                            {
                                @Html.AntiForgeryToken()
                                foreach (var cModel in Model.Results.TransferReference01s.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("TransferReference01s[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle text-right w_no">
                                            @((cModel.i + 1) + (Model.Results.TransferReference01s.PageNumber - 1) * Model.Results.TransferReference01s.PageSize)
                                        </td>
                                        @*<td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ArrivePlanDate)
                                        </td>*@
                                        <td class="align-middle text-left">
                                            @switch (cModel.v.TransferClass)
                                            {
                                                case "1":
                                                    @TransferReferenceResource.BaseMove
                                                    break;
                                                case "2":
                                                    @TransferReferenceResource.StoreReturn
                                                    break;
                                                case "3":
                                                    @TransferReferenceResource.BaseMoveNoWmsCenter
                                                    break;
                                                default:
                                                    break;
                                            }
                                        </td>
                                        <td class="align-middle text-left">
                                            @Html.DisplayFor(modelItem => cModel.v.DenpyoDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransferFromStoreId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.TransferFromStoreName)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipNoPlanQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipNoResultQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemSkuQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ArrivePlanQty)
                                        </td>
                                        <td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.ResultQty)
                                        </td>
                                        <td class="align-middle text-left">
                                            @Html.DisplayFor(modelItem => cModel.v.TransferStatusName)
                                        </td>
                                        <td class="align-middle text-left">
                                            @Html.DisplayFor(modelItem => cModel.v.ConfirmDate)
                                        </td>
                                        <td class="align-middle">
                                            <button type="button" class="btn btn-dark btn-sm" onclick="Detail(@cModel.v.Seq,@cModel.v.LineNo,@cModel.v.UnplannedFlag)">@TransferReferenceResource.BtnDetail</button>
                                        </td>
                                        <td class="template" hidden>
                                            @Html.HiddenFor(modelItem => cModel.v.Seq, new { Name = key + "Seq" })
                                            @Html.HiddenFor(modelItem => cModel.v.LineNo, new { Name = key + "LineNo" })
                                            @Html.HiddenFor(modelItem => cModel.v.UnplannedFlag, new { Name = key + "UnplannedFlag" })
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div> }

@*Bottomnav*@
@section Basefooter{
    <div class="btnarea">
        @if (Model.Results.TransferReference01s != null && Model.Results.TransferReference01s.Count() > 0)
        {
            <button type="button" id="btnDetail" class="btn btn-dark btnsize" onclick="Detail(@Model.SearchConditions.Seq,'0')">@TransferReferenceResource.BtnDetailList</button>
        }
        else
        {
            <button type="button" id="btnDetail" class="btn btn-dark btnsize" disabled>@TransferReferenceResource.BtnDetailList</button>
        }
    </div>
}
@{
    var storeConditions = new ViewDataDictionary { { "ParameterStoreId", Model.SearchConditions.TransferFromStoreId }, { "TempStoreId", Model.SearchConditions.TransferFromStoreId } };
}
@Html.Partial("~/Areas/Master/Views/Shared/_BrandSearchModal.cshtml", "dialog")
@Html.Partial("~/Areas/Master/Views/Shared/_ColorSearchModal.cshtml")
