@section LayoutScripts{
    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")
    <script>
        $("#btnDownload").on("click", function () {
            var urlAction = '@Url.Action("TransferReference01Download", "TransferReference", new { area = "Move" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        });

        /**
         * Country class
         */
        var TransferReferenceView = {

            /**
             * CONST Object
             */
            CONST: {
                FORM_METHOD: 'formmethod',
                FORM_ACTION: 'formaction',
                POST: 'post',
                FORM: 'form',
                METHOD: 'method',
                ACTION: 'action'
            },

            /**
             * SELECTORS Object
             */
            SELECTORS: {
                chkInTable: '#listData input[type=checkbox][id$=".CheckedValue"]',
                chkCheckedInTable: '#listData input[type=checkbox][id$=".CheckedValue"]:checked',
                chkInRow: 'input[type=checkbox][class=check-box]',
                tblRow: '#listData tbody tr',
                btnDetail: '#btnDetail',
                ddlSortKey: '#ddlSortKey',
                form: 'form',
                searchForm: '#frmSearch',
                frmUpdate: 'frmUpdate',
                btnBrand: '#btnBrand',
                brandId:'#txtBrandId',
                brandName:'#txtBrandName',
                brandSelect: '#brandSelect',
                colorSelect: '#colorSelect',
                btnItemColor:'#btnItemColor',
                colorId:'#txtItemColorId',
                colorName:'#txtItemColorName',
                sizeSelect: '#sizeSelect',
                btnItemSize:'#btnItemSize',
                sizeId:'#txtItemSizeId',
                sizeName:'#txtItemSizeName',
            },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                colorSearchModal.init();
                sizeSearchModal.init();
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                * ブランド検索ダイアログの設定
                */
                $(TransferReferenceView.SELECTORS.btnBrand).on("click", brandSearchModal.open);

                /**
                * カラー検索ダイアログの設定
                */
                $(TransferReferenceView.SELECTORS.btnItemColor).on("click", colorSearchModal.open);

                /**
                * サイズ検索ダイアログの設定
                */
                $(TransferReferenceView.SELECTORS.btnItemSize).on("click", sizeSearchModal.open);

                /**
                 *Click button get data Brand
                 */
                $(TransferReferenceView.SELECTORS.brandSelect).on("click", function () {
                    $('#brandSearchResult input[type=radio]:checked').each(function (index, item) {
                        var brandId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var brandName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(TransferReferenceView.SELECTORS.brandId).val(brandId);
                        $(TransferReferenceView.SELECTORS.brandName).val(brandName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(TransferReferenceView.SELECTORS.colorSelect).on("click", function () {
                    $('#colorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var colorId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var colorName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(TransferReferenceView.SELECTORS.colorId).val(colorId);
                        $(TransferReferenceView.SELECTORS.colorName).val(colorName);
                    })
                });

                /**
                 *Click button get data Vendor
                 */
                $(TransferReferenceView.SELECTORS.sizeSelect).on("click", function () {
                    $('#sizeSearchResult input[type=radio]:checked').each(function (index, item) {
                        var sizeId = $(item).parents("tr").find("td:eq(2)").text().trim();
                        var sizeName = $(item).parents("tr").find("td:eq(3)").text().trim();
                        $(TransferReferenceView.SELECTORS.sizeId).val(sizeId);
                        $(TransferReferenceView.SELECTORS.sizeName).val(sizeName);
                    })
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function (difCnt) {
            },
        }

        /**
        * Page loaded
        */
        $(document).ready(function () {
            TransferReferenceView.init();
            var val = $('input:radio[name="SearchConditions.TransferClass"]:checked').val();
            if (val == 1) {
                $("#btnShipTo").attr("disabled","disabled");
                $("#ddlTransferFromCenterId").removeAttr("disabled");
                $("#txtTransferFromStoreName").val("");
                $("#txtTransferFromStoreId").val("");
            } else {
                $("#btnShipTo").removeAttr("disabled");
                $("#ddlTransferFromCenterId").attr("disabled","disabled");
                $("#ddlTransferFromCenterId").val("");
            }

            var arriveDateClass = $('#hidArriveDateClass').val();

            if (arriveDateClass == "ArrivePlanDate") {
                $('input:radio[name="SearchConditions.ArrivePlanDate"]').val('checked', true);
                $('input:radio[name="SearchConditions.TransferResultDate"]').val('checked', false);
                $('input[name^="SearchConditions.ArrivePlanDate"]').prop('disabled', false);
                $('input[name^="SearchConditions.TransferResultDate"]').prop('disabled', true);
            } else if (arriveDateClass == "TransferResultDate") {
                $('input:radio[name="SearchConditions.ArrivePlanDate"]').val('checked', false);
                $('input:radio[name="SearchConditions.TransferResultDate"]').val('checked', true);
                $('input[name^="SearchConditions.ArrivePlanDate"]').prop('disabled', true);
                $('input[name^="SearchConditions.TransferResultDate"]').prop('disabled', false);
            }

            chgTransferClass();

            if ($("#ddlCategoryId1").val() != '') {
                $("#ddlCategoryId2").removeAttr('disabled');
            }
            if ($("#ddlCategoryId2").val() != '') {
                    $("#ddlCategoryId3").removeAttr('disabled');
            }
            if ($("#ddlCategoryId3").val() != '') {
                    $("#ddlCategoryId4").removeAttr('disabled');
            }
                @* Pageを変更時 *@
                $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                    var urlAction ='@Url.Action("Search", "TransferReference", new { area= "Move" })';
                    var pageUrl = urlAction + '?Page=';
                    var page = $(item).attr("href").replace(pageUrl, "");
                    page = page.replace("&class=btn-outline-dark", "");
                    $(item).attr("href", "javascript:void(0);").click(function () {
                        $("#hidPage").val(page);
                        $("#hidSearchType").val("SortPage");
                        $("#frmSearch").attr("action", urlAction);
                        $("#frmSearch").attr("method", "POST");
                        $("#frmSearch").submit();
                    });
                });
        });

        function TransferClassChange() {
            var val = $('input:radio[name="SearchConditions.TransferClass"]:checked').val();
            if (val == 1) {
                $("#btnShipTo").attr("disabled","disabled");
                $("#ddlTransferFromCenterId").removeAttr("disabled");
                $("#txtTransferFromStoreName").val("");
                $("#txtTransferFromStoreId").val("");
            } else {
                $("#btnShipTo").removeAttr("disabled");
                $("#ddlTransferFromCenterId").attr("disabled","disabled");
                $("#ddlTransferFromCenterId").val("");
            }
        }

        function ArriveDateClassChange(val) {
            $('#hidArriveDateClass').val(val);

            if (val == "ArrivePlanDate") {
                $('input[name^="SearchConditions.ArrivePlanDate"]').prop('disabled', false);
                $('input[name^="SearchConditions.TransferResultDate"]').prop('disabled', true);
            } else if (val == "TransferResultDate") {
                $('input[name^="SearchConditions.ArrivePlanDate"]').prop('disabled', true);
                $('input[name^="SearchConditions.TransferResultDate"]').prop('disabled', false);
            }
        }

        function GetCategoryList(id) {
            var urlAction = '@Url.Action("GetCategoryList","ItemSku",new { area = "Master"})';
            $.ajax({
                url: urlAction,
                type: "POST",
                data: {
                    id: id + 1,
                    category1: $("#ddlCategoryId1").val(),
                    category2: $("#ddlCategoryId2").val(),
                    category3: $("#ddlCategoryId3").val()
                },
                success: function (data) {
                    $("#ddlCategoryId" + (id + 1)).html("");
                    $("#ddlCategoryId" + (id + 1)).html(data.html);
                }
            });
        }

        function CategoryChange(id) {
            if ($("#ddlCategoryId" + id).val() != '') {
                GetCategoryList(id);
                $("#ddlCategoryId" + (id + 1)).removeAttr('disabled');
                if (id == 1) {
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            } else {
                if (id == 1) {
                    $("#ddlCategoryId2").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId2").val('');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 3){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            }
        }

        // Sort
        function getSortData() {
            $("#hidSort").val($("#ddlSort").val());
            $("#hidSortKey").val($("#ddlSortKey").val());
            $("#hidSearchType").val("SortPage");

            var $form = $("#frmSearch");
            var urlAction ='@Url.Action("Search", "TransferReference", new { area= "Move" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function Search() {
            $("#hidSearchType").val("Search");
            var urlAction = '@Url.Action("Search", "TransferReference", new { area = "Move" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        $('#btnDetail').on("click", function () {
            $("#hidLineNo").val(0);
            var urlAction ='@Url.Action("DetailIndexSearch", "TransferReference", new { area= "Move" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        function Detail(seq,lineNo,unplannedFlag) {
            $("#hidSeq").val(seq);
            $("#hidLineNo").val(lineNo)
            $("#hidUnplannedFlag").val(unplannedFlag);
            var urlAction = '@Url.Action("DetailIndexSearch", "TransferReference", new { area = "Move" })';
            var $form = $("#frmSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }

        //移動区分変更時
        function chgTransferClass() {
            if ($("#txtStoreReturnFlag").prop("checked") == true || $("#txtBaseMoveNoWmsCenterFlag").prop("checked") == true) {
                $("#btnShipTo").removeAttr('disabled');
                $("#txtTransferFromStoreName").removeAttr('disabled');
            } else {
                $("#btnShipTo").attr('disabled', 'disabled');
                $("#txtTransferFromStoreName").val("");
                $("#txtTransferFromStoreId").val("");
                $("#txtTransferFromStoreName").attr('disabled', 'disabled');   
            }
            if ($("#txtBaseMoveFlag").prop("checked") == true) {
                $("#ddlTransferFromCenterId").removeAttr('disabled');
            } else {
                $("#ddlTransferFromCenterId").val("");
                $("#ddlTransferFromCenterId").attr('disabled', 'disabled');
            }
        }
    </script>
}