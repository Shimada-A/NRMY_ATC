                                    </th>
                                    <th class="bg-grey align-middle">
                                        @TransferReferenceResource.TransferStatus
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @TransferReferenceResource.ConfirmDate
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @TransferReferenceResource.UnplannedFlag
                                    </th>
                                    <th class="bg-grey align-middle">
                                        @TransferReferenceResource.BoxNo
                                    </th>
                                    <th hidden>
                                    </th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var cModel in Model.Results.TransferReference02s.Select((v, i) => new { v, i }))
                                {
                                    var key = String.Format("TransferReference02s[{0}].", cModel.i);
                                    <tr>
                                        <td class="align-middle chk_cell">
                                            <label>
                                                @if (int.Parse(cModel.v.TransferStatus) >= 4)
                                                {
                                                    <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" , disabled=true />
                                                }
                                                else
                                                {
                                                    <input type="radio" id=@(key + "CheckedValue") name="IsCheck" class="radio_input" onclick="SetIsCheck('@(key + "IsCheck")')" />

                                                }
                                                <span class="radio_parts"></span>
                                            </label>
                                            @Html.CheckBox(key + "IsCheck", new { @id = (key + "IsCheck"), @class = "check-box", hidden = true })
                                        </td>
                                        <td class="align-middle text-right">
                                            @((cModel.i + 1) + (Model.Results.TransferReference02s.PageNumber - 1) * Model.Results.TransferReference02s.PageSize)
                                        </td>
                                        @*<td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ArrivePlanDate)
                                        </td>*@
                                        <td class="align-middle text-left">
                                            @switch (cModel.v.TransferClass)
                                            {
                                                case "1":
                                                    @TransferReferenceResource.BaseMove
                                                    break;
                                                case "2":
                                                    @TransferReferenceResource.StoreReturn
                                                    break;
                                                case "3":
                                                    @TransferReferenceResource.BaseMoveNoWmsCenter
                                                    break;
                                                default:
                                                    break;
                                            }
                                        </td>
                                        <td class="align-middle text-left">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipDate)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.TransferFromStoreId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.TransferFromStoreName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipNo)
                                        </td>
                                        @*<td class="align-middle text-right">
                                            @Html.DisplayFor(modelItem => cModel.v.SlipSeq)
                                        </td>*@
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.BrandId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.BrandShortName)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.CategoryName1)
                                        </td>
                                        <td class="align-middle">
                                            @Html.DisplayFor(modelItem => cModel.v.ItemId)<br />
                                            @Html.DisplayFor(modelItem => cModel.v.ItemName)
