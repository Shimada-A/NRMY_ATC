    if (Model.Results.TransferReference02s != null && Model.Results.TransferReference02s.Count() > 0)
    {
        @* Sublbarea *@
        <div class="sublbarea no_border stock_detail_load">
            <div class="sortarea">
                <ul>
                    @*<li>
                        <button type="button" id="btnPrint" class="download" style="width:200px">
                            <img src="~/Content/img/print.png" />
                            @TransferReferenceResource.BtnPrint
                        </button>
                    </li>*@
                    <li>
                        <button type="button" id="btnDownload" class="download">
