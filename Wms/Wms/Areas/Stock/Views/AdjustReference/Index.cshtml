@Html.Partial("~/Areas/Master/Views/Shared/_BrandSearchModal.cshtml", "dialog")
@Html.Partial("~/Areas/Master/Views/Shared/_VendorSearchModal.cshtml")
@Html.Partial("~/Areas/Master/Views/Shared/_ColorSearchModal.cshtml")
@Html.Partial("~/Areas/Master/Views/Shared/_SizeSearchModal.cshtml")

@section LayoutScripts{
    <script>
        const CategoryId = '#ddlCategoryId';
        const IndexFrom = 1;
        const IndexTo = 4;
        const addChangeCagegoryEvent = function (index) {
            if (!$(CategoryId + index).val()) {
                changeCategoryDisabled(index);
            }

            $(CategoryId + index).off('change').on('change', () => changeCategory(index));
        };
        const changeCategory = function (index) {
            const val = $(CategoryId + index).val();

            changeCategoryDisabled(index);

            if (index === IndexFrom && !val) {
                return;
            }

            if (val) {
                changeCategory(index + 1);
            } else {
                setCategoryList(index, () => changeCategoryDisabled(index));
            }
        };
        const changeCategoryDisabled = function (index) {
            $('.cat1, .cat2, .cat3').removeAttr('disabled');
            $('.cat' + index).attr('disabled', 'disabled');
            $('.cat' + index).val('');
        };
        const setCategoryList = function (index, callBack) {
            const urlAction = '@Url.Action("GetCategoryList", "ItemSku", new { area = "Master"})';

            $.ajax({
            url: urlAction,
                type: "POST",
                data: {
                id: index,
                    category1: $(CategoryId + 1).val(),
                    category2: $(CategoryId + 2).val(),
                    category3: $(CategoryId + 3).val(),
                },
                success: function (data) {
                    $(CategoryId + index).empty();
                    $(CategoryId + index).html(data.html);
                    callBack();
                },
            });
        };
      //  const addClickEvent = function (id, func) {
      //      $(id).off('click').on('click', func);
      //  };
      //  const addChangeEvent = function (id, func) {
      //      $(id).off('change').on('change', func);
      //  };
        const addModalEvent = function (button, result, id, name, isVendor) {
            $(button).on("click", function () {
                const colId = isVendor ? 4 : 2;
                const colName = isVendor ? 5 : 3;

                $(result + ' input[type=radio]:checked').each(function (i, val) {
                    const valId = $(val).parents('tr').find('td:eq(' + colId + ')').text().trim();
                    const valName = $(val).parents('tr').find('td:eq(' + colName + ')').text().trim();

                    $(id).val(valId);
                    $(name).val(valName);
                });
            });
        };
        const setPageInformation = function () {
            const sortOrder = $('#ddlSortOrder option:selected').val();
            const ascDesc = $('#ddlAscDesc option:selected').val();

            if (sortOrder) {
                $('.hiddenSortOrder').val(sortOrder);
            }

            if (ascDesc) {
                $('.hiddenAscDesc').val(ascDesc);
            }
        };

        $(document).ready(function () {
            colorSearchModal.init();
            sizeSearchModal.init();
            brandSearchModal.init();
            vendorSearchModal.init();

            if ('@Model.CanChangeCenter'.toLowerCase() === 'true') {
                $('#ddlCenterId').removeAttr('disabled');
            }

            for (let i = IndexTo; i >= IndexFrom; i--) {
                addChangeCagegoryEvent(i);
            }

            addClickEvent('#btnSearch', function () {
                setPageInformation();
                $('#frmSearch').submit();
            });
            addChangeEvent('#ddlSortOrder, #ddlAscDesc', function () {
                setPageInformation();
                $('#frmReSearch').submit();
            });
            addClickEvent('#btnDownload', function () {
                $('#frmDownloadExcel').submit();
            });
            addClickEvent('#btnPrint', function () {
                $('#frmPrint').submit();
            });

            addClickEvent('#btnColor', () => colorSearchModal.open());
            addModalEvent('#colorSelect', '#colorSearchResult', '#txtColorId', '#txtColorName');
            addClickEvent('#btnSize', () => sizeSearchModal.open());
            addModalEvent('#sizeSelect', '#sizeSearchResult', '#txtSizeId', '#txtSizeName');
            addClickEvent('#btnBrand', () => brandSearchModal.open());
            addModalEvent('#brandSelect', '#brandSearchResult', '#txtBrandId', '#txtBrandName');
            addClickEvent('#btnVendor', () => vendorSearchModal.open());
            addModalEvent('#vendorSelect', '#vendorSearchResult', '#txtVendorIdx', '#txtVendorNamex', true);
        });
    </script>
}

