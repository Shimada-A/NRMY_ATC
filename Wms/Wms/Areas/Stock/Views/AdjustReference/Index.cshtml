@if (Model.IsShowResultList && !Model.Result.IsEmpty())
{
    <div class="sublbarea no_border stock_detail_load">
        @using (Html.BeginForm("DownloadExcel", "AdjustReference", FormMethod.Post, new { id = "frmDownloadExcel" }))
        {
            @Html.AntiForgeryToken()
        }
        @using (Html.BeginForm("Print", "AdjustReference", FormMethod.Post, new { id = "frmPrint" }))
        {
            @Html.AntiForgeryToken()
        }
        <div class="sortarea">
            <ul>
                <li>
                    <button type="button" id="btnDownload" class="download">
                        <img src="~/Content/img/download.png" />
                        @FormsResource.BTN_DOWNLOAD
                    </button>
                </li>
                <li>
                    <button type="button" id="btnPrint" class="download download-large">
                        <img src="~/Content/img/print.png" />
                        @AdjustReferenceResource.ButtonPrint
                    </button>
                </li>
            </ul>
        </div>
    </div>
    <div class="sublbarea no_border">
        <div class="sortarea mainpagearea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.Condition.SortOrder, new { Name = "AdjustReferenceSortOrder", @id = "ddlSortOrder" })
                        </div>
                    </div>
                </li>
                <li>
