@using Share.Common;
@using Wms.Helpers;
@using PagedList.Mvc;
@using Wms.Areas.Stock.Resources;
@model Wms.Areas.Stock.ViewModels.Adjust.AdjustViewModel
@{
    ViewBag.Title = Wms.Common.Resources.MenuResource.W_STK_Adjust;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* Head *@
<div id="div_search" class="head head_white collapse">
    @using (Html.BeginForm("Search", "Adjust", FormMethod.Post, new { id = "frmSearch" }))
    {
        @Html.AntiForgeryToken()
        <table>
            <tr>
                <td class="tdtitle">@AdjustResource.CenterIdS</td>
                <td colspan="3">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.CenterDropDownFor(
                                model => model.SearchConditions.CenterId
                                , Wms.Common.Profile.User.UserId
                                , "", new { @id = "ddlCenterId", tabindex = "1" })
                        </div>
                    </div>
                </td>
                <td class="tdtitle">@AdjustResource.DivisionIdS</td>
                <td colspan="4">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.DivisionId,
                                (IEnumerable<SelectListItem>)ViewBag.DivisionList,
                                CommonResource.None, new { id = "ddlDivisionId", tabindex = "14" })
                        </div>
                    </div>
                </td>
            </tr>
            <tr>
                <td class="tdtitle_large">@AdjustResource.LocationClassS</td>
                <td colspan="3">
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.DropDownListFor(
                                model => model.SearchConditions.LocationClass,
                                (IEnumerable<SelectListItem>)ViewBag.LocationClassList,
                                CommonResource.None, new { id = "ddlLocationClass", tabindex = "2" })
                        </div>
                    </div>
                </td>
                <td class="tdtitle">@AdjustResource.BrandIdS</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.BrandId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtBrandId", tabindex = "15" } })
                    @Html.EditorFor(model => model.SearchConditions.BrandName, new { htmlAttributes = new { @class = "w_18_normal", @id = "txtBrandName", tabindex = "16" } })
                    <div class="search">
                        <button type="button" id="btnBrandId" class="search_btn" tabindex="17" />
                    </div>
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@AdjustResource.Locsec1S</td>
                <td colspan="3">
                    @Html.EditorFor(model => model.SearchConditions.Locsec1, new { htmlAttributes = new { @class = "w_6_short", @id = "txtLocsec1", tabindex = "3" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td class="tdtitle">@AdjustResource.MainVendorIdS</td>
                <td colspan="4">
                    @Html.EditorFor(model => model.SearchConditions.MainVendorId, new { htmlAttributes = new { @class = "w_6_short", @id = "txtMainVendorId", tabindex = "18" } })
                    @Html.EditorFor(model => model.SearchConditions.MainVendorName, new { htmlAttributes = new { @class = "w_18_normal", @id = "txtMainVendorName", tabindex = "19" } })
                    <div class="search">
                        <button type="button" id="btnMainVendor" class="search_btn" tabindex="20" />
                    </div>
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
            </tr>
            <tr>
                <td class="tdtitle">@AdjustResource.LocationCdS</td>
                <td colspan="3">
                    <div>
                        @Html.EditorFor(model => model.SearchConditions.LocationCdFrom, new { htmlAttributes = new { @class = "column_byte_20", @id = "txtLocationCdFrom", tabindex = "4" } })
