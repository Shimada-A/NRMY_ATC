                            <th class="bg-grey  align-middle">
                                @ResearchReferenceResource.ThRegistClass
                            </th>
                            <th class="bg-grey  align-middle">
                                @ResearchReferenceResource.ThRegistUserId
                            </th>
                            <th class="bg-grey  align-middle">
                                @ResearchReferenceResource.ThBatchNo2
                            </th>
                            <th class="bg-grey  align-middle">
                                @ResearchReferenceResource.ThLocation2
                            </th>
                            <th class="bg-grey  align-middle">
                                @ResearchReferenceResource.ThInvoiceNo2
                            </th>
                            <th class="bg-grey  align-middle">
