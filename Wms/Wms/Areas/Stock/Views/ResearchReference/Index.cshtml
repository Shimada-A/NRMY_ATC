@{
    var storeConditions = new ViewDataDictionary { { "ParameterStoreId", Model.Condition.ShippingStoreId }, { "TempStoreId", Model.Condition.ShippingStoreId } };
}
@Html.Partial("~/Areas/Master/Views/Shared/_SyukkasakiSearchModal.cshtml", storeConditions)
@Html.Partial("_ConfirmMessageDialog", new Wms.Models.MessageDialog() { Id = "Update", Message = ResearchReferenceResource.MsgUpdate })


@section LayoutScripts
{
    @Scripts.Render("~/Scripts/My/SyukkasakiSearchModal.js")
<script>
        let selectedRowForm = null;
        const isEmpty = function (val) {
            return !val;
        };
        const isHh24mmss = function (val) {
            return val.match(/^([01]?[0-9]|2[0-3]):([0-5][0-9]):([0-5][0-9])$/) !== null;
        };
        //const addClickEvent = function (id, func) {
        //    $(id).off('click').on('click', func);
        //};
        //const addChangeEvent = function (id, func) {
        //    $(id).off('change').on('change', func);
        //};
        const addBlurEvent = function (id, func) {
            $(id).off('blur').on('blur', func);
        };
        const addCheckTimeBlurEvent = function (timeId, messageId) {
            const func = function () {
                const val = $(timeId).val();

                if (isEmpty(val) || isHh24mmss(val)) {
                    $(messageId).text('');
                    $(messageId).removeClass("field-validation-error");
                    $(timeId).removeClass("input-validation-error");
                    return;
                } else {
                    $(messageId).text('@ResearchReferenceResource.MessageTimeFormatError');
                    $(messageId).addClass("field-validation-error");
                    $(timeId).addClass("input-validation-error");
                }
            };

            addBlurEvent(timeId, func);
        };
        const setPageInformation = function () {
            const sortOrder = $('#ddlSortOrder option:selected').val();
            const ascDesc = $('#ddlAscDesc option:selected').val();

            if (sortOrder) {
                $('.hiddenSortOrder').val(sortOrder);
            }

            if (ascDesc) {
                $('.hiddenAscDesc').val(ascDesc);
            }
        };
        const clearCheckBox = function () {
            $('#resultRowList td .check-box').prop('checked', false);
            $('#resultRowList td .radio_input').prop('checked', false);
        };
        const setCheckBox = function (selector) {
            selector.find('.check-box').prop('checked', true);
            selector.find('.radio_input').prop('checked', true);

            const uniqueQuery = '&uniqueKey=';
            const uniqueKey = selector.attr('id');

            $('.pager').find('a').each(function (index, element) {
                const href = $(element).attr('href');

                if (href) {
                    const i = href.indexOf(uniqueQuery);
                    const newHref = i < 0 ? href : href.slice(0, i);

                    $(element).attr('href', newHref + uniqueQuery + uniqueKey);
                }
            });
        };

        $(document).ready(function () {
            if ('@Model.CanChangeCenter'.toLowerCase() === 'true') {
                $('#ddlCenterId').removeAttr('disabled');
            }

            $('#btnResearchInput').attr('disabled', 'disabled');
            $('#btnUpdate').attr('disabled', 'disabled');
            clearCheckBox();
            $('.uniqueKey').each(function (index, element) {
                const uniqueKey = $(element).attr('id');

                if (uniqueKey === '@Model.Result.SelectedUniqueKey') {
                    setCheckBox($(element));
                    $('#btnResearchInput').removeAttr('disabled');
                    return false;
                }
            });

            addCheckTimeBlurEvent('#txtOccurredTimeFrom', '#msgOccurredTimeFrom');
            addCheckTimeBlurEvent('#txtOccurredTimeTo', '#msgOccurredTimeTo');
            addClickEvent('#btnSearch', function () {
                if ($('body .input-validation-error').length) {
                    return;
                }

                $('#frmSearch').submit();
            });
            addChangeEvent('#ddlSortOrder, #ddlAscDesc', function () {
                setPageInformation();
                $('#frmReSearch').submit();
            });
            addClickEvent('#resultRowList td .radio_input', function () {
                clearCheckBox();
                setCheckBox($(this).parents('td'));
                $('#btnResearchInput').removeAttr('disabled');

                var registClass = $(this).parents('td').find('.registClass_input').val();
                var status = $(this).parents('td').find('.Status_input').val();
                if (registClass == "7" && status == "0") {
                    $('#btnUpdate').removeAttr('disabled');
                } else {
                    $('#btnUpdate').attr('disabled', 'disabled');
                };
                $('.hiddenSelectedUniqueKey').val($(this).parents('td').attr('id'));
                selectedRowForm = $(this).parents('tr').find('form');
            });
            addClickEvent('#btnResearchInput', function () {
                if (!selectedRowForm) {
                    return;
                }

                selectedRowForm.submit();
            });
            addClickEvent('#btnDownload', function () {
                $('#frmDownloadExcel').submit();
            });
            addClickEvent('#btnPrint', function () {
                $('#frmPrint').submit().attr('target', '_self');
            });
            addClickEvent('#btnUpdate', function () {
                if (!selectedRowForm) {
                    return;
                }
                $('#btnUpdateHidden').click();
            });
            addClickEvent('#Update', function () {
                if (!selectedRowForm) {
                    return;
                }
                var urlAction = '@Url.Action("Update", "ResearchReference", new { area = "Stock" })';
                selectedRowForm.attr("action", urlAction);
                selectedRowForm.submit();
            });
        });

</script>
}
