        @Html.HiddenFor(vm => vm.Condition.PageNumber, new { @id = "hiddenPageNumber2", @class = "hiddenPageNumber" })
        @Html.HiddenFor(vm => vm.Condition.SortOrder, new { @id = "hiddenSortOrder2", @class = "hiddenSortOrder" })
        @Html.HiddenFor(vm => vm.Condition.AscDescSort, new { @id = "hiddenAscDesc2", @class = "hiddenAscDesc" })
