                        new { htmlAttributes = new { @class = "w_18_normal", @id = "txtInvoiceNo", tabindex = "19" } })
                </td>
            </tr>
            <tr>
                <td class="tdtitle">
                    @ResearchReferenceResource.LabelJan
                </td>
                <td colspan="4">
                    @Html.EditorFor(
                        model => model.Condition.Jan,
                        new { htmlAttributes = new { @class = "w_18_normal", @id = "txtJan", tabindex = "14" } })
                    @Html.LikeMark(CommonsResource.BeforeLike)
                </td>
                <td class="tdtitle">
                    @ResearchReferenceResource.LabelBoxNo
                </td>
                <td colspan="4">
                    @Html.EditorFor(
                        model => model.Condition.BoxNo,
                        new { htmlAttributes = new { @class = "w_18_normal", @id = "txtBoxNo", tabindex = "20" } })
