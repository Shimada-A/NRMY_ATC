                                        @Html.Hidden("ResearchNote", row.ResearchNote, new { @id = key + "ResearchNote" })
                                    </td>
                                    <td>
                                        @row.SlipNo
                                    </td>
                                    <td>
                                        @row.GetOccurredDateTimeString()
                                    </td>
                                    <td>
                                        @row.RegistClassName
                                    </td>
                                    <td>
                                        @row.RegistUserId
