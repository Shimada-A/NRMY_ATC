                    </button>
                </li>
                <li>
                    <button type="button" id="btnReport" class="download">
                        <img src="~/Content/img/print.png" />
                        @PurchaseReferenceResource.BtnPlanPrint
                    </button>
                </li>
            </ul>
        </div>
    </div>
    <div class="sublbarea no_border">
        <div class="btn-group btn-group-toggle" data-toggle="buttons">
            <label class="btn btn-outline-dark active" id="lblDetail">
                <input type="radio" name="options" id="Detail" autocomplete="off"> @PurchaseReferenceResource.BtnDetailTab
            </label>
            <label class="btn btn-outline-dark" id="lblBox">
                <input type="radio" name="options" id="Box" autocomplete="off"> @PurchaseReferenceResource.BtnBoxTab
            </label>
        </div>
        <div class="sortarea mainpagearea">
            <ul>
                <li>
                    @FormsResource.DISPLAY_SHORT
                    <div class="sort">
                        <div class="sort_inner">
                            @if (Model.SearchConditions.ResultType == PurchaseReference02SearchConditions.ResultTypes.Detail)
                            {
                                @Html.EnumDropDownListFor(model => model.SearchConditions.DetailSort, new { Name = "SearchConditions.DetailSort", @id = "ddlDetailSort", @onchange = "getSortData();" })
                            }
                            else
                            {
                                @Html.EnumDropDownListFor(model => model.SearchConditions.BoxSort, new { Name = "SearchConditions.BoxSort", @id = "ddlBoxSort", @onchange = "getSortData();" })
                            }
                        </div>
                    </div>
                </li>
                <li>
                    <div class="sort">
                        <div class="sort_inner">
                            @Html.EnumDropDownListFor(model => model.SearchConditions.Sort, new { Name = "SearchConditions.Sort", @id = "ddlSort", @onchange = "getSortData();" })
                        </div>
                    </div>
                </li>
                <li class="totalcount">
                    @String.Format(Share.Common.Resources.FormsResource.KENSU, Model.Results.PurchaseReference02s.TotalItemCount.ToString("N0"))
                </li>
            </ul>
            @if (Model.Results.PurchaseReference02s.Count() > 0)
            {
                @Html.PagedListPager(Model.Results.PurchaseReference02s, Page => Url.Action("DetailSearch", "PurchaseReference", new { Page, @class = "btn-outline-dark" }), PagerHelper.Default)
            }
        </div>
    </div>
    if (Model.Results.PurchaseReference02s.Count() > 0)
    {
        <div class="sublbarea no_border stock_detail_head">
            <div class="sortarea">
                <ul>
                    <li>
                        @PurchaseReferenceResource.ItemSkuQtySum @Html.DisplayFor(model => model.SearchConditions.ItemSkuQtySum)
                    </li>
                    <li>
                        @PurchaseReferenceResource.ArrivePlanQtySum @Html.DisplayFor(model => model.SearchConditions.ArrivePlanQtySum)
                    </li>
                    <li>
                        @PurchaseReferenceResource.ResultQtySum @Html.DisplayFor(model => model.SearchConditions.ResultQtySum)
                    </li>
                    <li>
                        @PurchaseReferenceResource.PlanSlipNoSum @Html.DisplayFor(model => model.SearchConditions.PlanSlipNoSum)
                    </li>
                    <li>
                        @PurchaseReferenceResource.ResultSlipNoSum @Html.DisplayFor(model => model.SearchConditions.ResultSlipNoSum)
                    </li>
                </ul>
            </div>
        </div>
    }
}
