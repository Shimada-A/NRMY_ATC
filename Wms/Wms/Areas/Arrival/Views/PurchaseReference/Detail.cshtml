@Html.Partial("~/Areas/Master/Views/Shared/_BrandSearchModal.cshtml", "dialog")
@Html.Partial("~/Areas/Master/Views/Shared/_VendorSearchModal.cshtml")
@** スクリプト *@
@section LayoutScripts{
    <script>
        $("#SearchConditions_BrandId").select2({
            multiple: true,
            width: "500px",
            placeholder: "",
            allowClear: true,
            closeOnSelect: false
        });
        $("#btnDownload").on("click", function () {
            var urlAction = '@Url.Action("PurchaseReference02Download", "PurchaseReference", new { area = "Arrival" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "GET");
            $form.submit();
        });
        $("#btnReport").on("click", function () {
            //window.open("about:blank", "newtab");
            var urlAction = '@Url.Action("Report", "PurchaseReference", new { area = "Arrival" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            //$form.attr("target", "newtab");
            $form.submit();
            //$form.attr("target", "_self");
        });
        //$(".select2").select2();
    /**
     * Country class
     */
    var PurchaseReferenceView = {

        /**
         * CONST Object
         */
        CONST: {
            FORM_METHOD: 'formmethod',
            FORM_ACTION: 'formaction',
            POST: 'post',
            FORM: 'form',
            METHOD: 'method',
            ACTION: 'action'
        },

        /**
         * SELECTORS Object
         */
        SELECTORS: {
            chkInTable: '#listData input[type=radio][id$=".CheckedValue"]',
            chkCheckedInTable: '#listData input[type=radio][id$=".CheckedValue"]:checked',
            chkInRow: 'input[type=radio][class=check-box]',
            tblRow: '#listData tbody tr',
            btnCheckAll: '#rbCheckAll',
            btnUnCheckAll: '#rbUnCheckAll',
            rowSelected: '#spnCheckedCounter',
            btnResultInput: '#btnResultInput',
            btnEdit: '#btnUpdate',
            ddlSortKey: '#ddlSortKey',
            chkChecked: ':radio:checked',
            chkLabel: '#listData span.chk_parts',
            form: 'form',
            searchForm: '#frmDetailSearch',
            frmUpdate: 'frmUpdate',
            btnSubmit: 'button[type=submit],input[type=submit]',
            btnBrand: '#btnBrand',
            brandId:'#txtBrandId',
            brandName:'#txtBrandName',
            brandSelect: '#brandSelect',
            btnVendor:'#btnVendor',
            vendorId:'#txtVendorId',
            vendorName:'#txtVendorName',
            vendorSelect: '#vendorSelect',
        },

            /**
             * Init data
             */
            init: function () {
                this.registerEvent();
                this.setButtonStatus(0);
                brandSearchModal.init();
                vendorSearchModal.init();
            },

            /**
             * Register event for control
             */
            registerEvent: function () {

                /**
                 * Check box click
                 */
                $(PurchaseReferenceView.SELECTORS.chkInTable).click(function (evt) {
                    $(this).prop("checked", true);
                    evt.stopPropagation();
                    PurchaseReferenceView.setButtonStatus();
                });

                /**
                * 仕入先検索ダイアログの設定
                */
                $(PurchaseReferenceView.SELECTORS.btnVendor).on("click", vendorSearchModal.open);

                /**
                 *Click button get data Vendor
                 */
                $(PurchaseReferenceView.SELECTORS.vendorSelect).on("click", function () {
                    $('#vendorSearchResult input[type=radio]:checked').each(function (index, item) {
                        var vendorId = $(item).parents("tr").find("td:eq(4)").text().trim();
                        var vendorName = $(item).parents("tr").find("td:eq(5)").text().trim();
                        $(PurchaseReferenceView.SELECTORS.vendorId).val(vendorId);
                        $(PurchaseReferenceView.SELECTORS.vendorName).val(vendorName);
                    })
                });
            },

            /**
             * Enable/Disable button Edit
             */
            setButtonStatus: function () {
                // Enable/Disable button Edit
                if ($(PurchaseReferenceView.SELECTORS.chkCheckedInTable).length === 1) {
                    if (getUsable_Class() != 1) {
                        $(PurchaseReferenceView.SELECTORS.btnResultInput).removeAttr('disabled');
                    }
                } else {
                    $(PurchaseReferenceView.SELECTORS.btnResultInput).attr('disabled', 'disabled');
                }
            },
        }

    /**
    * Page loaded
    */
    $(document).ready(function () {
        PurchaseReferenceView.init();
        $("#ddlBoxSort").removeClass("input-validation-error");
        $("#ddlDetailSort").removeClass("input-validation-error");
        if ($("#ddlCategoryId1").val() != '') {
            $("#ddlCategoryId2").removeAttr('disabled');
        }
        if ($("#ddlCategoryId2").val() != '') {
                $("#ddlCategoryId3").removeAttr('disabled');
        }
        if ($("#ddlCategoryId3").val() != '') {
                $("#ddlCategoryId4").removeAttr('disabled');
        }
        if ('@Model.SearchConditions.ResultType'=='@PurchaseReference02SearchConditions.ResultTypes.BoxNo') {
            $("#lblDetail").removeClass("active");
            $("#lblBox").addClass("active");
            $("#Box").prop("checked", true);
            $("#Detail").prop("checked", false);
        } else {
            $("#lblDetail").addClass("active");
            $("#lblBox").removeClass("active");
            $("#Box").prop("checked", false);
            $("#Detail").prop("checked", true);
        }
            @* Pageを変更時 *@
            $(".mainpagearea .paging>li>a[href]").each(function (i, item) {
                var urlAction ='@Url.Action("DetailSearch", "PurchaseReference", new { area= "Arrival" })';
                var pageUrl = urlAction + '?Page=';
                var page = $(item).attr("href").replace(pageUrl, "");
                page = page.replace("&class=btn-outline-dark", "");
                $(item).attr("href", "javascript:void(0);").click(function () {
                    $("#hidPage").val(page);
                    $("#hidSearchType").val("SortPage");
                    $("#frmDetailSearch").attr("action", urlAction);
                    $("#frmDetailSearch").attr("method", "POST");
                    $("#frmDetailSearch").submit();
                });
            });
    });
        // Sort
        function getSortData() {

            $("#hidSort").val($("#ddlSort").val());
            $("#hidDetailSort").val($("#ddlDetailSort").val());
            $("#hidBoxSort").val($("#ddlBoxSort").val());
            $("#hidSearchType").val("SortPage");

            var $form = $("#frmDetailSearch");
            var urlAction ='@Url.Action("DetailSearch", "PurchaseReference", new { area= "Arrival" })';
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        function GetCategoryList(id) {
                    var urlAction = '@Url.Action("GetCategoryList","ItemSku",new { area = "Master"})';
                    $.ajax({
                        url: urlAction,
                        type: "POST",
                        data: {
                            id: id + 1,
                            category1: $("#ddlCategoryId1").val(),
                            category2: $("#ddlCategoryId2").val(),
                            category3: $("#ddlCategoryId3").val()
                        },
                        success: function (data) {
                            $("#ddlCategoryId" + (id + 1)).html("");
                            $("#ddlCategoryId" + (id + 1)).html(data.html);
                        }
                    });
        }
        function CategoryChange(id) {
            if ($("#ddlCategoryId" + id).val() != '') {
                GetCategoryList(id);
                $("#ddlCategoryId" + (id + 1)).removeAttr('disabled');
                if (id == 1) {
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            } else {
                if (id == 1) {
                    $("#ddlCategoryId2").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId2").val('');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 2){
                    $("#ddlCategoryId3").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId3").val('');
                    $("#ddlCategoryId4").val('');
                }else if(id == 3){
                    $("#ddlCategoryId4").attr('disabled', 'disabled');
                    $("#ddlCategoryId4").val('');
                }
            }
        }
        function Search() {
            $("#hidResultType").val("Detail");
            $("#hidSearchType").val("Search");
            var urlAction = '@Url.Action("DetailSearch", "PurchaseReference", new { area = "Arrival" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        }
        $("#Detail").on("click", function () {
            $("#hidResultType").val("Detail");
            $("#hidSearchType").val("Search");
            var urlAction = '@Url.Action("DetailSearch", "PurchaseReference", new { area = "Arrival" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });
        $("#Box").on("click", function () {
            $("#hidResultType").val("BoxNo");
            $("#hidSearchType").val("Search");
            var urlAction = '@Url.Action("DetailSearch", "PurchaseReference", new { area = "Arrival" })';
            var $form = $("#frmDetailSearch");
            $form.attr("action", urlAction);
            $form.attr("method", "POST");
            $form.submit();
        });

        function SetIsCheck(id) {
            $('#listData input[type=checkbox][id$=".IsCheck"]').prop("checked", false);
            $('#listData input[type=checkbox][id="' + id + '"]').prop("checked", true);
        }
    </script>
