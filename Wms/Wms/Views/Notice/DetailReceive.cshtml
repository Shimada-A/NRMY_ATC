                                        </td>
                                        break;
                                    default:
                                        break;
                                }
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.IfErrColumnComment)
                                </td>
                                <td class="align-middle">
                                    @Html.DisplayFor(modelItem => cModel.v.IfErrClassNm)
                                </td>
                            </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
