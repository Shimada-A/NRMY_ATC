@* 確認メッセージを表示します。(ex:注文完了時に注文番号を表示する。) *@
@* MessageDialog.jsが必要 *@

@* ModalDialogのid *@
@model Wms.Models.MessageDialog

    <div class="modal fade" id="@("err_"+Model.Id)" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog margintop" role="document" style="margin-top:15%;">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">@MessagesResource.TITLE_ERROR</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <p>@Model.Message</p>
                    </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-dark" data-dismiss="modal" id="@Model.Id">OK</button>
                </div>
            </div>
        </div>
    </div>