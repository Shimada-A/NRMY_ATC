@*
    ファイルアップロードのモーダルダイアログ
    FileUploadModal.js が必要
*@

@using Resources = Share.Common.Resources.FormsResource;

<div id="fileUploadModalDialog" style="display:none;">
    <div class="d_continer main">
        <span class="ui-helper-hidden-accessible">
            <input type="image" />
        </span>

        <div class="pgtitlearea">
            <h1 id="fileUploadTitle"></h1>
        </div>

        <div id="myDropzone" class="dropzone dz-clickable">
            <div class="dz-default dz-message" data-dz-message="">
                <span>@Resources.FileUploadMessage</span>
            </div>
        </div>

        <div class="bottomnav">
            <div class="btnarea">
                <button id="btnFileUploadComplete" type="button" class="btn btn-outline-dark btnsize">@Resources.Close</button>
            </div>
        </div>

        <div>
            <ul id="myDropzone-list"></ul>
        </div>
    </div>
</div>